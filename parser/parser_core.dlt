TK_NEWLINE: i32 = 1
TK_IDENT: i32 = 2
TK_INT: i32 = 3
TK_INT64: i32 = 4
TK_FLOAT: i32 = 5
TK_STRING: i32 = 6
TK_CHAR: i32 = 7
