# ==========================================
# Parser State
# ==========================================
p_kinds: i64 = 0
p_values: i64 = 0
p_indents: i64 = 0
p_count: i32 = 0
p_pos: i32 = 0

# ==========================================
# Module Name Registry
# Tracks names registered via import so the parser
# can produce namespace-qualified AST nodes.
# ==========================================
g_module_names: i64 = 0
g_module_count: i32 = 0

fun init_module_names():
    g_module_names = Memory.malloc_zeroed(256 * 8)
    g_module_count = 0

fun register_module_name(name: str):
    off: i64 = (g_module_count as i64) * 8
    Memory.write_i64(g_module_names + off, name as i64)
    g_module_count = g_module_count + 1

fun is_module_name(name: str) -> i32:
    i: i32 = 0
    while i < g_module_count:
        off: i64 = (i as i64) * 8
        m: str = Memory.read_i64(g_module_names + off) as str
        if str_eq(m, name) == 1:
            return 1
        i = i + 1
    return 0

# ==========================================
# Local Variable/Param Name Registry
# Tracks declared variables and function params so
# local names take priority over module names.
# ==========================================
g_local_names: i64 = 0
g_local_count: i32 = 0

fun init_local_names():
    g_local_names = Memory.malloc_zeroed(1024 * 8)
    g_local_count = 0

fun register_local_name(name: str):
    li: i32 = 0
    while li < g_local_count:
        loff: i64 = (li as i64) * 8
        lm: str = Memory.read_i64(g_local_names + loff) as str
        if str_eq(lm, name) == 1:
            return
        li = li + 1
    off: i64 = (g_local_count as i64) * 8
    Memory.write_i64(g_local_names + off, name as i64)
    g_local_count = g_local_count + 1

fun clear_local_names():
    g_local_count = 0

fun is_local_name(name: str) -> i32:
    i: i32 = 0
    while i < g_local_count:
        off: i64 = (i as i64) * 8
        m: str = Memory.read_i64(g_local_names + off) as str
        if str_eq(m, name) == 1:
            return 1
        i = i + 1
    return 0

# ==========================================
# Error Handling
# ==========================================
fun panic(msg: str):
    print(@"[PARSE ERROR] {msg}")
    ExitProcess(1)

# ==========================================
# String Helpers
# ==========================================
fun str_to_i64(s: str) -> i64:
    result: i64 = 0
    neg: i64 = 0
    idx: i64 = 0
    c: i8 = Memory.read_i8((s as i64) + idx)
    if c == 45:
        neg = 1
        idx = idx + 1
    c = Memory.read_i8((s as i64) + idx)
    while c >= 48 and c <= 57:
        result = result * 10 + ((c as i64) - 48)
        idx = idx + 1
        c = Memory.read_i8((s as i64) + idx)
    if neg == 1:
        return 0 - result
    return result

fun hex_to_i64(s: str) -> i64:
    result: i64 = 0
    idx: i64 = 0
    slen: i64 = Memory.strlen(s)
    while idx < slen:
        c: i8 = Memory.read_i8((s as i64) + idx)
        result = result * 16
        if c >= 48 and c <= 57:
            result = result + ((c as i64) - 48)
        elif c >= 65 and c <= 70:
            result = result + ((c as i64) - 55)
        elif c >= 97 and c <= 102:
            result = result + ((c as i64) - 87)
        idx = idx + 1
    return result

fun bin_to_i64(s: str) -> i64:
    result: i64 = 0
    idx: i64 = 0
    slen: i64 = Memory.strlen(s)
    while idx < slen:
        c: i8 = Memory.read_i8((s as i64) + idx)
        result = result * 2
        if c == 49:
            result = result + 1
        idx = idx + 1
    return result

fun oct_to_i64(s: str) -> i64:
    result: i64 = 0
    idx: i64 = 0
    slen: i64 = Memory.strlen(s)
    while idx < slen:
        c: i8 = Memory.read_i8((s as i64) + idx)
        result = result * 8 + ((c as i64) - 48)
        idx = idx + 1
    return result

fun str_eq(a: str, b: str) -> i32:
    la: i64 = Memory.strlen(a)
    lb: i64 = Memory.strlen(b)
    if la != lb:
        return 0
    i: i64 = 0
    while i < la:
        ca: i8 = Memory.read_i8((a as i64) + i)
        cb: i8 = Memory.read_i8((b as i64) + i)
        if ca != cb:
            return 0
        i = i + 1
    return 1

fun str_from_range(src: str, start: i64, end: i64) -> str:
    length: i64 = end - start
    buf: i64 = Memory.malloc_zeroed(length + 1)
    i: i64 = 0
    while i < length:
        c: i8 = Memory.read_i8((src as i64) + start + i)
        Memory.write_i8(buf + i, c)
        i = i + 1
    Memory.write_i8(buf + length, 0 as i8)
    return buf as str

# ==========================================
# Parser Init
# ==========================================
fun init_parser(kinds: i64, values: i64, indents: i64, count: i32):
    p_kinds = kinds
    p_values = values
    p_indents = indents
    p_count = count
    p_pos = 0

# ==========================================
# Token Navigation
# ==========================================
fun cur_kind() -> i32:
    if p_pos < p_count:
        return Memory.read_i32(p_kinds + ((p_pos as i64) * 4))
    return TK_EOF

fun cur_val() -> str:
    if p_pos < p_count:
        v: i64 = Memory.read_i64(p_values + ((p_pos as i64) * 8))
        return v as str
    return ""

fun cur_indent() -> i32:
    if p_pos < p_count:
        return Memory.read_i32(p_indents + ((p_pos as i64) * 4))
    return 0

fun peek_kind(offset: i32) -> i32:
    idx: i32 = p_pos + offset
    if idx < p_count:
        return Memory.read_i32(p_kinds + ((idx as i64) * 4))
    return TK_EOF

fun peek_val(offset: i32) -> str:
    idx: i32 = p_pos + offset
    if idx < p_count:
        v: i64 = Memory.read_i64(p_values + ((idx as i64) * 8))
        return v as str
    return ""

fun peek_indent(offset: i32) -> i32:
    idx: i32 = p_pos + offset
    if idx < p_count:
        return Memory.read_i32(p_indents + ((idx as i64) * 4))
    return 0

fun advance():
    if p_pos < p_count:
        p_pos = p_pos + 1

fun eat(expected: i32):
    if cur_kind() == expected:
        p_pos = p_pos + 1
    else:
        panic(@"Expected token kind {expected}, got {cur_kind()} (value='{cur_val()}')")

# Eat a > token, handling >> (SHIFT_RIGHT) by splitting it into two >
fun eat_greater():
    if cur_kind() == TK_GREATER:
        p_pos = p_pos + 1
    elif cur_kind() == TK_SHIFT_RIGHT:
        # Mutate >> to single > — outer parser consumes remaining >
        Memory.write_i32(p_kinds + ((p_pos as i64) * 4), TK_GREATER)
        Memory.write_i64(p_values + ((p_pos as i64) * 8), ">" as i64)
    else:
        panic(@"Expected '>' or '>>', got {cur_kind()} (value='{cur_val()}')")

fun skip_newlines() -> i32:
    while cur_kind() == TK_NEWLINE:
        p_pos = p_pos + 1
    return cur_indent()

# ==========================================
# Token Kind Checks
# ==========================================
fun is_type_token(k: i32) -> i32:
    return 0

fun is_comparison_op(k: i32) -> i32:
    if k == TK_EQUAL:
        return 1
    if k == TK_NOT_EQUAL:
        return 1
    if k == TK_LESS:
        return 1
    if k == TK_GREATER:
        return 1
    if k == TK_LESS_EQUAL:
        return 1
    if k == TK_GREATER_EQUAL:
        return 1
    return 0

fun is_additive_op(k: i32) -> i32:
    if k == TK_PLUS:
        return 1
    if k == TK_MINUS:
        return 1
    return 0

fun is_multiplicative_op(k: i32) -> i32:
    if k == TK_MULTIPLY:
        return 1
    if k == TK_DIVIDE:
        return 1
    if k == TK_MODULO:
        return 1
    return 0

fun is_assignment_op(k: i32) -> i32:
    if k == TK_ASSIGN:
        return 1
    if k == TK_PLUS_ASSIGN:
        return 1
    if k == TK_MINUS_ASSIGN:
        return 1
    if k == TK_MULT_ASSIGN:
        return 1
    if k == TK_DIV_ASSIGN:
        return 1
    return 0

fun is_literal_token(k: i32) -> i32:
    if k == TK_INT:
        return 1
    if k == TK_INT64:
        return 1
    if k == TK_FLOAT:
        return 1
    if k == TK_STRING:
        return 1
    if k == TK_CHAR:
        return 1
    if k == TK_FSTRING:
        return 1
    if k == TK_BOOL:
        return 1
    if k == TK_NULL:
        return 1
    if k == TK_HEX:
        return 1
    return 0

fun token_to_type_str(k: i32) -> str:
    if k == TK_BOOL:
        return "bool"
    if k == TK_TYPE:
        return "type"
    return ""

fun op_to_str(k: i32) -> str:
    if k == TK_PLUS:
        return "+"
    if k == TK_MINUS:
        return "-"
    if k == TK_MULTIPLY:
        return "*"
    if k == TK_DIVIDE:
        return "/"
    if k == TK_MODULO:
        return "%"
    if k == TK_EQUAL:
        return "=="
    if k == TK_NOT_EQUAL:
        return "!="
    if k == TK_LESS:
        return "<"
    if k == TK_GREATER:
        return ">"
    if k == TK_LESS_EQUAL:
        return "<="
    if k == TK_GREATER_EQUAL:
        return ">="
    if k == TK_AND:
        return "and"
    if k == TK_OR:
        return "or"
    if k == TK_NOT:
        return "not"
    if k == TK_BIT_AND:
        return "&"
    if k == TK_BIT_OR:
        return "|"
    if k == TK_BIT_XOR:
        return "^"
    if k == TK_SHIFT_LEFT:
        return "<<"
    if k == TK_SHIFT_RIGHT:
        return ">>"
    if k == TK_PLUS_ASSIGN:
        return "+="
    if k == TK_MINUS_ASSIGN:
        return "-="
    if k == TK_MULT_ASSIGN:
        return "*="
    if k == TK_DIV_ASSIGN:
        return "/="
    return "?"

# ==========================================
# Indented Block Parsing Helper
# ==========================================
# Parses an indented block of statements (body of if/while/for/fun)
# Returns a node_list of statement nodes
# The caller should provide a parse_stmt function pointer but since
# Dolet doesn't support function pointers yet, we'll handle this differently.
# The block parsing will be done inline in each statement parser.
