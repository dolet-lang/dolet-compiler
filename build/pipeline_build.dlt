# ContextBlockNode: f0=expression (node), f1=variable_name (str, 0 if none),
#                   f2=body (node_list), f3=has_as_clause (0/1)
fun mk_context_block(expr: i64, var_name: str, body: i64, has_as: i64) -> i64:
    n: i64 = alloc_node(NODE_CONTEXT_BLOCK)
    Memory.write_i64(n + 8, expr)
    Memory.write_i64(n + 16, var_name as i64)
    Memory.write_i64(n + 24, body)
    Memory.write_i64(n + 32, has_as)
    return n

