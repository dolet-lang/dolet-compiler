    return Memory.read_i64(n + 16)

fun adecl_etype(n: i64) -> str:
    return Memory.read_i64(n + 24) as str

# ArrayAccessNode: f0=target (i64 — str if simple, node if nested), f1=index (node), f2=is_nested (0/1)
fun mk_array_access(target: i64, index: i64, is_nested: i64) -> i64:
    n: i64 = alloc_node(NODE_ARRAY_ACCESS)
    Memory.write_i64(n + 8, target)
    Memory.write_i64(n + 16, index)
    Memory.write_i64(n + 24, is_nested)
    return n

