# AwaitExprNode: f0=expr (node)
fun mk_await(expr: i64) -> i64:
    n: i64 = alloc_node(NODE_AWAIT)
    Memory.write_i64(n + 8, expr)
    return n

fun await_expr(n: i64) -> i64:
