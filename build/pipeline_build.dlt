# BlockNode: f0=statements (node_list)
fun mk_block(stmts: i64) -> i64:
    n: i64 = alloc_node(NODE_BLOCK)
    Memory.write_i64(n + 8, stmts)
    return n

fun block_stmts(n: i64) -> i64:
