    NODE_UNARY_OP = 23
    NODE_CAST = 24
    NODE_PAREN = 25
    NODE_TERNARY = 26
    NODE_VAR_DECL = 30
    NODE_ASSIGN = 31
    NODE_IF = 40
    NODE_WHILE = 41
    NODE_FOR = 42
    NODE_FOR_EACH = 43
    NODE_BREAK = 44
    NODE_CONTINUE = 45
    NODE_PASS = 46
    NODE_RETURN = 47
    NODE_MATCH = 48
    NODE_CASE = 49
    NODE_PATTERN = 50
    NODE_FUN_DEF = 60
    NODE_FUN_CALL = 61
    NODE_BUILTIN_CALL = 62
    NODE_FUN_REF = 63
    NODE_AWAIT = 64
    NODE_BLOCK = 70
    NODE_EXTERN_FUN = 71
    NODE_EXTERN_BLOCK = 72
    NODE_CONTEXT_BLOCK = 73
    NODE_USE_STMT = 74
    NODE_STRUCT_DECL = 80
    NODE_STRUCT_FIELD = 81
    NODE_STRUCT_INST = 82
    NODE_FIELD_ACCESS = 83
    NODE_FIELD_ASSIGN = 84
    NODE_STATIC_METHOD = 85
    NODE_STATIC_FIELD = 86
    NODE_STATIC_FIELD_ASSIGN = 87
    NODE_INST_METHOD = 88
