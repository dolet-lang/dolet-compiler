##############################
# Parser Core
# State, navigation, error handling, token constants, string helpers
##############################

# ==========================================
# Token Type Constants
# (duplicated from tokenizer for directory independence)
# ==========================================

# ==========================================
# Parser State
# ==========================================
p_kinds: i64 = 0
p_values: i64 = 0
p_indents: i64 = 0
p_count: i32 = 0
p_pos: i32 = 0

# ==========================================
# Module Name Registry
# ==========================================
g_module_names: i64 = 0
g_module_count: i32 = 0

fun init_module_names():
    g_module_names = Memory.malloc_zeroed(256 * 8)
    g_module_count = 0

fun register_module_name(name: str):
    off: i64 = (g_module_count as i64) * 8
    Memory.write_i64(g_module_names + off, name as i64)
    g_module_count = g_module_count + 1

fun is_module_name(name: str) -> i32:
    i: i32 = 0
    while i < g_module_count:
        off: i64 = (i as i64) * 8
        m: str = Memory.read_i64(g_module_names + off) as str
        if str_eq(m, name) == 1:
            return 1
        i = i + 1
    return 0

# ==========================================
# Error Handling
# ==========================================

# ==========================================
# String Helpers
# ==========================================
fun str_to_i64(s: str) -> i64:
    result: i64 = 0
    neg: i64 = 0
    idx: i64 = 0
    c: i8 = Memory.read_i8((s as i64) + idx)
    if c == 45:
        neg = 1
        idx = idx + 1
    c = Memory.read_i8((s as i64) + idx)
    while c >= 48 and c <= 57:
        result = result * 10 + ((c as i64) - 48)
        idx = idx + 1
        c = Memory.read_i8((s as i64) + idx)
    if neg == 1:
        return 0 - result
    return result

fun hex_to_i64(s: str) -> i64:
    result: i64 = 0
    idx: i64 = 0
    slen: i64 = Memory.strlen(s)
    while idx < slen:
        c: i8 = Memory.read_i8((s as i64) + idx)
        result = result * 16
        if c >= 48 and c <= 57:
            result = result + ((c as i64) - 48)
        elif c >= 65 and c <= 70:
            result = result + ((c as i64) - 55)
        elif c >= 97 and c <= 102:
            result = result + ((c as i64) - 87)
        idx = idx + 1
    return result

fun bin_to_i64(s: str) -> i64:
    result: i64 = 0
    idx: i64 = 0
    slen: i64 = Memory.strlen(s)
    while idx < slen:
        c: i8 = Memory.read_i8((s as i64) + idx)
        result = result * 2
        if c == 49:
            result = result + 1
        idx = idx + 1
    return result

fun oct_to_i64(s: str) -> i64:
    result: i64 = 0
    idx: i64 = 0
    slen: i64 = Memory.strlen(s)
    while idx < slen:
        c: i8 = Memory.read_i8((s as i64) + idx)
        result = result * 8 + ((c as i64) - 48)
        idx = idx + 1
    return result



# ==========================================
# Parser Init
# ==========================================
fun init_parser(kinds: i64, values: i64, indents: i64, count: i32):
    p_kinds = kinds
    p_values = values
    p_indents = indents
    p_count = count
    p_pos = 0

# ==========================================
# Token Navigation
# ==========================================
fun cur_kind() -> i32:
    if p_pos < p_count:
        return Memory.read_i32(p_kinds + ((p_pos as i64) * 4))
    return TK_EOF

fun cur_val() -> str:
    if p_pos < p_count:
        v: i64 = Memory.read_i64(p_values + ((p_pos as i64) * 8))
        return v as str
    return ""

fun cur_indent() -> i32:
    if p_pos < p_count:
        return Memory.read_i32(p_indents + ((p_pos as i64) * 4))
    return 0

fun peek_kind(offset: i32) -> i32:
    idx: i32 = p_pos + offset
    if idx < p_count:
        return Memory.read_i32(p_kinds + ((idx as i64) * 4))
    return TK_EOF

fun peek_val(offset: i32) -> str:
    idx: i32 = p_pos + offset
    if idx < p_count:
        v: i64 = Memory.read_i64(p_values + ((idx as i64) * 8))
        return v as str
    return ""

fun peek_indent(offset: i32) -> i32:
    idx: i32 = p_pos + offset
    if idx < p_count:
        return Memory.read_i32(p_indents + ((idx as i64) * 4))
    return 0

fun advance():
    if p_pos < p_count:
        p_pos = p_pos + 1

fun eat(expected: i32):
    if cur_kind() == expected:
        p_pos = p_pos + 1
    else:
        panic(@"Expected token kind {expected}, got {cur_kind()} (value='{cur_val()}')")

# Eat a > token, handling >> (SHIFT_RIGHT) by splitting it into two >
fun eat_greater():
    if cur_kind() == TK_GREATER:
        p_pos = p_pos + 1
    elif cur_kind() == TK_SHIFT_RIGHT:
        # Mutate >> to single > — outer parser consumes remaining >
        Memory.write_i32(p_kinds + ((p_pos as i64) * 4), TK_GREATER)
        Memory.write_i64(p_values + ((p_pos as i64) * 8), ">" as i64)
    else:
        panic(@"Expected '>' or '>>', got {cur_kind()} (value='{cur_val()}')")

fun skip_newlines() -> i32:
    while cur_kind() == TK_NEWLINE:
        p_pos = p_pos + 1
    return cur_indent()

# ==========================================
# Token Kind Checks
# ==========================================
fun is_type_token(k: i32) -> i32:
    return 0

fun is_comparison_op(k: i32) -> i32:
    if k == TK_EQUAL:
        return 1
    if k == TK_NOT_EQUAL:
        return 1
    if k == TK_LESS:
        return 1
    if k == TK_GREATER:
        return 1
    if k == TK_LESS_EQUAL:
        return 1
    if k == TK_GREATER_EQUAL:
        return 1
    return 0

fun is_additive_op(k: i32) -> i32:
    if k == TK_PLUS:
        return 1
    if k == TK_MINUS:
        return 1
    return 0

fun is_multiplicative_op(k: i32) -> i32:
    if k == TK_MULTIPLY:
        return 1
    if k == TK_DIVIDE:
        return 1
    if k == TK_MODULO:
        return 1
    return 0

fun is_assignment_op(k: i32) -> i32:
    if k == TK_ASSIGN:
        return 1
    if k == TK_PLUS_ASSIGN:
        return 1
    if k == TK_MINUS_ASSIGN:
        return 1
    if k == TK_MULT_ASSIGN:
        return 1
    if k == TK_DIV_ASSIGN:
        return 1
    return 0

fun is_literal_token(k: i32) -> i32:
    if k == TK_INT:
        return 1
    if k == TK_INT64:
        return 1
    if k == TK_FLOAT:
        return 1
    if k == TK_STRING:
        return 1
    if k == TK_CHAR:
        return 1
    if k == TK_FSTRING:
        return 1
    if k == TK_BOOL:
        return 1
    if k == TK_NULL:
        return 1
    if k == TK_HEX:
        return 1
    return 0

fun token_to_type_str(k: i32) -> str:
    if k == TK_BOOL:
        return "bool"
    if k == TK_TYPE:
        return "type"
    return ""

fun op_to_str(k: i32) -> str:
    if k == TK_PLUS:
        return "+"
    if k == TK_MINUS:
        return "-"
    if k == TK_MULTIPLY:
        return "*"
    if k == TK_DIVIDE:
        return "/"
    if k == TK_MODULO:
        return "%"
    if k == TK_EQUAL:
        return "=="
    if k == TK_NOT_EQUAL:
        return "!="
    if k == TK_LESS:
        return "<"
    if k == TK_GREATER:
        return ">"
    if k == TK_LESS_EQUAL:
        return "<="
    if k == TK_GREATER_EQUAL:
        return ">="
    if k == TK_AND:
        return "and"
    if k == TK_OR:
        return "or"
    if k == TK_NOT:
        return "not"
    if k == TK_BIT_AND:
        return "&"
    if k == TK_BIT_OR:
        return "|"
    if k == TK_BIT_XOR:
        return "^"
    if k == TK_SHIFT_LEFT:
        return "<<"
    if k == TK_SHIFT_RIGHT:
        return ">>"
    if k == TK_PLUS_ASSIGN:
        return "+="
    if k == TK_MINUS_ASSIGN:
        return "-="
    if k == TK_MULT_ASSIGN:
        return "*="
    if k == TK_DIV_ASSIGN:
        return "/="
    return "?"

# ==========================================
# Indented Block Parsing Helper
# ==========================================
# Parses an indented block of statements (body of if/while/for/fun)
# Returns a node_list of statement nodes
# The caller should provide a parse_stmt function pointer but since
# Dolet doesn't support function pointers yet, we'll handle this differently.
# The block parsing will be done inline in each statement parser.

##############################
# Parser Expressions
# Recursive descent expression parser with operator precedence
# Depends on: parser_core.dlt, ast_nodes.dlt
##############################

# ==========================================
# Argument List Helper
# ==========================================
fun parse_one_arg() -> i64:
    # Check for named argument: name=value (e.g. Point(x=10, y=20))
    if cur_kind() == TK_IDENT and peek_kind(1) == TK_ASSIGN:
        aname: str = cur_val()
        advance()
        advance()
        aval: i64 = parse_expression()
        return mk_field_val(aname, aval)
    return parse_expression()

fun parse_arg_list() -> i64:
    args: i64 = mk_node_list(16)
    eat(TK_LPAREN)
    skip_newlines()
    if cur_kind() != TK_RPAREN:
        nl_add(args, parse_one_arg())
        skip_newlines()
        while cur_kind() == TK_COMMA:
            advance()
            skip_newlines()
            nl_add(args, parse_one_arg())
            skip_newlines()
    eat(TK_RPAREN)
    return args

# ==========================================
# Primary Expressions
# ==========================================
fun parse_primary() -> i64:
    k: i32 = cur_kind()

    # Integer literal
    if k == TK_INT or k == TK_INT64:
        v: str = cur_val()
        advance()
        return mk_int_lit(str_to_i64(v))

    if k == TK_HEX:
        v: str = cur_val()
        advance()
        return mk_int_lit(hex_to_i64(v))

    if k == TK_BINARY:
        v: str = cur_val()
        advance()
        return mk_int_lit(bin_to_i64(v))

    if k == TK_OCTAL:
        v: str = cur_val()
        advance()
        return mk_int_lit(oct_to_i64(v))

    # Float literal
    if k == TK_FLOAT:
        v2: str = cur_val()
        advance()
        return mk_float_lit(v2)

    # String literal
    if k == TK_STRING:
        v3: str = cur_val()
        advance()
        return mk_str_lit(v3)

    # F-string literal — parse {expr} interpolation into parts
    if k == TK_FSTRING:
        v4: str = cur_val()
        advance()
        parts: i64 = mk_node_list(8)
        flen: i64 = Memory.strlen(v4)
        fi: i64 = 0
        seg_start: i64 = 0
        while fi < flen:
            ch: i8 = Memory.read_i8((v4 as i64) + fi)
            if ch == 123:
                # '{' — add literal text before this
                if fi > seg_start:
                    nl_add(parts, mk_str_lit(str_from_range(v4, seg_start, fi)))
                # Find matching '}'
                fi = fi + 1
                expr_start: i64 = fi
                brace_depth: i32 = 1
                while fi < flen and brace_depth > 0:
                    bc: i8 = Memory.read_i8((v4 as i64) + fi)
                    if bc == 123:
                        brace_depth = brace_depth + 1
                    elif bc == 125:
                        brace_depth = brace_depth - 1
                    if brace_depth > 0:
                        fi = fi + 1
                # Extract expression name and create appropriate node
                if fi > expr_start:
                    expr_name: str = str_from_range(v4, expr_start, fi)
                    elen: i64 = Memory.strlen(expr_name)
                    # Check for function call pattern: name()
                    has_parens: i32 = 0
                    if elen >= 3:
                        p1: i8 = Memory.read_i8((expr_name as i64) + elen - 2)
                        p2: i8 = Memory.read_i8((expr_name as i64) + elen - 1)
                        if p1 == 40 and p2 == 41:
                            has_parens = 1
                    if has_parens == 1:
                        fn_name: str = str_from_range(expr_name, 0 as i64, elen - 2)
                        empty_args: i64 = mk_node_list(0)
                        nl_add(parts, mk_fun_call(fn_name, empty_args, 0))
                    else:
                        # Check for self.field pattern
                        # Find dot position
                        di: i64 = 0
                        dot_pos: i64 = -1
                        while di < elen:
                            dc: i8 = Memory.read_i8((expr_name as i64) + di)
                            if dc == 46:
                                dot_pos = di
                                break
                            di = di + 1
                        if dot_pos > 0:
                            obj_part: str = str_from_range(expr_name, 0 as i64, dot_pos)
                            field_part: str = str_from_range(expr_name, dot_pos + 1, elen)
                            if str_eq(obj_part, "self") == 1:
                                nl_add(parts, mk_self_field(field_part))
                            else:
                                nl_add(parts, mk_field_access(obj_part, field_part))
                        else:
                            nl_add(parts, mk_var_ref(expr_name))
                if fi < flen:
                    fi = fi + 1
                seg_start = fi
            else:
                fi = fi + 1
        # Add remaining literal text
        if seg_start < flen:
            nl_add(parts, mk_str_lit(str_from_range(v4, seg_start, flen)))
        if nl_count(parts) == 0:
            nl_add(parts, mk_str_lit(""))
        return mk_fstring(parts)

    # Char literal
    if k == TK_CHAR:
        v5: str = cur_val()
        advance()
        return mk_char_lit(v5)

    # Bool literal
    if k == TK_BOOL:
        v6: str = cur_val()
        advance()
        if str_eq(v6, "true") == 1:
            return mk_bool_lit(1)
        return mk_bool_lit(0)

    # Null literal
    if k == TK_NULL:
        advance()
        return mk_null_lit()

    # Parenthesized expression
    if k == TK_LPAREN:
        eat(TK_LPAREN)
        inner: i64 = parse_expression()
        eat(TK_RPAREN)
        return mk_paren(inner)

    # Array/List literal: [elem, ...]
    if k == TK_LBRACKET:
        return parse_bracket_literal()

    # Self
    if k == TK_SELF:
        advance()
        if cur_kind() == TK_DOT:
            advance()
            fname: str = cur_val()
            eat(TK_IDENT)
            # self.method()
            if cur_kind() == TK_LPAREN:
                sargs: i64 = parse_arg_list()
                return mk_inst_method("self", fname, sargs)
            # self.field
            return mk_self_field(fname)
        return mk_self()

    # Super
    if k == TK_SUPER:
        advance()
        eat(TK_DOT)
        mname: str = cur_val()
        eat(TK_IDENT)
        sup_args: i64 = parse_arg_list()
        return mk_super_method(mname, sup_args)

    # Builtin call: @sqrt(x)
    if k == TK_BUILTIN_CALL:
        bname: str = cur_val()
        advance()
        bargs: i64 = parse_arg_list()
        return mk_builtin_call(bname, bargs)

    # Identifier (variable, function call, method call, field access)
    if k == TK_IDENT:
        return parse_ident_expr()

    panic(@"Unexpected token in expression: kind={k} val='{cur_val()}'")
    return 0

# ==========================================
# Identifier Expression
# Handles: var_ref, fun_call, static_method, field_access, etc.
# ==========================================
fun parse_ident_expr() -> i64:
    name: str = cur_val()
    eat(TK_IDENT)

    # Function call: name(args)
    if cur_kind() == TK_LPAREN:
        cargs: i64 = parse_arg_list()
        fc_node: i64 = mk_fun_call(name, cargs, 0)
        if cur_kind() == TK_DOT or cur_kind() == TK_NEWLINE:
            return parse_chained_dot(fc_node)
        return fc_node

    # Dot access: name.something
    if cur_kind() == TK_DOT:
        return parse_dot_access(name)

    # Array access: name[index]
    if cur_kind() == TK_LBRACKET:
        eat(TK_LBRACKET)
        idx_expr: i64 = parse_expression()
        eat(TK_RBRACKET)
        return mk_array_access(name as i64, idx_expr, 0)

    # Simple variable reference
    return mk_var_ref(name)

# ==========================================
# Dot Access Chain
# Handles: Struct.method(), obj.field, obj.method(), Enum.Value
# ==========================================
fun parse_dot_access(first: str) -> i64:
    eat(TK_DOT)
    member: str = cur_val()
    eat(TK_IDENT)

    # Namespace-qualified access: ns.func() or ns.Struct.method()
    if is_module_name(first) == 1:
        if cur_kind() == TK_LPAREN:
            nargs: i64 = parse_arg_list()
            nfc: i8 = Memory.read_i8(member as i64)
            ns_node: i64 = 0
            if nfc >= 65 and nfc <= 90:
                ns_node = mk_ns_struct_inst(first, member, nargs, 0)
            else:
                ns_node = mk_ns_fun_call(first, member, nargs, 0)
            if cur_kind() == TK_DOT or cur_kind() == TK_NEWLINE:
                return parse_chained_dot(ns_node)
            return ns_node
        if cur_kind() == TK_DOT:
            eat(TK_DOT)
            third: str = cur_val()
            eat(TK_IDENT)
            if cur_kind() == TK_LPAREN:
                targs: i64 = parse_arg_list()
                tfc: i8 = Memory.read_i8(member as i64)
                ns_node2: i64 = 0
                if tfc >= 65 and tfc <= 90:
                    ns_node2 = mk_ns_static_method(first, member, third, targs)
                else:
                    ns_node2 = mk_ns_fun_call(first, third, targs, 0)
                if cur_kind() == TK_DOT or cur_kind() == TK_NEWLINE:
                    return parse_chained_dot(ns_node2)
                return ns_node2
            return mk_ns_access(first, member)
        return mk_ns_access(first, member)

    # Static/instance method call: Name.method(args)
    if cur_kind() == TK_LPAREN:
        margs: i64 = parse_arg_list()
        # If first char is uppercase, treat as static method
        fc: i8 = Memory.read_i8(first as i64)
        node: i64 = 0
        if fc >= 65 and fc <= 90:
            node = mk_static_method(first, member, margs)
        else:
            node = mk_inst_method(first, member, margs)
        # Check for chaining continuation (direct dot or newline+dot)
        if cur_kind() == TK_DOT or cur_kind() == TK_NEWLINE:
            return parse_chained_dot(node)
        return node

    # Chained dot: Name.member.something
    if cur_kind() == TK_DOT:
        # Build base node
        fc2: i8 = Memory.read_i8(first as i64)
        base: i64 = 0
        if fc2 >= 65 and fc2 <= 90:
            base = mk_static_field(first, member)
        else:
            base = mk_field_access(first, member)
        return parse_chained_dot(base)

    # Assignment: Name.field = value
    if cur_kind() == TK_ASSIGN:
        advance()
        aval: i64 = parse_expression()
        fc3: i8 = Memory.read_i8(first as i64)
        if fc3 >= 65 and fc3 <= 90:
            return mk_static_field_assign(first, member, aval)
        return mk_field_assign(first, member, aval)

    # Array access on field: obj.field[index]
    if cur_kind() == TK_LBRACKET:
        eat(TK_LBRACKET)
        aidx: i64 = parse_expression()
        eat(TK_RBRACKET)
        fc4: i8 = Memory.read_i8(first as i64)
        base2: i64 = 0
        if fc4 >= 65 and fc4 <= 90:
            base2 = mk_static_field(first, member)
        else:
            base2 = mk_field_access(first, member)
        return mk_array_access(base2, aidx, 1)

    # Simple field/static field access
    fc5: i8 = Memory.read_i8(first as i64)
    if fc5 >= 65 and fc5 <= 90:
        return mk_static_field(first, member)
    return mk_field_access(first, member)

# ==========================================
# Chained Dot Access: a.b.c.d
# ==========================================
fun parse_chained_dot(base: i64) -> i64:
    result: i64 = base
    while 1 == 1:
        # Direct dot continuation
        if cur_kind() == TK_DOT:
            pass
        elif cur_kind() == TK_NEWLINE:
            # Peek past newlines to see if next non-NL token is TK_DOT
            save_pos: i32 = p_pos
            skip_newlines()
            if cur_kind() == TK_DOT:
                pass
            else:
                p_pos = save_pos
                break
        else:
            break
        advance()
        nxt: str = cur_val()
        eat(TK_IDENT)
        if cur_kind() == TK_LPAREN:
            nargs: i64 = parse_arg_list()
            result = mk_nested_method(result, nxt, nargs)
        elif cur_kind() == TK_ASSIGN:
            advance()
            nval: i64 = parse_expression()
            result = mk_field_assign("", nxt, nval)
        else:
            result = mk_nested_field(result, nxt)
    return result

# ==========================================
# Bracket Literal: [elem, ...] or [key:val, ...]
# ==========================================
fun parse_bracket_literal() -> i64:
    eat(TK_LBRACKET)
    skip_newlines()

    # Empty list/array
    if cur_kind() == TK_RBRACKET:
        eat(TK_RBRACKET)
        elems: i64 = mk_node_list(0)
        return mk_array_lit(elems)

    # Parse first element
    first_elem: i64 = parse_expression()
    skip_newlines()

    # Check if map literal: [key : value, ...]
    if cur_kind() == TK_COLON:
        eat(TK_COLON)
        first_val: i64 = parse_expression()
        entries: i64 = mk_node_list(16)
        nl_add(entries, mk_map_entry(first_elem, first_val))
        skip_newlines()
        while cur_kind() == TK_COMMA:
            advance()
            skip_newlines()
            if cur_kind() == TK_RBRACKET:
                break
            mk: i64 = parse_expression()
            eat(TK_COLON)
            mv: i64 = parse_expression()
            nl_add(entries, mk_map_entry(mk, mv))
            skip_newlines()
        eat(TK_RBRACKET)
        return mk_map_lit(entries)

    # Array/list literal: [elem, ...]
    aelems: i64 = mk_node_list(1024)
    nl_add(aelems, first_elem)
    while cur_kind() == TK_COMMA:
        advance()
        skip_newlines()
        if cur_kind() == TK_RBRACKET:
            break
        nl_add(aelems, parse_expression())
        skip_newlines()
    eat(TK_RBRACKET)
    return mk_array_lit(aelems)

# ==========================================
# Operator Precedence Chain (lowest to highest)
# ==========================================

# Level 1: Ternary — value if cond else other
fun parse_ternary() -> i64:
    expr: i64 = parse_logical_or()
    if cur_kind() == TK_IF:
        true_val: i64 = expr
        advance()
        cond: i64 = parse_logical_or()
        eat(TK_ELSE)
        false_val: i64 = parse_logical_or()
        return mk_ternary(cond, true_val, false_val)
    return expr

# Level 2: Logical OR
fun parse_logical_or() -> i64:
    left: i64 = parse_logical_and()
    while cur_kind() == TK_OR:
        advance()
        right: i64 = parse_logical_and()
        left = mk_logical_op("or", left, right)
    return left

# Level 3: Logical AND
fun parse_logical_and() -> i64:
    left: i64 = parse_bitwise_or()
    while cur_kind() == TK_AND:
        advance()
        right: i64 = parse_bitwise_or()
        left = mk_logical_op("and", left, right)
    return left

# Level 4: Bitwise OR
fun parse_bitwise_or() -> i64:
    left: i64 = parse_bitwise_xor()
    while cur_kind() == TK_BIT_OR:
        advance()
        right: i64 = parse_bitwise_xor()
        left = mk_binary_op("|", left, right)
    return left

# Level 5: Bitwise XOR
fun parse_bitwise_xor() -> i64:
    left: i64 = parse_bitwise_and()
    while cur_kind() == TK_BIT_XOR:
        advance()
        right: i64 = parse_bitwise_and()
        left = mk_binary_op("^", left, right)
    return left

# Level 6: Bitwise AND
fun parse_bitwise_and() -> i64:
    left: i64 = parse_logical_not()
    while cur_kind() == TK_BIT_AND:
        advance()
        right: i64 = parse_logical_not()
        left = mk_binary_op("&", left, right)
    return left

# Level 7: Logical NOT
fun parse_logical_not() -> i64:
    if cur_kind() == TK_NOT:
        advance()
        operand: i64 = parse_logical_not()
        return mk_unary_op("not", operand)
    return parse_equality()

# Level 8: Equality == != is
fun parse_equality() -> i64:
    left: i64 = parse_comparison()
    while cur_kind() == TK_EQUAL or cur_kind() == TK_NOT_EQUAL or cur_kind() == TK_IS:
        if cur_kind() == TK_IS:
            advance()
            if cur_kind() == TK_NOT:
                advance()
                eat(TK_NULL)
                left = mk_is_not_null(left)
            elif cur_kind() == TK_NULL:
                advance()
                left = mk_is_null(left)
            else:
                panic("Expected 'null' or 'not null' after 'is'")
        else:
            op_str: str = op_to_str(cur_kind())
            advance()
            right: i64 = parse_comparison()
            left = mk_comparison(op_str, left, right)
    return left

# Level 9: Comparison < > <= >= in
fun parse_comparison() -> i64:
    left: i64 = parse_shift()
    while cur_kind() == TK_LESS or cur_kind() == TK_GREATER or cur_kind() == TK_LESS_EQUAL or cur_kind() == TK_GREATER_EQUAL or cur_kind() == TK_IN:
        op_s: str = op_to_str(cur_kind())
        advance()
        right: i64 = parse_shift()
        left = mk_comparison(op_s, left, right)
    return left

# Level 10: Bit Shift << >>
fun parse_shift() -> i64:
    left: i64 = parse_addition()
    while cur_kind() == TK_SHIFT_LEFT or cur_kind() == TK_SHIFT_RIGHT:
        op_sh: str = op_to_str(cur_kind())
        advance()
        right: i64 = parse_addition()
        left = mk_binary_op(op_sh, left, right)
    return left

# Level 11: Addition + -
fun parse_addition() -> i64:
    left: i64 = parse_multiplication()
    while cur_kind() == TK_PLUS or cur_kind() == TK_MINUS:
        op_a: str = op_to_str(cur_kind())
        advance()
        right: i64 = parse_multiplication()
        left = mk_binary_op(op_a, left, right)
    return left

# Level 12: Multiplication * / %
fun parse_multiplication() -> i64:
    left: i64 = parse_unary()
    while cur_kind() == TK_MULTIPLY or cur_kind() == TK_DIVIDE or cur_kind() == TK_MODULO:
        op_m: str = op_to_str(cur_kind())
        advance()
        right: i64 = parse_unary()
        left = mk_binary_op(op_m, left, right)
    return left

# Level 13: Unary - ~ await
fun parse_unary() -> i64:
    if cur_kind() == TK_MINUS:
        advance()
        operand: i64 = parse_unary()
        return mk_unary_op("-", operand)
    if cur_kind() == TK_BIT_NOT:
        advance()
        operand2: i64 = parse_unary()
        return mk_unary_op("~", operand2)
    if cur_kind() == TK_AWAIT:
        advance()
        operand3: i64 = parse_unary()
        return mk_await(operand3)
    return parse_cast()

# Level 14: Cast — expr as type
fun parse_cast() -> i64:
    expr: i64 = parse_primary()
    while cur_kind() == TK_AS:
        advance()
        target: str = parse_type_name()
        expr = mk_cast(expr, target)
    return expr

# ==========================================
# Type Name Parser (for cast, var decl, etc.)
# ==========================================
fun parse_type_name() -> str:
    k: i32 = cur_kind()
    ts: str = token_to_type_str(k)
    if k == TK_TYPE:
        ts = cur_val()
    if str_eq(ts, "") == 0:
        advance()
        # Handle parametric types: ptr[T], list[T], map[K,V], array[T]
        # Support both [] and <> syntax
        if cur_kind() == TK_LBRACKET or cur_kind() == TK_LESS:
            close_kind: i32 = TK_RBRACKET
            if cur_kind() == TK_LESS:
                close_kind = TK_GREATER
            advance()
            inner: str = parse_type_name()
            # Handle map[K,V] or map<K,V> — support multiple type params
            while cur_kind() == TK_COMMA:
                advance()
                inner2: str = parse_type_name()
                inner = Str.concat(Str.concat(inner, ","), inner2)
            # Handle >> for nested generics like array<array<i32>>
            if close_kind == TK_GREATER:
                eat_greater()
            else:
                eat(close_kind)
            return Str.concat(Str.concat(Str.concat(ts, "["), inner), "]")
        return ts
    # Custom type (struct name, etc.)
    if k == TK_IDENT:
        tn: str = cur_val()
        advance()
        # Handle generic types: TypeName[T] or TypeName<T>
        if cur_kind() == TK_LBRACKET or cur_kind() == TK_LESS:
            close_kind2: i32 = TK_RBRACKET
            if cur_kind() == TK_LESS:
                close_kind2 = TK_GREATER
            advance()
            inner3: str = parse_type_name()
            # Handle multiple type params: TypeName<K, V>
            while cur_kind() == TK_COMMA:
                advance()
                inner4: str = parse_type_name()
                inner3 = Str.concat(Str.concat(inner3, ","), inner4)
            # Handle >> for nested generics like MyType<MyType<i32>>
            if close_kind2 == TK_GREATER:
                eat_greater()
            else:
                eat(close_kind2)
            return Str.concat(Str.concat(Str.concat(tn, "["), inner3), "]")
        return tn
    # Function pointer type: fun(i32, i32) -> i32
    if k == TK_FUN:
        advance()
        eat(TK_LPAREN)
        fpt_str: str = "fun("
        if cur_kind() != TK_RPAREN:
            fpt_str = Str.concat(fpt_str, parse_type_name())
            while cur_kind() == TK_COMMA:
                advance()
                fpt_str = Str.concat(fpt_str, Str.concat(",", parse_type_name()))
        eat(TK_RPAREN)
        fpt_str = Str.concat(fpt_str, ")")
        if cur_kind() == TK_ARROW:
            advance()
            fpt_str = Str.concat(fpt_str, Str.concat("->", parse_type_name()))
        return fpt_str
    panic(@"Expected type name, got kind={k}")
    return ""

# ==========================================
# Entry Point
# ==========================================
fun parse_expression() -> i64:
    return parse_ternary()

##############################
# Parser Statements
# if/elif/else, while, for, return, match, break, continue, pass
# variable declarations, assignments
# Depends on: parser_core.dlt, ast_nodes.dlt, parser_expr.dlt
# Forward-calls: parse_statement() defined in parser_main.dlt
##############################

# parse_indented_block is defined in parser_main.dlt (needs parse_statement)

# ==========================================
# If / Elif / Else
# ==========================================
fun parse_if_stmt() -> i64:
    if_indent: i32 = cur_indent()

    # Eat IF or ELIF
    if cur_kind() == TK_IF:
        eat(TK_IF)
    elif cur_kind() == TK_ELIF:
        eat(TK_ELIF)

    cond: i64 = parse_expression()

    # Optional colon
    if cur_kind() == TK_COLON:
        advance()

    # Single-line if: `if cond: statement`
    then_body: i64 = 0
    if cur_kind() != TK_NEWLINE and cur_kind() != TK_EOF:
        then_body = mk_node_list(4)
        nl_add(then_body, parse_statement())
    else:
        skip_newlines()
        then_body = parse_indented_block(if_indent)
    else_body: i64 = 0

    skip_newlines()

    # Check for elif
    if cur_kind() == TK_ELIF and cur_indent() == if_indent:
        eat(TK_ELIF)
        elif_cond: i64 = parse_expression()
        if cur_kind() == TK_COLON:
            advance()
        elif_body: i64 = 0
        if cur_kind() != TK_NEWLINE and cur_kind() != TK_EOF:
            elif_body = mk_node_list(4)
            nl_add(elif_body, parse_statement())
        else:
            skip_newlines()
            elif_body = parse_indented_block(if_indent)

        # Create elif as nested IfNode
        elif_else: i64 = 0

        skip_newlines()
        # Check for more elif or else after this elif
        if cur_kind() == TK_ELIF and cur_indent() == if_indent:
            elif_next: i64 = parse_if_stmt()
            elif_else = mk_node_list(4)
            nl_add(elif_else, elif_next)
        elif cur_kind() == TK_ELSE and cur_indent() == if_indent:
            eat(TK_ELSE)
            if cur_kind() == TK_COLON:
                advance()
            if cur_kind() != TK_NEWLINE and cur_kind() != TK_EOF:
                elif_else = mk_node_list(4)
                nl_add(elif_else, parse_statement())
            else:
                skip_newlines()
                elif_else = parse_indented_block(if_indent)

        elif_node: i64 = mk_if(elif_cond, elif_body, elif_else)
        else_body = mk_node_list(4)
        nl_add(else_body, elif_node)

    elif cur_kind() == TK_ELSE and cur_indent() == if_indent:
        eat(TK_ELSE)
        if cur_kind() == TK_COLON:
            advance()

        # Single-line else: `else: statement`
        if cur_kind() != TK_NEWLINE and cur_kind() != TK_EOF:
            else_body = mk_node_list(4)
            nl_add(else_body, parse_statement())
        else:
            skip_newlines()

            # else if (two keywords)
            if cur_kind() == TK_IF:
                else_if: i64 = parse_if_stmt()
                else_body = mk_node_list(4)
                nl_add(else_body, else_if)
            else:
                else_body = parse_indented_block(if_indent)

    return mk_if(cond, then_body, else_body)

# ==========================================
# While Loop
# ==========================================
fun parse_while_stmt() -> i64:
    wi: i32 = cur_indent()
    eat(TK_WHILE)
    cond: i64 = parse_expression()
    if cur_kind() == TK_COLON:
        advance()
    body: i64 = 0
    if cur_kind() != TK_NEWLINE and cur_kind() != TK_EOF:
        body = mk_node_list(4)
        nl_add(body, parse_statement())
    else:
        skip_newlines()
        body = parse_indented_block(wi)
    return mk_while(cond, body)

# ==========================================
# For Loop (range-based and for-each)
# for i in start to end:
# for i in start to end step s:
# for item in collection:
# ==========================================
fun parse_for_stmt() -> i64:
    fi: i32 = cur_indent()
    eat(TK_FOR)

    var_name: str = cur_val()
    eat(TK_IDENT)
    eat(TK_IN)

    start_expr: i64 = parse_expression()

    # Check if range-based (has 'to')
    if cur_kind() == TK_TO:
        advance()
        end_expr: i64 = parse_expression()

        step_expr: i64 = mk_int_lit(1)
        has_explicit_step: i32 = 0
        if cur_kind() == TK_STEP:
            advance()
            step_expr = parse_expression()
            has_explicit_step = 1

        if cur_kind() == TK_COLON:
            advance()
        body: i64 = 0
        if cur_kind() != TK_NEWLINE and cur_kind() != TK_EOF:
            body = mk_node_list(4)
            nl_add(body, parse_statement())
        else:
            skip_newlines()
            body = parse_indented_block(fi)

        # Determine comparison operator based on step direction
        # If explicit negative step => use >=
        # If no explicit step, check if start > end for auto-reverse
        comp_op: str = "<="
        step_val: i64 = 0
        is_neg_step: i32 = 0

        # Check if step is a negative literal (NODE_UNARY_OP with "-")
        if has_explicit_step == 1:
            st: i32 = nd_type(step_expr)
            if st == 23:
                is_neg_step = 1
            elif st == 1:
                sv: i64 = Memory.read_i64(step_expr + 8)
                if sv < 0:
                    is_neg_step = 1

        if is_neg_step == 1:
            comp_op = ">="
        else:
            # Auto-reverse: check if start > end (both int literals)
            s_type: i32 = nd_type(start_expr)
            e_type: i32 = nd_type(end_expr)
            if s_type == 1 and e_type == 1:
                s_val: i64 = Memory.read_i64(start_expr + 8)
                e_val: i64 = Memory.read_i64(end_expr + 8)
                if s_val > e_val:
                    comp_op = ">="
                    if has_explicit_step == 0:
                        step_expr = mk_int_lit(0 - 1)

        f_init: i64 = mk_var_decl("int", var_name, start_expr, 0, 0, 1)
        f_cond: i64 = mk_comparison(comp_op, mk_var_ref(var_name), end_expr)
        f_update: i64 = mk_assign(var_name, mk_binary_op("+", mk_var_ref(var_name), step_expr))
        return mk_for(f_init, f_cond, f_update, body, 1)

    # For-each: for item in collection
    if cur_kind() == TK_COLON:
        advance()
    fe_body: i64 = 0
    if cur_kind() != TK_NEWLINE and cur_kind() != TK_EOF:
        fe_body = mk_node_list(4)
        nl_add(fe_body, parse_statement())
    else:
        skip_newlines()
        fe_body = parse_indented_block(fi)
    return mk_for_each(var_name, "", "", start_expr, fe_body)

# ==========================================
# Return Statement
# ==========================================
fun parse_return_stmt() -> i64:
    eat(TK_RETURN)
    if cur_kind() == TK_NEWLINE or cur_kind() == TK_EOF:
        return mk_return(0)
    val: i64 = parse_expression()
    return mk_return(val)

# ==========================================
# Break / Continue / Pass
# ==========================================
fun parse_break_stmt() -> i64:
    eat(TK_BREAK)
    return mk_break()

fun parse_continue_stmt() -> i64:
    eat(TK_CONTINUE)
    return mk_continue()

fun parse_pass_stmt() -> i64:
    eat(TK_PASS)
    return mk_pass()

# ==========================================
# Match Statement
# ==========================================
fun parse_one_case(case_indent: i32) -> i64:
    eat(TK_CASE)
    patterns: i64 = mk_node_list(8)
    nl_add(patterns, parse_pattern())
    while cur_kind() == TK_COMMA:
        advance()
        nl_add(patterns, parse_pattern())

    guard: i64 = 0
    if cur_kind() == TK_IF:
        advance()
        guard = parse_expression()

    if cur_kind() == TK_COLON:
        advance()
    skip_newlines()

    cbody: i64 = parse_indented_block(case_indent)
    return mk_case(patterns, cbody, guard)

fun parse_match_stmt() -> i64:
    mi: i32 = cur_indent()
    eat(TK_MATCH)
    expr: i64 = parse_expression()
    if cur_kind() == TK_COLON:
        advance()
    skip_newlines()

    cases: i64 = mk_node_list(16)
    else_body: i64 = 0

    while cur_kind() != TK_EOF:
        ci: i32 = cur_indent()
        if ci <= mi:
            break
        if cur_kind() == TK_CASE:
            nl_add(cases, parse_one_case(ci))
            skip_newlines()
        elif cur_kind() == TK_ELSE:
            eat(TK_ELSE)
            if cur_kind() == TK_COLON:
                advance()
            skip_newlines()
            else_body = parse_indented_block(ci)
            break
        else:
            break

    return mk_match(expr, cases, else_body, 0)

# ==========================================
# Pattern Parser (for match/case)
# ==========================================
fun parse_pattern() -> i64:
    k: i32 = cur_kind()

    # Integer pattern
    if k == TK_INT or k == TK_HEX:
        pval: str = cur_val()
        advance()
        # Check for range: 1..10
        if cur_kind() == TK_RANGE:
            advance()
            end_val: str = cur_val()
            eat(TK_INT)
            return mk_pattern("range", 0, pval as i64, end_val as i64, 0, "", "", "", 0)
        return mk_pattern("value", pval as i64, 0, 0, 0, "", "", "", 0)

    # String/char pattern
    if k == TK_STRING:
        sv: str = cur_val()
        advance()
        return mk_pattern("value", sv as i64, 0, 0, 0, "", "", "", 0)

    if k == TK_CHAR:
        cv: str = cur_val()
        advance()
        return mk_pattern("value", cv as i64, 0, 0, 0, "", "", "", 0)

    # Bool pattern
    if k == TK_BOOL:
        bv: str = cur_val()
        advance()
        return mk_pattern("value", bv as i64, 0, 0, 0, "", "", "", 0)

    # Identifier: variable pattern or enum access
    if k == TK_IDENT:
        name: str = cur_val()
        eat(TK_IDENT)

        # Enum pattern: Direction.UP
        if cur_kind() == TK_DOT:
            advance()
            variant: str = cur_val()
            eat(TK_IDENT)
            return mk_pattern("enum", 0, 0, 0, 0, "", name, variant, 0)

        # Variable capture pattern
        return mk_pattern("variable", 0, 0, 0, 0, name, "", "", 0)

    # List pattern: [x, y, z]
    if k == TK_LBRACKET:
        eat(TK_LBRACKET)
        elems: i64 = mk_node_list(8)
        if cur_kind() != TK_RBRACKET:
            nl_add(elems, parse_pattern())
            while cur_kind() == TK_COMMA:
                advance()
                nl_add(elems, parse_pattern())
        eat(TK_RBRACKET)
        return mk_pattern("list", 0, 0, 0, elems, "", "", "", 0)

    panic(@"Unexpected pattern token: kind={k}")
    return 0

# ==========================================
# Variable Declaration
# type_token name = expr
# name : type = expr
# ==========================================
fun parse_var_decl_typed(type_str: str) -> i64:
    # Type token already consumed, type_str has the type name
    name: str = cur_val()
    eat(TK_IDENT)

    value: i64 = 0
    if cur_kind() == TK_ASSIGN:
        advance()
        value = parse_expression()

    return mk_var_decl(type_str, name, value, 0, 0, 0)

fun parse_var_decl_ident() -> i64:
    # IDENT : type = expr  OR  IDENT = expr  OR  IDENT(...) call
    # IDENT ?: type = expr  (nullable)
    name: str = cur_val()
    eat(TK_IDENT)

    # Nullable: name?: type = expr
    if cur_kind() == TK_QUESTION:
        advance()
        if cur_kind() == TK_COLON:
            advance()
            ntype: str = parse_type_name()
            nval: i64 = 0
            if cur_kind() == TK_ASSIGN:
                advance()
                nval = parse_expression()
            return mk_var_decl(ntype, name, nval, 1, 0, 0)
        # name? without type — infer as ptr
        nval2: i64 = 0
        if cur_kind() == TK_ASSIGN:
            advance()
            nval2 = parse_expression()
        return mk_var_decl("ptr", name, nval2, 1, 0, 0)

    # name : type = expr
    if cur_kind() == TK_COLON:
        advance()
        vtype: str = parse_type_name()
        value: i64 = 0
        if cur_kind() == TK_ASSIGN:
            advance()
            value = parse_expression()
        return mk_var_decl(vtype, name, value, 0, 0, 0)

    # name = expr (assignment)
    if cur_kind() == TK_ASSIGN:
        advance()
        aval: i64 = parse_expression()
        return mk_assign(name, aval)

    # Compound assignment: name += expr, name -= expr, etc.
    if cur_kind() == TK_PLUS_ASSIGN or cur_kind() == TK_MINUS_ASSIGN or cur_kind() == TK_MULT_ASSIGN or cur_kind() == TK_DIV_ASSIGN:
        op_k: i32 = cur_kind()
        advance()
        cval: i64 = parse_expression()
        # Desugar: name += expr  =>  name = name + expr
        base_op: str = "+"
        if op_k == TK_MINUS_ASSIGN:
            base_op = "-"
        elif op_k == TK_MULT_ASSIGN:
            base_op = "*"
        elif op_k == TK_DIV_ASSIGN:
            base_op = "/"
        combined: i64 = mk_binary_op(base_op, mk_var_ref(name), cval)
        return mk_assign(name, combined)

    # Increment/decrement: name++ or name--
    if cur_kind() == TK_PLUS_PLUS:
        advance()
        inc: i64 = mk_binary_op("+", mk_var_ref(name), mk_int_lit(1))
        return mk_assign(name, inc)
    if cur_kind() == TK_MINUS_MINUS:
        advance()
        dec: i64 = mk_binary_op("-", mk_var_ref(name), mk_int_lit(1))
        return mk_assign(name, dec)

    # Function call: name(args)
    if cur_kind() == TK_LPAREN:
        cargs: i64 = parse_arg_list()
        fc_node: i64 = mk_fun_call(name, cargs, 0)
        if cur_kind() == TK_DOT or cur_kind() == TK_NEWLINE:
            return parse_chained_dot(fc_node)
        return fc_node

    # Dot access: name.something (method call, field access/assign)
    if cur_kind() == TK_DOT:
        return parse_dot_stmt(name)

    # Array access as statement: name[idx] = expr
    if cur_kind() == TK_LBRACKET:
        eat(TK_LBRACKET)
        idx: i64 = parse_expression()
        eat(TK_RBRACKET)
        if cur_kind() == TK_ASSIGN:
            advance()
            arr_val: i64 = parse_expression()
            # Array element assignment — represent as special assign
            access: i64 = mk_array_access(name as i64, idx, 0)
            return mk_assign("", arr_val)
        return mk_array_access(name as i64, idx, 0)

    # Just a bare identifier expression (shouldn't normally happen)
    return mk_var_ref(name)

# ==========================================
# Dot Access as Statement
# name.method(args)  or  name.field = expr
# ==========================================
fun parse_dot_stmt(name: str) -> i64:
    eat(TK_DOT)
    member: str = cur_val()
    eat(TK_IDENT)

    # Namespace-qualified statement: ns.func() or ns.Struct.method()
    if is_module_name(name) == 1:
        if cur_kind() == TK_LPAREN:
            nargs: i64 = parse_arg_list()
            nfc: i8 = Memory.read_i8(member as i64)
            ns_node: i64 = 0
            if nfc >= 65 and nfc <= 90:
                ns_node = mk_ns_struct_inst(name, member, nargs, 0)
            else:
                ns_node = mk_ns_fun_call(name, member, nargs, 0)
            if cur_kind() == TK_DOT or cur_kind() == TK_NEWLINE:
                return parse_chained_dot(ns_node)
            return ns_node
        if cur_kind() == TK_DOT:
            eat(TK_DOT)
            third: str = cur_val()
            eat(TK_IDENT)
            if cur_kind() == TK_LPAREN:
                targs: i64 = parse_arg_list()
                tfc: i8 = Memory.read_i8(member as i64)
                ns_node2: i64 = 0
                if tfc >= 65 and tfc <= 90:
                    ns_node2 = mk_ns_static_method(name, member, third, targs)
                else:
                    ns_node2 = mk_ns_fun_call(name, third, targs, 0)
                if cur_kind() == TK_DOT or cur_kind() == TK_NEWLINE:
                    return parse_chained_dot(ns_node2)
                return ns_node2
            return mk_ns_access(name, member)
        return mk_ns_access(name, member)

    # Method call
    if cur_kind() == TK_LPAREN:
        margs: i64 = parse_arg_list()
        fc: i8 = Memory.read_i8(name as i64)
        node: i64 = 0
        if fc >= 65 and fc <= 90:
            node = mk_static_method(name, member, margs)
        else:
            node = mk_inst_method(name, member, margs)
        # Check for chaining continuation (direct dot or newline+dot)
        if cur_kind() == TK_DOT or cur_kind() == TK_NEWLINE:
            return parse_chained_dot(node)
        return node

    # Field assignment: name.field = expr
    if cur_kind() == TK_ASSIGN:
        advance()
        fval: i64 = parse_expression()
        fc2: i8 = Memory.read_i8(name as i64)
        if fc2 >= 65 and fc2 <= 90:
            return mk_static_field_assign(name, member, fval)
        return mk_field_assign(name, member, fval)

    # Compound assignment on field: name.field += expr
    if cur_kind() == TK_PLUS_ASSIGN or cur_kind() == TK_MINUS_ASSIGN:
        cop: i32 = cur_kind()
        advance()
        cval2: i64 = parse_expression()
        bop: str = "+"
        if cop == TK_MINUS_ASSIGN:
            bop = "-"
        fa: i64 = mk_field_access(name, member)
        combined2: i64 = mk_binary_op(bop, fa, cval2)
        return mk_field_assign(name, member, combined2)

    # Chained: name.member.something
    if cur_kind() == TK_DOT:
        fc3: i8 = Memory.read_i8(name as i64)
        base: i64 = 0
        if fc3 >= 65 and fc3 <= 90:
            base = mk_static_field(name, member)
        else:
            base = mk_field_access(name, member)
        return parse_chained_dot(base)

    # Just field access
    fc4: i8 = Memory.read_i8(name as i64)
    if fc4 >= 65 and fc4 <= 90:
        return mk_static_field(name, member)
    return mk_field_access(name, member)

# ==========================================
# Const Declaration: const name = expr  or  const name: type = expr
# ==========================================
fun parse_const_decl() -> i64:
    eat(TK_CONST)
    name: str = cur_val()
    eat(TK_IDENT)

    vtype: str = ""
    if cur_kind() == TK_COLON:
        advance()
        vtype = parse_type_name()

    eat(TK_ASSIGN)
    val: i64 = parse_expression()

    if str_eq(vtype, "") == 1:
        return mk_var_decl("", name, val, 1, 1, 0)
    return mk_var_decl(vtype, name, val, 0, 1, 0)

# ==========================================
# Imm Declaration: imm name = expr  or  imm name: type = expr
# Same as const — immutable variable
# ==========================================
fun parse_imm_decl() -> i64:
    eat(TK_IMM)
    name: str = cur_val()
    eat(TK_IDENT)

    vtype: str = ""
    if cur_kind() == TK_COLON:
        advance()
        vtype = parse_type_name()

    eat(TK_ASSIGN)
    val: i64 = parse_expression()

    if str_eq(vtype, "") == 1:
        return mk_var_decl("", name, val, 1, 1, 0)
    return mk_var_decl(vtype, name, val, 0, 1, 0)

##############################
# Parser Declarations
# fun, struct, enum, trait, impl, import, extern, type alias
# Depends on: parser_core.dlt, ast_nodes.dlt, parser_expr.dlt, parser_stmt.dlt
##############################

# ==========================================
# Function Definition
# fun name(params) -> ret_type:
#     body
# ==========================================
fun parse_fun_def(is_async: i64) -> i64:
    fi: i32 = cur_indent()
    eat(TK_FUN)

    name: str = cur_val()
    eat(TK_IDENT)

    # Parse parameters
    eat(TK_LPAREN)
    params: i64 = mk_node_list(16)
    is_variadic: i64 = 0
    variadic_param: str = ""

    while cur_kind() != TK_RPAREN:
        pname: str = cur_val()
        if cur_kind() == TK_SELF:
            advance()
        else:
            eat(TK_IDENT)

        # Optional nullable: name?
        nullable: i64 = 0
        if cur_kind() == TK_QUESTION:
            nullable = 1
            advance()

        # Optional variadic: name...
        if cur_kind() == TK_ELLIPSIS:
            advance()
            is_variadic = 1
            variadic_param = pname

        # Optional type: name: type
        ptype: str = ""
        if cur_kind() == TK_COLON:
            advance()
            if cur_kind() != TK_COMMA and cur_kind() != TK_RPAREN:
                ptype = parse_type_name()

        nl_add(params, mk_param(pname, ptype, nullable))

        if cur_kind() == TK_COMMA:
            advance()

    eat(TK_RPAREN)

    # Optional return type: -> type
    ret_type: str = ""
    if cur_kind() == TK_ARROW:
        advance()
        ret_type = parse_type_name()

    # Colon before body (optional for abstract/trait methods)
    if cur_kind() == TK_COLON:
        advance()
        skip_newlines()
        body: i64 = parse_indented_block(fi)
        return mk_fun_def(name, params, ret_type, body, 0, is_variadic, variadic_param, is_async)

    # No colon = abstract method (trait method signature)
    body2: i64 = mk_node_list(4)
    return mk_fun_def(name, params, ret_type, body2, 0, is_variadic, variadic_param, is_async)

# ==========================================
# Parse Type Parameter List: <T>, <T, U>, <K, V>
# Returns node_list of param name strings, or 0 if no <
# ==========================================
fun parse_type_param_list() -> i64:
    if cur_kind() != TK_LESS:
        return 0
    advance()
    params: i64 = mk_node_list(8)
    while cur_kind() != TK_GREATER and cur_kind() != TK_EOF:
        pname: str = cur_val()
        eat(TK_IDENT)
        nl_add(params, pname as i64)
        if cur_kind() == TK_COMMA:
            advance()
    eat(TK_GREATER)
    return params

# ==========================================
# Struct Declaration
# struct Name:
#     field: type
#     field: type = default
# ==========================================
fun parse_struct_decl(is_abstract: i64) -> i64:
    si: i32 = cur_indent()
    eat(TK_STRUCT)

    name: str = cur_val()
    eat(TK_IDENT)

    # Optional type parameters: struct Name<T, U>
    type_params: i64 = parse_type_param_list()

    # Optional extends: struct Name extends Base, Other
    parents: i64 = 0
    base_class: str = ""
    if cur_kind() == TK_EXTENDS:
        advance()
        parents = mk_node_list(8)
        base_name: str = cur_val()
        eat(TK_IDENT)
        base_class = base_name
        # Store parent name as int_lit node (reusing for string storage)
        p_node: i64 = alloc_node(NODE_INT_LIT)
        Memory.write_i64(p_node + 8, base_name as i64)
        nl_add(parents, p_node)
        while cur_kind() == TK_COMMA:
            advance()
            pn: str = cur_val()
            eat(TK_IDENT)
            pp: i64 = alloc_node(NODE_INT_LIT)
            Memory.write_i64(pp + 8, pn as i64)
            nl_add(parents, pp)

    # Optional doc string (triple-quoted)
    if cur_kind() == TK_STRING:
        advance()

    if cur_kind() == TK_COLON:
        advance()

    skip_newlines()

    # Parse fields
    fields: i64 = mk_node_list(64)
    methods: i64 = mk_node_list(256)

    while cur_kind() != TK_EOF:
        ci: i32 = cur_indent()
        if ci <= si:
            break
        if cur_kind() == TK_NEWLINE:
            skip_newlines()
        elif cur_kind() == TK_EOF:
            break
        else:
            ci2: i32 = cur_indent()
            if ci2 <= si:
                break

            # Check for access modifiers
            access: str = "public"
            is_static: i64 = 0
            if cur_kind() == TK_PUBLIC:
                advance()
            elif cur_kind() == TK_PRIVATE:
                access = "private"
                advance()
            elif cur_kind() == TK_PROTECT:
                access = "protected"
                advance()

            if cur_kind() == TK_STATIC:
                is_static = 1
                advance()

            # Method or field?
            if cur_kind() == TK_FUN:
                m: i64 = parse_fun_def(0)
                Memory.write_i64(m + 72, is_static)
                nl_add(methods, m)
            else:
                # Field: name: type = default
                fname: str = cur_val()
                eat(TK_IDENT)

                ftype: str = ""
                if cur_kind() == TK_COLON:
                    advance()
                    ftype = parse_type_name()

                fdefault: i64 = 0
                if cur_kind() == TK_ASSIGN:
                    advance()
                    fdefault = parse_expression()

                nl_add(fields, mk_struct_field(fname, ftype, 0, fdefault, access, is_static))

            if cur_kind() == TK_NEWLINE:
                skip_newlines()

    return mk_struct_decl(name, fields, type_params, base_class, methods, is_abstract, 0, parents)

# @transparent struct — parse normally then set flag=2 in stack_alloc field
# ==========================================
# Annotation Definition Parser
# annot name:
#     target: fun, struct
#     param message: str
#         default: "..."
#     effect: llvm
#         attribute: "hot"
#     emit: warning
#     composes: inline, hot
#     mutually_exclusive: noinline
# ==========================================
fun parse_annot_def() -> i64:
    si: i32 = cur_indent()
    eat(TK_ANNOT)

    aname: str = cur_val()
    advance()  # Accept any token as annotation name (keywords like 'stack' too)

    # Defaults
    targets: str = ""
    effect: str = ""
    emit_kind: str = ""
    emit_msg: str = ""
    exclusive: str = ""
    composes: str = ""
    params_nl: i64 = 0

    # Parse optional params in parentheses — annot name(p1: type = default)
    if cur_kind() == TK_LPAREN:
        advance()
        params_nl = mk_node_list(8)
        while cur_kind() != TK_RPAREN and cur_kind() != TK_EOF:
            # Check for variadic "..."
            is_variadic: i32 = 0
            if cur_kind() == TK_ELLIPSIS:
                is_variadic = 1
                advance()
            pname: str = cur_val()
            eat(TK_IDENT)
            if cur_kind() == TK_COLON:
                advance()
            ptype: str = cur_val()
            advance()
            # Check for default value: = value
            def_val: str = ""
            if cur_kind() == TK_ASSIGN:
                advance()
                def_val = cur_val()
                advance()
            pnode: i64 = mk_annot_param(pname, ptype)
            if str_eq(def_val, "") == 0:
                Memory.write_i64(pnode + 24, def_val as i64)
            if is_variadic == 1:
                Memory.write_i64(pnode + 32, 1)
            nl_add(params_nl, pnode)
            if cur_kind() == TK_COMMA:
                advance()
        if cur_kind() == TK_RPAREN:
            advance()

    # Expect: = Annot(...)
    eat(TK_ASSIGN)
    skip_newlines()
    # Consume "Annot" identifier
    advance()
    eat(TK_LPAREN)
    skip_newlines()

    # Parse key: value fields inside Annot(...)
    while cur_kind() != TK_RPAREN and cur_kind() != TK_EOF:
        field_name: str = cur_val()
        advance()
        if cur_kind() == TK_ASSIGN:
            advance()

        # target = fun | struct
        if str_eq(field_name, "target") == 1:
            targets = cur_val()
            advance()
            while cur_kind() == TK_BIT_OR:
                advance()
                targets = Str.concat(targets, Str.concat(", ", cur_val()))
                advance()

        # effect: "llvm:alwaysinline"
        elif str_eq(field_name, "effect") == 1:
            effect = cur_val()
            advance()

        # conflicts: [name1, name2]
        elif str_eq(field_name, "conflicts") == 1:
            if cur_kind() == TK_LBRACKET:
                advance()
                exclusive = cur_val()
                advance()
                while cur_kind() == TK_COMMA:
                    advance()
                    exclusive = Str.concat(exclusive, Str.concat(",", cur_val()))
                    advance()
                if cur_kind() == TK_RBRACKET:
                    advance()
            else:
                exclusive = cur_val()
                advance()

        # emit: warning("msg") or emit: error("msg")
        elif str_eq(field_name, "emit") == 1:
            emit_kind = cur_val()
            advance()
            if cur_kind() == TK_LPAREN:
                advance()
                emit_msg = cur_val()
                advance()
                if cur_kind() == TK_RPAREN:
                    advance()

        # composes: [name1, name2]
        elif str_eq(field_name, "composes") == 1:
            if cur_kind() == TK_LBRACKET:
                advance()
                composes = cur_val()
                advance()
                while cur_kind() == TK_COMMA:
                    advance()
                    composes = Str.concat(composes, Str.concat(",", cur_val()))
                    advance()
                if cur_kind() == TK_RBRACKET:
                    advance()
            else:
                composes = cur_val()
                advance()

        # Unknown field — skip value
        else:
            while cur_kind() != TK_COMMA and cur_kind() != TK_RPAREN and cur_kind() != TK_EOF:
                advance()

        # Eat comma separator between fields
        if cur_kind() == TK_COMMA:
            advance()
        skip_newlines()

    eat(TK_RPAREN)

    # Register the annotation
    aidx: i32 = register_annot(aname, targets, effect, emit_kind, emit_msg, exclusive, composes)
    if params_nl != 0 and aidx >= 0:
        register_annot_params(aidx, params_nl)

    # Create and return the AST node
    node: i64 = mk_annot_def(aname, targets)
    Memory.write_i64(node + 24, params_nl)
    Memory.write_i64(node + 32, effect as i64)
    Memory.write_i64(node + 40, 0)
    Memory.write_i64(node + 48, composes as i64)
    Memory.write_i64(node + 56, exclusive as i64)
    Memory.write_i64(node + 64, emit_kind as i64)
    Memory.write_i64(node + 72, emit_msg as i64)
    return node

fun parse_struct_decl_transparent() -> i64:
    node: i64 = parse_struct_decl(0)
    # Set stack_alloc (offset +56) to 2 = transparent marker
    Memory.write_i64(node + 56, 2)
    return node

# @stack struct — parse normally then set flag=1 in stack_alloc field (default = stack anyway)
fun parse_struct_decl_stack() -> i64:
    node: i64 = parse_struct_decl(0)
    # Set stack_alloc (offset +56) to 1 = stack marker (same as default, explicit annotation)
    Memory.write_i64(node + 56, 1)
    return node

# @heap struct — parse normally then set flag=3 in stack_alloc field (explicit heap allocation)
fun parse_struct_decl_heap() -> i64:
    node: i64 = parse_struct_decl(0)
    # Set stack_alloc (offset +56) to 3 = heap marker (opt-in to Memory.malloc)
    Memory.write_i64(node + 56, 3)
    return node

# ==========================================
# Enum Declaration
# enum Name:
#     VALUE1
#     VALUE2
# ==========================================
fun parse_enum_decl() -> i64:
    ei: i32 = cur_indent()
    eat(TK_ENUM)

    name: str = cur_val()
    eat(TK_IDENT)

    if cur_kind() == TK_COLON:
        advance()
    skip_newlines()

    values: i64 = mk_node_list(32)
    variants: i64 = mk_node_list(16)

    while cur_kind() != TK_EOF:
        ci: i32 = cur_indent()
        if ci <= ei:
            break
        if cur_kind() == TK_NEWLINE:
            skip_newlines()
        elif cur_kind() == TK_EOF:
            break
        else:
            ci2: i32 = cur_indent()
            if ci2 <= ei:
                break

            vname: str = cur_val()
            eat(TK_IDENT)

            # Check for variant with fields: Variant(field: type, ...)
            if cur_kind() == TK_LPAREN:
                eat(TK_LPAREN)
                vfields: i64 = mk_node_list(8)
                while cur_kind() != TK_RPAREN:
                    vfn: str = cur_val()
                    eat(TK_IDENT)
                    vft: str = ""
                    if cur_kind() == TK_COLON:
                        advance()
                        vft = parse_type_name()
                    nl_add(vfields, mk_param(vfn, vft, 0))
                    if cur_kind() == TK_COMMA:
                        advance()
                eat(TK_RPAREN)
                nl_add(variants, mk_enum_variant(vname, vfields))
            else:
                # Simple value
                # Store as string pointer in node_list
                sv: i64 = alloc_node(NODE_INT_LIT)
                Memory.write_i64(sv + 8, vname as i64)
                nl_add(values, sv)

            if cur_kind() == TK_NEWLINE:
                skip_newlines()

    return mk_enum_decl(name, values, variants, 0)

# ==========================================
# Trait Declaration
# trait Name:
#     fun method(params) -> type
# ==========================================
fun parse_trait_decl() -> i64:
    ti: i32 = cur_indent()
    eat(TK_TRAIT)

    name: str = cur_val()
    eat(TK_IDENT)

    if cur_kind() == TK_COLON:
        advance()
    skip_newlines()

    methods: i64 = mk_node_list(256)

    while cur_kind() != TK_EOF:
        ci: i32 = cur_indent()
        if ci <= ti:
            break
        if cur_kind() == TK_NEWLINE:
            skip_newlines()
        elif cur_kind() == TK_FUN:
            m: i64 = parse_fun_def(0)
            nl_add(methods, m)
            if cur_kind() == TK_NEWLINE:
                skip_newlines()
        else:
            break

    return mk_trait_decl(name, methods, 0)

# ==========================================
# Impl Block
# impl StructName:
#     fun method(...):
# ==========================================
fun parse_impl_block() -> i64:
    ii: i32 = cur_indent()
    eat(TK_IMPL)

    sname: str = cur_val()
    eat(TK_IDENT)

    # Optional type parameters: impl Name<T>
    type_params: i64 = parse_type_param_list()

    # Optional trait name: impl Struct for Trait
    trait_name: str = ""
    # (simplified — Dolet uses impl Struct: syntax)

    if cur_kind() == TK_COLON:
        advance()
    skip_newlines()

    methods: i64 = mk_node_list(256)

    while cur_kind() != TK_EOF:
        ci: i32 = cur_indent()
        if ci <= ii:
            break
        if cur_kind() == TK_NEWLINE:
            skip_newlines()
        elif cur_kind() == TK_FUN or cur_kind() == TK_STATIC:
            mis: i64 = 0
            if cur_kind() == TK_STATIC:
                mis = 1
                advance()
            m: i64 = parse_fun_def(0)
            Memory.write_i64(m + 72, mis)
            nl_add(methods, m)
            if cur_kind() == TK_NEWLINE:
                skip_newlines()
        else:
            break

    return mk_impl_block(sname, methods, trait_name, type_params)

# ==========================================
# Extend Block
# extend TypeName:
#     fun method(...):
# ==========================================
fun parse_extend_block() -> i64:
    xi: i32 = cur_indent()
    eat(TK_EXTEND)

    tname: str = cur_val()
    # Accept keywords like list/array/map as type names
    advance()

    # Optional type parameters: extend Name<T>
    type_params: i64 = parse_type_param_list()

    if cur_kind() == TK_COLON:
        advance()
    skip_newlines()

    methods: i64 = mk_node_list(256)

    while cur_kind() != TK_EOF:
        ci: i32 = cur_indent()
        if ci <= xi:
            break
        if cur_kind() == TK_NEWLINE:
            skip_newlines()
        elif cur_kind() == TK_FUN or cur_kind() == TK_STATIC:
            mis: i64 = 0
            if cur_kind() == TK_STATIC:
                mis = 1
                advance()
            m: i64 = parse_fun_def(0)
            Memory.write_i64(m + 72, mis)
            nl_add(methods, m)
            if cur_kind() == TK_NEWLINE:
                skip_newlines()
        else:
            break

    return mk_extend_block(tname, methods, type_params)

# ==========================================
# Import Statement
# import module_name
# import module_name as alias
# import module_name.symbol
# ==========================================
fun parse_import_stmt() -> i64:
    eat(TK_IMPORT)

    mod_name: str = cur_val()
    eat(TK_IDENT)

    # Handle dashes in module names: c-std
    while cur_kind() == TK_MINUS:
        advance()
        if cur_kind() == TK_IDENT:
            # Concat with dash
            next_part: str = cur_val()
            mod_name = Str.concat(Str.concat(mod_name, "-"), next_part)
            advance()

    alias: str = ""
    symbols: i64 = 0
    imp_type: i64 = 0

    # Check for dot notation: import math.dsqrt
    if cur_kind() == TK_DOT:
        advance()
        # Check for bracket syntax: import std.[io, string]
        if cur_kind() == TK_LBRACKET:
            advance()
            symbols = mk_node_list(8)
            while cur_kind() != TK_RBRACKET:
                bsym_name: str = cur_val()
                if cur_kind() == TK_IDENT or cur_kind() == TK_TYPE:
                    advance()
                else:
                    eat(TK_IDENT)
                bsym_node: i64 = alloc_node(NODE_INT_LIT)
                Memory.write_i64(bsym_node + 8, bsym_name as i64)
                nl_add(symbols, bsym_node)
                if cur_kind() == TK_COMMA:
                    advance()
            eat(TK_RBRACKET)
            imp_type = 2
        else:
            sym_name: str = cur_val()
            eat(TK_IDENT)

            # Check for .dlt extension
            if str_eq(sym_name, "dlt") == 1:
                mod_name = Str.concat(mod_name, ".dlt")
            else:
                symbols = mk_node_list(8)
                sym_node: i64 = alloc_node(NODE_INT_LIT)
                Memory.write_i64(sym_node + 8, sym_name as i64)
                nl_add(symbols, sym_node)
                imp_type = 2

    # Check for 'as' alias
    if cur_kind() == TK_AS:
        advance()
        alias = cur_val()
        eat(TK_IDENT)
        if imp_type == 2:
            imp_type = 4
        else:
            imp_type = 3

    return mk_import(mod_name, alias, symbols, imp_type)

# ==========================================
# From Import Statement
# from mod_name import sym1, sym2, ...
# ==========================================
fun parse_from_import() -> i64:
    eat(TK_FROM)

    mod_name: str = cur_val()
    eat(TK_IDENT)

    # Handle dotted module names: from std.io import print
    while cur_kind() == TK_DOT:
        advance()
        mid: str = cur_val()
        eat(TK_IDENT)
        mod_name = Str.concat(Str.concat(mod_name, "."), mid)

    eat(TK_IMPORT)

    # Collect selected symbol names
    symbols: i64 = mk_node_list(16)
    sym1: str = cur_val()
    eat(TK_IDENT)
    sym1_node: i64 = alloc_node(NODE_INT_LIT)
    Memory.write_i64(sym1_node + 8, sym1 as i64)
    nl_add(symbols, sym1_node)

    while cur_kind() == TK_COMMA:
        advance()
        symn: str = cur_val()
        eat(TK_IDENT)
        symn_node: i64 = alloc_node(NODE_INT_LIT)
        Memory.write_i64(symn_node + 8, symn as i64)
        nl_add(symbols, symn_node)

    return mk_import(mod_name, "", symbols, 2)

# ==========================================
# Extern Block
# extern lib "name":
#     fun func_name(params) -> ret
# ==========================================
fun parse_extern_block() -> i64:
    xi: i32 = cur_indent()
    eat(TK_EXTERN)

    # Expect 'lib' keyword (as IDENT)
    lib_kw: str = cur_val()
    eat(TK_IDENT)

    lib_name: str = cur_val()
    eat(TK_STRING)

    if cur_kind() == TK_COLON:
        advance()
    skip_newlines()

    funs: i64 = mk_node_list(1024)

    while cur_kind() != TK_EOF:
        ci: i32 = cur_indent()
        if ci <= xi:
            break
        if cur_kind() == TK_NEWLINE:
            skip_newlines()
        elif cur_kind() == TK_FUN:
            advance()
            fname: str = cur_val()
            eat(TK_IDENT)
            eat(TK_LPAREN)
            eparams: i64 = mk_node_list(16)
            while cur_kind() != TK_RPAREN:
                pn: str = cur_val()
                eat(TK_IDENT)
                pt: str = ""
                if cur_kind() == TK_COLON:
                    advance()
                    pt = parse_type_name()
                nl_add(eparams, mk_param(pn, pt, 0))
                if cur_kind() == TK_COMMA:
                    advance()
            eat(TK_RPAREN)

            eret: str = ""
            if cur_kind() == TK_ARROW:
                advance()
                eret = parse_type_name()

            nl_add(funs, mk_extern_fun(fname, eparams, eret))
            if cur_kind() == TK_NEWLINE:
                skip_newlines()
        else:
            break

    return mk_extern_block(lib_name, funs)

# ==========================================
# Type Alias: type Name = TargetType
# ==========================================
fun parse_type_alias_stmt() -> i64:
    eat(TK_TYPE_ALIAS)

    name: str = cur_val()
    eat(TK_IDENT)
    eat(TK_ASSIGN)

    target: str = parse_type_name()
    return mk_type_alias(name, target as i64)

##############################
# Parser Main Entry Point
# parse(), parse_statement(), parse_indented_block()
# Depends on: all other parser files
##############################

# ==========================================
# Indented Block Parser
# ==========================================
fun parse_indented_block(base_indent: i32) -> i64:
    body: i64 = mk_node_list(512)
    while cur_kind() != TK_EOF:
        ci: i32 = cur_indent()
        if ci <= base_indent:
            break
        if cur_kind() == TK_NEWLINE:
            skip_newlines()
        elif cur_kind() == TK_EOF:
            break
        else:
            ci2: i32 = cur_indent()
            if ci2 <= base_indent:
                break
            stmt: i64 = parse_statement()
            if stmt != 0:
                nl_add(body, stmt)
            if cur_kind() == TK_NEWLINE:
                skip_newlines()
    return body

# ==========================================
# Statement Dispatcher
# ==========================================
fun parse_statement() -> i64:
    k: i32 = cur_kind()

    # Skip newlines
    if k == TK_NEWLINE:
        skip_newlines()
        return 0

    # Const declaration
    if k == TK_CONST:
        return parse_const_decl()

    # Imm declaration (alias for const)
    if k == TK_IMM:
        return parse_imm_decl()

    # Static declaration (treat as const for now)
    if k == TK_STATIC:
        advance()
        if cur_kind() == TK_FUN:
            return parse_fun_def(0)
        # static var decl
        name: str = cur_val()
        eat(TK_IDENT)
        if cur_kind() == TK_COLON:
            advance()
            vt: str = parse_type_name()
            eat(TK_ASSIGN)
            val: i64 = parse_expression()
            return mk_var_decl(vt, name, val, 0, 0, 0)
        eat(TK_ASSIGN)
        val2: i64 = parse_expression()
        return mk_var_decl("", name, val2, 1, 0, 0)

    # Mut declaration
    if k == TK_MUT:
        advance()
        name2: str = cur_val()
        eat(TK_IDENT)
        if cur_kind() == TK_COLON:
            advance()
            mt: str = parse_type_name()
            eat(TK_ASSIGN)
            mval: i64 = parse_expression()
            return mk_var_decl(mt, name2, mval, 0, 0, 0)
        eat(TK_ASSIGN)
        mval2: i64 = parse_expression()
        return mk_var_decl("", name2, mval2, 1, 0, 0)

    # Enum
    if k == TK_ENUM:
        return parse_enum_decl()

    # Trait
    if k == TK_TRAIT:
        return parse_trait_decl()

    # Abstract struct
    if k == TK_ABSTRACT:
        advance()
        if cur_kind() == TK_STRUCT:
            return parse_struct_decl(1)
        panic("Expected 'struct' after 'abstract'")

    # Struct
    if k == TK_STRUCT:
        return parse_struct_decl(0)

    # Impl
    if k == TK_IMPL:
        return parse_impl_block()

    # Extend
    if k == TK_EXTEND:
        return parse_extend_block()

    # Type alias
    if k == TK_TYPE_ALIAS:
        return parse_type_alias_stmt()

    # Type token as variable declaration start
    if is_type_token(k) == 1:
        ts: str = token_to_type_str(k)
        advance()
        return parse_var_decl_typed(ts)

    # Function definition
    if k == TK_FUN:
        return parse_fun_def(0)

    # Access-modified function: private fun, public fun, protect fun
    if k == TK_PRIVATE or k == TK_PUBLIC or k == TK_PROTECT:
        advance()
        if cur_kind() == TK_FUN:
            return parse_fun_def(0)
        # Access modifier on struct field or other context — skip
        while cur_kind() != TK_NEWLINE and cur_kind() != TK_EOF:
            advance()
        return 0

    # Async function
    if k == TK_ASYNC:
        advance()
        if cur_kind() == TK_FUN:
            return parse_fun_def(1)
        panic("Expected 'fun' after 'async'")

    # Return
    if k == TK_RETURN:
        return parse_return_stmt()

    # If
    if k == TK_IF:
        return parse_if_stmt()

    # While
    if k == TK_WHILE:
        return parse_while_stmt()

    # For
    if k == TK_FOR:
        return parse_for_stmt()

    # Match
    if k == TK_MATCH:
        return parse_match_stmt()

    # Break
    if k == TK_BREAK:
        return parse_break_stmt()

    # Continue
    if k == TK_CONTINUE:
        return parse_continue_stmt()

    # Pass
    if k == TK_PASS:
        return parse_pass_stmt()

    # Import
    if k == TK_IMPORT:
        return parse_import_stmt()

    # Module system keywords (processed by load_module, skip if seen in source)
    if k == TK_MODULE or k == TK_EXPORT or k == TK_REQUIRES:
        # Skip to end of line
        advance()
        while cur_kind() != TK_NEWLINE and cur_kind() != TK_EOF:
            advance()
        return 0

    # Use statement: use std.IOOps.io_println (module symbol aliasing)
    # Since all symbols are in flat namespace, just skip the directive
    if k == TK_USE:
        advance()
        # Consume dotted path: ident.ident.ident...
        if cur_kind() == TK_IDENT:
            advance()
            while cur_kind() == TK_DOT:
                advance()
                if cur_kind() == TK_IDENT:
                    advance()
        return 0

    # From import: from mod import sym1, sym2
    if k == TK_FROM:
        return parse_from_import()

    # Extern
    if k == TK_EXTERN:
        return parse_extern_block()

    # Super method call
    if k == TK_SUPER:
        return parse_expression()

    # Self as statement (self.method() or self.field = ... or self.field += ...)
    if k == TK_SELF:
        advance()
        if cur_kind() == TK_DOT:
            advance()
            sfname: str = cur_val()
            eat(TK_IDENT)
            # self.method()
            if cur_kind() == TK_LPAREN:
                sma: i64 = parse_arg_list()
                return mk_inst_method("self", sfname, sma)
            # self.field = expr
            if cur_kind() == TK_ASSIGN:
                advance()
                sfval: i64 = parse_expression()
                return mk_field_assign("self", sfname, sfval)
            # self.field += expr or self.field -= expr
            if cur_kind() == TK_PLUS_ASSIGN or cur_kind() == TK_MINUS_ASSIGN or cur_kind() == TK_MULT_ASSIGN or cur_kind() == TK_DIV_ASSIGN:
                sop: i32 = cur_kind()
                advance()
                scval: i64 = parse_expression()
                sbop: str = "+"
                if sop == TK_MINUS_ASSIGN:
                    sbop = "-"
                elif sop == TK_MULT_ASSIGN:
                    sbop = "*"
                elif sop == TK_DIV_ASSIGN:
                    sbop = "/"
                scombined: i64 = mk_binary_op(sbop, mk_self_field(sfname), scval)
                return mk_field_assign("self", sfname, scombined)
            # Just self.field as expression statement
            return mk_self_field(sfname)
        return mk_self()

    # Annotation definition: annot name:
    if k == TK_ANNOT:
        return parse_annot_def()

    # Annotation: @stack, @heap, @transparent, @inline, @[deprecated(msg="...")] etc.
    if k == TK_AT:
        # Collect all stacked annotations
        annot_nodes: i64 = mk_node_list(8)
        while cur_kind() == TK_AT:
            advance()

            # Check for @[name(k=v, ...)] bracket syntax
            use_bracket: i32 = 0
            if cur_kind() == TK_LBRACKET:
                use_bracket = 1
                advance()

            ann_name: str = ""
            if cur_kind() == TK_IDENT:
                ann_name = cur_val()
                advance()
            elif cur_kind() == TK_STACK:
                ann_name = "stack"
                advance()

            # Parse optional arguments: (k=v, k2=v2)
            ann_args: i64 = 0
            if cur_kind() == TK_LPAREN:
                advance()
                ann_args = mk_node_list(4)
                while cur_kind() != TK_RPAREN and cur_kind() != TK_EOF:
                    ak: str = cur_val()
                    advance()
                    if cur_kind() == TK_ASSIGN:
                        advance()
                        av: str = cur_val()
                        advance()
                        # Store as field_val node: +8=key, +16=value
                        kv_node: i64 = alloc_node(NODE_FIELD_VAL)
                        Memory.write_i64(kv_node + 8, ak as i64)
                        Memory.write_i64(kv_node + 16, av as i64)
                        nl_add(ann_args, kv_node)
                    if cur_kind() == TK_COMMA:
                        advance()
                if cur_kind() == TK_RPAREN:
                    advance()

            if use_bracket == 1:
                if cur_kind() == TK_RBRACKET:
                    advance()

            ann_use: i64 = mk_annot_use(ann_name, ann_args)
            nl_add(annot_nodes, ann_use)

            # Validate annotation exists in registry
            aidx: i32 = find_annot(ann_name)
            if aidx >= 0:
                # Check mutual exclusivity
                excl: str = get_annot_exclusive(aidx)
                if str_eq(excl, "") == 0:
                    ec: i32 = Memory.read_i32(annot_nodes)
                    ei: i32 = 0
                    while ei < ec:
                        en: i64 = Memory.read_i64(annot_nodes + 8 + (ei * 8) as i64)
                        ename: str = Memory.read_i64(en + 8) as str
                        if str_eq(ename, excl) == 1:
                            IOOps.io_println(Str.concat("[ERROR] @", Str.concat(ann_name, Str.concat(" is mutually exclusive with @", excl))))
                        ei = ei + 1

            skip_newlines()

        # Now parse the target declaration
        # Legacy: @transparent/@stack/@heap + struct → keep +56 flag AND attach +80
        ann_count: i32 = Memory.read_i32(annot_nodes)
        first_ann_name: str = ""
        if ann_count > 0:
            first_ann: i64 = Memory.read_i64(annot_nodes + 8)
            first_ann_name = Memory.read_i64(first_ann + 8) as str

        if cur_kind() == TK_STRUCT:
            target_node: i64 = 0
            # Legacy struct annotations
            if str_eq(first_ann_name, "transparent") == 1:
                target_node = parse_struct_decl_transparent()
            elif str_eq(first_ann_name, "stack") == 1:
                target_node = parse_struct_decl_stack()
            elif str_eq(first_ann_name, "heap") == 1:
                target_node = parse_struct_decl_heap()
            else:
                target_node = parse_struct_decl(0)
            # Attach annotations at +80
            Memory.write_i64(target_node + 80, annot_nodes)
            return target_node

        if cur_kind() == TK_FUN:
            target_node2: i64 = parse_fun_def(0)
            Memory.write_i64(target_node2 + 80, annot_nodes)
            return target_node2

        if cur_kind() == TK_ASYNC:
            advance()
            if cur_kind() == TK_FUN:
                target_node3: i64 = parse_fun_def(1)
                Memory.write_i64(target_node3 + 80, annot_nodes)
                return target_node3

        # Annotation on something else — fallthrough, just parse next statement
        return parse_statement()

    # Identifier: var decl, assignment, function call, method call
    if k == TK_IDENT:
        # Context-sensitive list/array/map declarations
        # "list NAME : TYPE = [...]" — only when followed by another identifier
        ident_v: str = cur_val()
        if str_eq(ident_v, "list") == 1:
            if peek_kind(1) == TK_IDENT:
                advance()
                lname: str = cur_val()
                eat(TK_IDENT)
                ltype: str = ""
                if cur_kind() == TK_COLON:
                    advance()
                    ltype = parse_type_name()
                eat(TK_ASSIGN)
                lval: i64 = parse_expression()
                return mk_list_decl(lname, lval, ltype, 0)
        if str_eq(ident_v, "array") == 1:
            if peek_kind(1) == TK_IDENT:
                advance()
                aname: str = cur_val()
                eat(TK_IDENT)
                atype: str = ""
                if cur_kind() == TK_COLON:
                    advance()
                    atype = parse_type_name()
                eat(TK_ASSIGN)
                aval: i64 = parse_expression()
                return mk_array_decl(aname, 0, atype, 0)
        if str_eq(ident_v, "map") == 1:
            if peek_kind(1) == TK_IDENT:
                advance()
                mname: str = cur_val()
                eat(TK_IDENT)
                eat(TK_ASSIGN)
                mval: i64 = parse_expression()
                return mk_map_decl(mname, 0, "", "", 0)
        # Check if it's a variable declaration: Name : type
        # or assignment, function call, etc.
        return parse_var_decl_ident()

    panic(@"Unknown statement: kind={k} val='{cur_val()}'")
    return 0

# ==========================================
# Main Parse Loop
# ==========================================
fun parse() -> i64:
    stmts: i64 = mk_node_list(2048)
    while cur_kind() != TK_EOF:
        skip_newlines()
        if cur_kind() == TK_EOF:
            break
        stmt: i64 = parse_statement()
        if stmt != 0:
            nl_add(stmts, stmt)
        skip_newlines()
    return stmts

# ===== Codegen =====
##############################
# MLIR Codegen Core
# State, output buffer, string pool, MLIR types,
# variable registry, scoping, counters, helpers
##############################

# ==========================================
fun panic(msg: str):
    IOOps.io_println(msg)
    ExitProcess(1)

