# ==========================================
# Static Fields Tracking
# ==========================================
g_sf_names: i64 = 0
g_sf_types: i64 = 0
g_sf_defaults: i64 = 0
g_static_field_count: i32 = 0

fun init_static_fields():
    g_sf_names = Memory.malloc_zeroed(1024 * 8)
    g_sf_types = Memory.malloc_zeroed(1024 * 8)
    g_sf_defaults = Memory.malloc_zeroed(1024 * 8)
    g_static_field_count = 0

fun register_static_field(full_name: str, ftype: str):
    off: i64 = (g_static_field_count as i64) * 8
    Memory.write_i64(g_sf_names + off, full_name as i64)
    Memory.write_i64(g_sf_types + off, ftype as i64)
    Memory.write_i64(g_sf_defaults + off, 0)
    g_static_field_count = g_static_field_count + 1

fun register_static_field_with_default(full_name: str, ftype: str, def_node: i64):
    off: i64 = (g_static_field_count as i64) * 8
    Memory.write_i64(g_sf_names + off, full_name as i64)
    Memory.write_i64(g_sf_types + off, ftype as i64)
    Memory.write_i64(g_sf_defaults + off, def_node)
    g_static_field_count = g_static_field_count + 1

fun lookup_static_field_type(full_name: str) -> str:
    i: i32 = 0
    while i < g_static_field_count:
        off: i64 = (i as i64) * 8
        n: str = Memory.read_i64(g_sf_names + off) as str
        if str_eq(n, full_name) == 1:
            return Memory.read_i64(g_sf_types + off) as str
        i = i + 1
    return "i64"

# ==========================================
# Impl Method Registry
# ==========================================
g_impl_struct: i64 = 0
g_impl_method_name: i64 = 0
g_impl_method_node: i64 = 0
g_impl_count: i32 = 0

fun init_impl_registry():
    g_impl_struct = Memory.malloc_zeroed(2048 * 8)
    g_impl_method_name = Memory.malloc_zeroed(2048 * 8)
    g_impl_method_node = Memory.malloc_zeroed(2048 * 8)
    g_impl_count = 0

fun register_impl_method(sname: str, mname: str, mnode: i64):
    if g_impl_count >= 2048:
        IOOps.io_println("[FATAL] Impl method registry overflow!")
        return
    off: i64 = (g_impl_count as i64) * 8
    Memory.write_i64(g_impl_struct + off, sname as i64)
    Memory.write_i64(g_impl_method_name + off, mname as i64)
    Memory.write_i64(g_impl_method_node + off, mnode)
    g_impl_count = g_impl_count + 1

fun find_impl_method(sname: str, mname: str) -> i64:
    i: i32 = 0
    while i < g_impl_count:
        off: i64 = (i as i64) * 8
        s: str = Memory.read_i64(g_impl_struct + off) as str
        m: str = Memory.read_i64(g_impl_method_name + off) as str
        if str_eq(s, sname) == 1 and str_eq(m, mname) == 1:
            return Memory.read_i64(g_impl_method_node + off)
        i = i + 1
    return 0

# ==========================================
# Codegen State
# ==========================================
g_in_function: i32 = 0
g_cur_fn_ret_type: str = ""
g_cur_fn_name: str = ""
g_cur_method_struct: str = ""
g_break_label: str = ""
g_continue_label: str = ""

# ==========================================
# Annotation Registry
# Parallel arrays storing custom annotation definitions
g_annot_names: i64 = 0
g_annot_targets: i64 = 0
g_annot_effects: i64 = 0
g_annot_emit_kinds: i64 = 0
g_annot_emit_msgs: i64 = 0
g_annot_exclusives: i64 = 0
g_annot_composes_list: i64 = 0
g_annot_param_lists: i64 = 0
g_annot_count: i32 = 0
MAX_ANNOTS: i32 = 256

fun init_annot_registry():
    MAX_ANNOTS = 256
    g_annot_names = Memory.malloc_zeroed(2048)
    g_annot_targets = Memory.malloc_zeroed(2048)
    g_annot_effects = Memory.malloc_zeroed(2048)
    g_annot_emit_kinds = Memory.malloc_zeroed(2048)
    g_annot_emit_msgs = Memory.malloc_zeroed(2048)
    g_annot_exclusives = Memory.malloc_zeroed(2048)
    g_annot_composes_list = Memory.malloc_zeroed(2048)
    g_annot_param_lists = Memory.malloc_zeroed(2048)
    g_annot_count = 0

fun register_annot(name: str, targets: str, effect: str, emit_kind: str, emit_msg: str, exclusive: str, composes: str) -> i32:
    idx: i32 = g_annot_count
    if idx >= MAX_ANNOTS:
        IOOps.io_println("[ERROR] Annotation registry overflow")
        return -1
    Memory.write_i64(g_annot_names + (idx * 8) as i64, name as i64)
    Memory.write_i64(g_annot_targets + (idx * 8) as i64, targets as i64)
    Memory.write_i64(g_annot_effects + (idx * 8) as i64, effect as i64)
    Memory.write_i64(g_annot_emit_kinds + (idx * 8) as i64, emit_kind as i64)
    Memory.write_i64(g_annot_emit_msgs + (idx * 8) as i64, emit_msg as i64)
    Memory.write_i64(g_annot_exclusives + (idx * 8) as i64, exclusive as i64)
    Memory.write_i64(g_annot_composes_list + (idx * 8) as i64, composes as i64)
    Memory.write_i64(g_annot_param_lists + (idx * 8) as i64, 0)
    g_annot_count = idx + 1
    return idx

fun register_annot_params(annot_idx: i32, params_nl: i64):
    if annot_idx >= 0 and annot_idx < g_annot_count:
        Memory.write_i64(g_annot_param_lists + (annot_idx * 8) as i64, params_nl)

fun find_annot(name: str) -> i32:
    i: i32 = 0
    while i < g_annot_count:
        aname: str = Memory.read_i64(g_annot_names + (i * 8) as i64) as str
        if str_eq(aname, name) == 1:
            return i
        i = i + 1
    return -1

fun get_annot_target(idx: i32) -> str:
    return Memory.read_i64(g_annot_targets + (idx * 8) as i64) as str

fun get_annot_effect(idx: i32) -> str:
    return Memory.read_i64(g_annot_effects + (idx * 8) as i64) as str

fun get_annot_emit_kind(idx: i32) -> str:
    return Memory.read_i64(g_annot_emit_kinds + (idx * 8) as i64) as str

fun get_annot_emit_msg(idx: i32) -> str:
    return Memory.read_i64(g_annot_emit_msgs + (idx * 8) as i64) as str

fun get_annot_exclusive(idx: i32) -> str:
    return Memory.read_i64(g_annot_exclusives + (idx * 8) as i64) as str

fun get_annot_composes(idx: i32) -> str:
    return Memory.read_i64(g_annot_composes_list + (idx * 8) as i64) as str

fun get_annot_params(idx: i32) -> i64:
    return Memory.read_i64(g_annot_param_lists + (idx * 8) as i64)

fun target_allows(targets: str, kind: str) -> i32:
    # Check if 'kind' is in comma-separated 'targets' string
    # Simple: check if targets contains the kind substring
    if str_eq(targets, kind) == 1:
        return 1
    # Check for "fun, struct" style — look for ",kind" or "kind,"
    tlen: i32 = Memory.strlen(targets as i64)
    klen: i32 = Memory.strlen(kind as i64)
    pos: i32 = 0
    while pos <= (tlen - klen):
        matched: i32 = 1
        j: i32 = 0
        while j < klen:
            tc: i32 = Memory.read_i8((targets as i64) + (pos + j) as i64) as i32
            kc: i32 = Memory.read_i8((kind as i64) + j as i64) as i32
            if tc != kc:
                matched = 0
                j = klen
            j = j + 1
        if matched == 1:
            # Verify word boundary: before must be start or comma/space, after must be end or comma/space
            ok_before: i32 = 0
            if pos == 0:
                ok_before = 1
            else:
                cb: i32 = Memory.read_i8((targets as i64) + (pos - 1) as i64) as i32
                if cb == 44 or cb == 32:
                    ok_before = 1
            ok_after: i32 = 0
            if (pos + klen) >= tlen:
                ok_after = 1
            else:
                ca: i32 = Memory.read_i8((targets as i64) + (pos + klen) as i64) as i32
                if ca == 44 or ca == 32:
                    ok_after = 1
            if ok_before == 1 and ok_after == 1:
                return 1
        pos = pos + 1
    return 0

fun init_builtin_annots():
    # Built-in annotations now defined in library/prelude/annotations.dlt
    # and loaded automatically by load_prelude() in the driver.
    return

# Check if a node has a specific annotation in its +80 annotation list
fun node_has_annot(node: i64, annot_name: str) -> i32:
    annot_list: i64 = Memory.read_i64(node + 80)
    if annot_list == 0:
        return 0
    count: i32 = Memory.read_i32(annot_list)
    i: i32 = 0
    while i < count:
        anode: i64 = Memory.read_i64(annot_list + 8 + (i * 8) as i64)
        aname: str = Memory.read_i64(anode + 8) as str
        if str_eq(aname, annot_name) == 1:
            return 1
        i = i + 1
    return 0

# Get annotation use node from a declaration node's +80 list
fun get_annot_use(node: i64, annot_name: str) -> i64:
    annot_list: i64 = Memory.read_i64(node + 80)
    if annot_list == 0:
        return 0
    count: i32 = Memory.read_i32(annot_list)
    i: i32 = 0
    while i < count:
        anode: i64 = Memory.read_i64(annot_list + 8 + (i * 8) as i64)
        aname: str = Memory.read_i64(anode + 8) as str
        if str_eq(aname, annot_name) == 1:
            return anode
        i = i + 1
    return 0

# Function annotation tracking (by mangled name)
# Records which functions have specific annotations for call-site checks
g_fn_annot_names: i64 = 0
g_fn_annot_flags: i64 = 0
g_fn_annot_msgs: i64 = 0
g_fn_annot_count: i32 = 0
MAX_FN_ANNOTS: i32 = 1024

fun init_fn_annot_registry():
    MAX_FN_ANNOTS = 1024
    g_fn_annot_names = Memory.malloc_zeroed(8192)
    g_fn_annot_flags = Memory.malloc_zeroed(8192)
    g_fn_annot_msgs = Memory.malloc_zeroed(8192)
    g_fn_annot_count = 0

# flags: 1=deprecated, 2=must_use
fun register_fn_annot(fname: str, flags: i32, msg: str):
    idx: i32 = g_fn_annot_count
    if idx >= MAX_FN_ANNOTS:
        return
    Memory.write_i64(g_fn_annot_names + (idx * 8) as i64, fname as i64)
    Memory.write_i32(g_fn_annot_flags + (idx * 4) as i64, flags)
    Memory.write_i64(g_fn_annot_msgs + (idx * 8) as i64, msg as i64)
    g_fn_annot_count = idx + 1

fun get_fn_annot_flags(fname: str) -> i32:
    i: i32 = 0
    while i < g_fn_annot_count:
        fn: str = Memory.read_i64(g_fn_annot_names + (i * 8) as i64) as str
        if str_eq(fn, fname) == 1:
            return Memory.read_i32(g_fn_annot_flags + (i * 4) as i64)
        i = i + 1
    return 0

fun get_fn_annot_msg(fname: str) -> str:
    i: i32 = 0
    while i < g_fn_annot_count:
        fn: str = Memory.read_i64(g_fn_annot_names + (i * 8) as i64) as str
        if str_eq(fn, fname) == 1:
            return Memory.read_i64(g_fn_annot_msgs + (i * 8) as i64) as str
        i = i + 1
    return ""

# Check if string starts with "llvm:" (5 chars: l=108, l=108, v=118, m=109, :=58)
fun starts_with_llvm(s: str) -> i32:
    if Memory.strlen(s as i64) < 6:
        return 0
    c0: i32 = Memory.read_i8((s as i64) + 0) as i32
    c1: i32 = Memory.read_i8((s as i64) + 1) as i32
    c2: i32 = Memory.read_i8((s as i64) + 2) as i32
    c3: i32 = Memory.read_i8((s as i64) + 3) as i32
    c4: i32 = Memory.read_i8((s as i64) + 4) as i32
    if c0 == 108 and c1 == 108 and c2 == 118 and c3 == 109 and c4 == 58:
        return 1
    return 0

# Collect all LLVM passthrough attributes from an annotation name, expanding composes
fun collect_llvm_attrs_for_annot(aname: str, acc: str) -> str:
    aidx: i32 = find_annot(aname)
    if aidx < 0:
        return acc
    out: str = acc
    # Direct effect
    aeff: str = get_annot_effect(aidx)
    if starts_with_llvm(aeff) == 1:
        attr_name: str = Str.substring(aeff, 5, Memory.strlen(aeff as i64))
        if str_eq(out, "") == 1:
            out = Str.concat("\"", Str.concat(attr_name, "\""))
        else:
            out = Str.concat(out, Str.concat(", \"", Str.concat(attr_name, "\"")))
    # Composed annotations (comma-separated names)
    comp: str = get_annot_composes(aidx)
    if str_eq(comp, "") == 0:
        # Parse comma-separated composed annotation names
        clen: i32 = Memory.strlen(comp as i64)
        cstart: i32 = 0
        cpos: i32 = 0
        while cpos <= clen:
            ch: i32 = 0
            if cpos < clen:
                ch = Memory.read_i8((comp as i64) + cpos as i64) as i32
            if cpos == clen or ch == 44:
                # Extract name from cstart to cpos
                cname: str = Str.substring(comp, cstart, cpos)
                # Skip leading spaces
                while Memory.strlen(cname as i64) > 0:
                    fc: i32 = Memory.read_i8(cname as i64) as i32
                    if fc == 32:
                        cname = Str.substring(cname, 1, Memory.strlen(cname as i64))
                    else:
                        break
                if str_eq(cname, "") == 0:
                    out = collect_llvm_attrs_for_annot(cname, out)
                cstart = cpos + 1
            cpos = cpos + 1
    return out

# Collect LLVM attrs from annotation node list at +80
fun collect_llvm_attrs_from_list(annot_list: i64) -> str:
    if annot_list == 0:
        return ""
    acc2: str = ""
    ac: i32 = Memory.read_i32(annot_list)
    ai: i32 = 0
    while ai < ac:
        an: i64 = Memory.read_i64(annot_list + 8 + (ai * 8) as i64)
        aname: str = Memory.read_i64(an + 8) as str
        acc2 = collect_llvm_attrs_for_annot(aname, acc2)
        ai = ai + 1
    return acc2

# ==========================================
# MLIR Type Mapping
fun mlir_type(dolet_type: str) -> str:
    # Resolve type aliases first (e.g. type UserID = i64)
    alias_resolved: str = resolve_alias(dolet_type)
    if str_eq(alias_resolved, "") == 0:
        return mlir_type(alias_resolved)

    # Direct struct type checks (for transparent types like I32, I64)
    if str_eq(dolet_type, "I8") == 1:
        return "i8"
    if str_eq(dolet_type, "I16") == 1:
        return "i16"
    if str_eq(dolet_type, "I32") == 1:
        return "i32"
    if str_eq(dolet_type, "I64") == 1:
        return "i64"
    if str_eq(dolet_type, "I128") == 1:
        return "i128"
    if str_eq(dolet_type, "U8") == 1:
        return "i8"
    if str_eq(dolet_type, "U16") == 1:
        return "i16"
    if str_eq(dolet_type, "U32") == 1:
        return "i32"
    if str_eq(dolet_type, "U64") == 1:
        return "i64"
    if str_eq(dolet_type, "U128") == 1:
        return "i128"
    if str_eq(dolet_type, "F32") == 1:
        return "f32"
    if str_eq(dolet_type, "F64") == 1:
        return "f64"
    if str_eq(dolet_type, "Bool") == 1:
        return "i1"
    if str_eq(dolet_type, "Char") == 1:
        return "i8"

    # Compiler intrinsic types (__i32 → LLVM i32, etc.)
    if str_eq(dolet_type, "__i8") == 1:
        return "i8"
    if str_eq(dolet_type, "__i16") == 1:
        return "i16"
    if str_eq(dolet_type, "__i32") == 1:
        return "i32"
    if str_eq(dolet_type, "__i64") == 1:
        return "i64"
    if str_eq(dolet_type, "__i128") == 1:
        return "i128"
    if str_eq(dolet_type, "__f32") == 1:
        return "f32"
    if str_eq(dolet_type, "__f64") == 1:
        return "f64"
    if str_eq(dolet_type, "__ptr") == 1:
        return "!llvm.ptr"
    if str_eq(dolet_type, "__bool") == 1:
        return "i1"
    if str_eq(dolet_type, "__char") == 1:
        return "i8"
    if str_eq(dolet_type, "__str") == 1:
        return "!llvm.ptr"
    if str_eq(dolet_type, "int") == 1:
        return "i32"
    if str_eq(dolet_type, "i8") == 1:
        return "i8"
    if str_eq(dolet_type, "i16") == 1:
        return "i16"
    if str_eq(dolet_type, "i32") == 1:
        return "i32"
    if str_eq(dolet_type, "i64") == 1:
        return "i64"
    if str_eq(dolet_type, "i128") == 1:
        return "i128"
    if str_eq(dolet_type, "u8") == 1:
        return "i8"
    if str_eq(dolet_type, "u16") == 1:
        return "i16"
    if str_eq(dolet_type, "u32") == 1:
        return "i32"
    if str_eq(dolet_type, "u64") == 1:
        return "i64"
    if str_eq(dolet_type, "u128") == 1:
        return "i128"
    if str_eq(dolet_type, "float") == 1:
        return "f32"
    if str_eq(dolet_type, "f32") == 1:
        return "f32"
    if str_eq(dolet_type, "double") == 1:
        return "f64"
    if str_eq(dolet_type, "f64") == 1:
        return "f64"
    if str_eq(dolet_type, "bool") == 1:
        return "i1"
    if str_eq(dolet_type, "i1") == 1:
        return "i1"
    if str_eq(dolet_type, "char") == 1:
        return "i8"
    if str_eq(dolet_type, "string") == 1:
        return "!llvm.ptr"
    if str_eq(dolet_type, "str") == 1:
        return "!llvm.ptr"
    if str_eq(dolet_type, "ptr") == 1:
        return "!llvm.ptr"
    if str_eq(dolet_type, "Pointer") == 1:
        return "!llvm.ptr"
    if str_eq(dolet_type, "array") == 1:
        return "!llvm.ptr"
    if str_eq(dolet_type, "list") == 1:
        return "!llvm.ptr"
    if str_eq(dolet_type, "map") == 1:
        return "!llvm.ptr"
    if str_eq(dolet_type, "null") == 1:
        return "!llvm.ptr"
    # ptr[T] — all typed pointers are opaque pointers in MLIR
    if Memory.read_i8(dolet_type as i64) == 112:
        if Memory.read_i8((dolet_type as i64) + 1) == 116:
            if Memory.read_i8((dolet_type as i64) + 2) == 114:
                if Memory.read_i8((dolet_type as i64) + 3) == 91:
                    return "!llvm.ptr"
    # Check if enum (all enums are i32)
    if is_enum_type(dolet_type) == 1:
        return "i32"
    # Check if struct (all structs are pointers)
    if is_struct_type(dolet_type) == 1:
        return "!llvm.ptr"
    # Default: pointer
    return "!llvm.ptr"

# ==========================================
# Ptr[T] Type Helpers
# ==========================================
fun is_ptr_type(t: str) -> i32:
    tlen: i64 = Memory.strlen(t)
    if tlen < 5:
        return 0
    if Memory.read_i8(t as i64) == 112:
        if Memory.read_i8((t as i64) + 1) == 116:
            if Memory.read_i8((t as i64) + 2) == 114:
                if Memory.read_i8((t as i64) + 3) == 91:
                    return 1
    return 0

fun ptr_elem_type(t: str) -> str:
    # t = "ptr[i8]" → return "i8"
    slen: i64 = Memory.strlen(t)
    return str_from_range(t, 4, slen - 1)

# ==========================================
# Emit Helpers — common MLIR patterns
# ==========================================
fun emit_ind(text: str):
    emit(Str.concat(ind(), text))

fun emit_const_i32(val: i32) -> str:
    tmp: str = new_tmp()
    emit_ind(Str.concat(Str.concat(Str.concat(tmp, " = llvm.mlir.constant("), Convert.i64_to_str(val as i64)), " : i32) : i32"))
    return tmp

fun emit_const_i64(val: i64) -> str:
    tmp: str = new_tmp()
    emit_ind(Str.concat(Str.concat(Str.concat(tmp, " = llvm.mlir.constant("), Convert.i64_to_str(val)), " : i64) : i64"))
    return tmp

fun emit_const_i1(val: i32) -> str:
    tmp: str = new_tmp()
    emit_ind(Str.concat(Str.concat(Str.concat(tmp, " = llvm.mlir.constant("), Convert.i64_to_str(val as i64)), " : i1) : i1"))
    return tmp

fun emit_zero_ptr() -> str:
    tmp: str = new_tmp()
    emit_ind(Str.concat(tmp, " = llvm.mlir.zero : !llvm.ptr"))
    return tmp

fun emit_alloca(mtype: str) -> str:
    c1: str = emit_const_i64(1)
    alloc: str = new_tmp()
    emit_ind(Str.concat(Str.concat(Str.concat(Str.concat(alloc, " = llvm.alloca "), c1), Str.concat(" x ", mtype)), " : (i64) -> !llvm.ptr"))
    return alloc

fun emit_store(val: str, dest: str, mtype: str):
    emit_ind(Str.concat(Str.concat(Str.concat(Str.concat(Str.concat("llvm.store ", val), ", "), dest), Str.concat(" : ", mtype)), ", !llvm.ptr"))

fun emit_load(src: str, mtype: str) -> str:
    tmp: str = new_tmp()
    emit_ind(Str.concat(Str.concat(Str.concat(Str.concat(tmp, " = llvm.load "), src), Str.concat(" : !llvm.ptr -> ", mtype)), ""))
    return tmp

fun emit_addr_of(global_name: str) -> str:
    tmp: str = new_tmp()
    emit_ind(Str.concat(Str.concat(Str.concat(tmp, " = llvm.mlir.addressof @"), global_name), " : !llvm.ptr"))
    return tmp

fun emit_call(fn_name: str, args: str, arg_types: str, ret_type: str) -> str:
    if str_eq(ret_type, "") == 1:
        emit_ind(Str.concat(Str.concat(Str.concat(Str.concat("llvm.call @", fn_name), "("), args), Str.concat(") : (", Str.concat(arg_types, ") -> ()"))))
        return ""
    tmp: str = new_tmp()
    emit_ind(Str.concat(Str.concat(Str.concat(Str.concat(Str.concat(tmp, " = llvm.call @"), fn_name), "("), args), Str.concat(") : (", Str.concat(arg_types, Str.concat(") -> ", ret_type)))))
    return tmp

# ==========================================
# String Escape for MLIR
# ==========================================
fun escape_mlir_string(text: str) -> str:
    result: str = ""
    slen: i64 = Memory.strlen(text)
    i: i64 = 0
    while i < slen:
        c: i8 = Memory.read_i8((text as i64) + i)
        if c == 10:
            result = Str.concat(result, "\\0A")
        elif c == 13:
            result = Str.concat(result, "\\0D")
        elif c == 34:
            result = Str.concat(result, "\\22")
        elif c == 92:
            # Handle escape sequences: \n \t \r \0 \\ \"
            next_c: i8 = 0
            if i + 1 < slen:
                next_c = Memory.read_i8((text as i64) + i + 1)
            if next_c == 110:
                result = Str.concat(result, "\\0A")
                i = i + 1
            elif next_c == 116:
                result = Str.concat(result, "\\09")
                i = i + 1
            elif next_c == 114:
                result = Str.concat(result, "\\0D")
                i = i + 1
            elif next_c == 48:
                result = Str.concat(result, "\\00")
                i = i + 1
            elif next_c == 92:
                result = Str.concat(result, "\\5C")
                i = i + 1
            elif next_c == 34:
                result = Str.concat(result, "\\22")
                i = i + 1
            else:
                result = Str.concat(result, "\\5C")
        else:
            # Single char append — build 1-byte string
            buf: i64 = Memory.malloc_zeroed(2)
            Memory.write_i8(buf, c)
            Memory.write_i8(buf + 1, 0)
            result = Str.concat(result, buf as str)
        i = i + 1
    return result

# ==========================================
# Function Overload Registry
# ==========================================
g_ovl_orig: i64 = 0
g_ovl_params: i64 = 0
g_ovl_mangled: i64 = 0
g_ovl_count: i32 = 0

fun init_overload_registry():
    g_ovl_orig = Memory.malloc_zeroed(4096 * 8)
    g_ovl_params = Memory.malloc_zeroed(4096 * 8)
    g_ovl_mangled = Memory.malloc_zeroed(4096 * 8)
    g_ovl_count = 0

fun normalize_type(t: str) -> str:
    if str_eq(t, "string") == 1:
        return "str"
    if str_eq(t, "int") == 1:
        return "i32"
    if str_eq(t, "float") == 1:
        return "f32"
    if str_eq(t, "double") == 1:
        return "f64"
    return t

fun build_param_types_str(params: i64) -> str:
    if params == 0:
        return ""
    pc: i32 = nl_count(params)
    result: str = ""
    i: i32 = 0
    while i < pc:
        pnode: i64 = nl_get(params, i)
        ptype: str = Memory.read_i64(pnode + 16) as str
        ptype = normalize_type(ptype)
        if i > 0:
            result = Str.concat(result, ",")
        result = Str.concat(result, ptype)
        i = i + 1
    return result

fun build_param_types_str_no_self(params: i64) -> str:
    if params == 0:
        return ""
    pc: i32 = nl_count(params)
    result: str = ""
    i: i32 = 0
    while i < pc:
        pnode: i64 = nl_get(params, i)
        pname: str = Memory.read_i64(pnode + 8) as str
        if str_eq(pname, "self") == 0:
            ptype: str = Memory.read_i64(pnode + 16) as str
            ptype = normalize_type(ptype)
            if Memory.strlen(result) > 0:
                result = Str.concat(result, ",")
            result = Str.concat(result, ptype)
        i = i + 1
    return result

fun register_overload(orig_name: str, param_types_str: str) -> str:
    # Check if this exact (orig_name, param_types) already exists
    i: i32 = 0
    while i < g_ovl_count:
        off: i64 = (i as i64) * 8
        en: str = Memory.read_i64(g_ovl_orig + off) as str
        ep: str = Memory.read_i64(g_ovl_params + off) as str
        if str_eq(en, orig_name) == 1 and str_eq(ep, param_types_str) == 1:
            return Memory.read_i64(g_ovl_mangled + off) as str
        i = i + 1

    # Check if any overload with same name exists
    has_existing: i32 = 0
    i = 0
    while i < g_ovl_count:
        off2: i64 = (i as i64) * 8
        en2: str = Memory.read_i64(g_ovl_orig + off2) as str
        if str_eq(en2, orig_name) == 1:
            has_existing = 1
            i = g_ovl_count
        i = i + 1

    # Build mangled name
    mangled: str = orig_name
    if has_existing == 1:
        # Subsequent overload: name__type1_type2
        # Replace commas with underscores
        suffix: str = ""
        slen: i64 = Memory.strlen(param_types_str)
        j: i64 = 0
        while j < slen:
            c: i8 = Memory.read_i8((param_types_str as i64) + j)
            if c == 44:
                suffix = Str.concat(suffix, "_")
            else:
                buf: i64 = Memory.malloc_zeroed(2)
                Memory.write_i8(buf, c)
                Memory.write_i8(buf + 1, 0)
                suffix = Str.concat(suffix, buf as str)
            j = j + 1
        mangled = Str.concat(Str.concat(orig_name, "__"), suffix)

    # Register
    off3: i64 = (g_ovl_count as i64) * 8
    Memory.write_i64(g_ovl_orig + off3, orig_name as i64)
    Memory.write_i64(g_ovl_params + off3, param_types_str as i64)
    Memory.write_i64(g_ovl_mangled + off3, mangled as i64)
    g_ovl_count = g_ovl_count + 1
    return mangled

fun resolve_overload(orig_name: str, arg_types_str: str) -> str:
    # Search for exact match on (orig_name, arg_types_str)
    i: i32 = 0
    while i < g_ovl_count:
        off: i64 = (i as i64) * 8
        en: str = Memory.read_i64(g_ovl_orig + off) as str
        ep: str = Memory.read_i64(g_ovl_params + off) as str
        if str_eq(en, orig_name) == 1 and str_eq(ep, arg_types_str) == 1:
            return Memory.read_i64(g_ovl_mangled + off) as str
        i = i + 1
    # No overload found — return original name
    return orig_name

# ==========================================
# Generic Type Registry
# Tracks which struct names have type parameters
# ==========================================
g_generic_names: i64 = 0
g_generic_params: i64 = 0
g_generic_count: i32 = 0

fun init_generic_registry():
    g_generic_names = Memory.malloc_zeroed(512 * 8)
    g_generic_params = Memory.malloc_zeroed(512 * 8)
    g_generic_count = 0

fun register_generic(name: str, params: i64):
    off: i64 = (g_generic_count as i64) * 8
    Memory.write_i64(g_generic_names + off, name as i64)
    Memory.write_i64(g_generic_params + off, params)
    g_generic_count = g_generic_count + 1

fun is_generic_type(name: str) -> i32:
    i: i32 = 0
    while i < g_generic_count:
        off: i64 = (i as i64) * 8
        if str_eq(Memory.read_i64(g_generic_names + off) as str, name) == 1:
            return 1
        i = i + 1
    return 0

fun get_generic_params(name: str) -> i64:
    i: i32 = 0
    while i < g_generic_count:
        off: i64 = (i as i64) * 8
        if str_eq(Memory.read_i64(g_generic_names + off) as str, name) == 1:
            return Memory.read_i64(g_generic_params + off)
        i = i + 1
    return 0

# ==========================================
# Module Symbol Registry
# ==========================================
g_mod_sym_module: i64 = 0
g_mod_sym_name: i64 = 0
g_mod_sym_kind: i64 = 0
g_mod_sym_count: i32 = 0

fun init_module_registry():
    g_mod_sym_module = Memory.malloc_zeroed(2048 * 8)
    g_mod_sym_name = Memory.malloc_zeroed(2048 * 8)
    g_mod_sym_kind = Memory.malloc_zeroed(2048 * 4)
    g_mod_sym_count = 0

fun register_module_symbol(mod_name: str, sym_name: str, kind: i32):
    off8: i64 = (g_mod_sym_count as i64) * 8
    off4: i64 = (g_mod_sym_count as i64) * 4
    Memory.write_i64(g_mod_sym_module + off8, mod_name as i64)
    Memory.write_i64(g_mod_sym_name + off8, sym_name as i64)
    Memory.write_i32(g_mod_sym_kind + off4, kind)
    g_mod_sym_count = g_mod_sym_count + 1

fun lookup_module_symbol(mod_name: str, sym_name: str) -> i32:
    i: i32 = 0
    while i < g_mod_sym_count:
        off8: i64 = (i as i64) * 8
        m: str = Memory.read_i64(g_mod_sym_module + off8) as str
        s: str = Memory.read_i64(g_mod_sym_name + off8) as str
        if str_eq(m, mod_name) == 1:
            if str_eq(s, sym_name) == 1:
                return 1
        i = i + 1
    return 0

# ==========================================
# Init All Registries
# ==========================================
fun init_all_registries():
    init_ast_constants()
    init_codegen()
    init_str_pool()
    init_var_registry()
    init_scopes()
    init_fun_sigs()
    init_struct_registry()
    init_transparent_registry()
    init_stack_registry()
    init_parent_registry()
    init_alias_registry()
    init_enum_registry()
    init_global_vars()
    init_global_lists()
    init_static_fields()
    init_impl_registry()
    init_overload_registry()
    init_generic_registry()
    init_module_registry()
    init_tree_shaking()
    init_emitted_fns()
    # Pre-register common strings
    gen_string_const("%s\n")
    gen_string_const("null")
    gen_string_const("")
    gen_string_const("true")
    gen_string_const("false")

##############################
# Tree Shaking — Dead Code Elimination
# Opt-in via --tree-shake flag
##############################

# Reachable symbols tracking
g_ts_names: i64 = 0
g_ts_kinds: i64 = 0
g_ts_processed: i64 = 0
g_ts_count: i32 = 0
g_ts_cap: i32 = 2048
g_tree_shake_enabled: i32 = 0

fun init_tree_shaking():
    g_ts_cap = 2048
    g_ts_names = Memory.malloc_zeroed((g_ts_cap as i64) * 8)
    g_ts_kinds = Memory.malloc_zeroed((g_ts_cap as i64) * 4)
    g_ts_processed = Memory.malloc_zeroed((g_ts_cap as i64) * 4)
    g_ts_count = 0

fun ts_mark_reachable(name: str, kind: i32):
    if (name as i64) == 0:
        return
    if Memory.strlen(name) == 0:
        return
    i: i32 = 0
    while i < g_ts_count:
        off8: i64 = (i as i64) * 8
        existing: str = Memory.read_i64(g_ts_names + off8) as str
        if str_eq(existing, name) == 1:
            return
        i = i + 1
    if g_ts_count < g_ts_cap:
        off8: i64 = (g_ts_count as i64) * 8
        off4: i64 = (g_ts_count as i64) * 4
        Memory.write_i64(g_ts_names + off8, name as i64)
        Memory.write_i32(g_ts_kinds + off4, kind)
        Memory.write_i32(g_ts_processed + off4, 0)
        g_ts_count = g_ts_count + 1

fun ts_mark_fun(name: str):
    if is_struct_type(name) == 1:
        ts_mark_struct(name)
        return
    ts_mark_reachable(name, 0)

fun ts_mark_struct(name: str):
    ts_mark_reachable(name, 1)
    parent: str = get_parent_struct(name)
    if Memory.strlen(parent) > 0:
        ts_mark_struct(parent)

fun ts_is_reachable(name: str) -> i32:
    if g_tree_shake_enabled == 0:
        return 1
    i: i32 = 0
    while i < g_ts_count:
        off8: i64 = (i as i64) * 8
        existing: str = Memory.read_i64(g_ts_names + off8) as str
        if str_eq(existing, name) == 1:
            return 1
        i = i + 1
    return 0

fun ts_is_extern_fun_reachable(name: str) -> i32:
    if g_tree_shake_enabled == 0:
        return 1
    i: i32 = 0
    while i < g_ts_count:
        off8: i64 = (i as i64) * 8
        existing: str = Memory.read_i64(g_ts_names + off8) as str
        if str_eq(existing, name) == 1:
            return 1
        i = i + 1
    return 0

fun ts_mark_method_by_name(method_name: str):
    i: i32 = 0
    while i < g_impl_count:
        off8: i64 = (i as i64) * 8
        mname: str = Memory.read_i64(g_impl_method_name + off8) as str
        if (mname as i64) != 0:
            if str_eq(mname, method_name) == 1:
                sname: str = Memory.read_i64(g_impl_struct + off8) as str
                ts_mark_struct(sname)
        i = i + 1

fun ts_walk_list(nlist: i64):
    if nlist == 0:
        return
    c: i32 = nl_count(nlist)
    i: i32 = 0
    while i < c:
        ts_walk_node(nl_get(nlist, i))
        i = i + 1

fun ts_walk_node(node: i64):
    if node == 0:
        return
    nt: i32 = nd_type(node)

    if nt == NODE_FUN_CALL:
        fname: str = Memory.read_i64(node + 8) as str
        ts_mark_fun(fname)
        ts_walk_list(Memory.read_i64(node + 16))
        return
    if nt == NODE_STATIC_METHOD:
        sname: str = Memory.read_i64(node + 8) as str
        ts_mark_struct(sname)
        ts_walk_list(Memory.read_i64(node + 24))
        return
    if nt == NODE_INST_METHOD:
        mname: str = Memory.read_i64(node + 16) as str
        ts_mark_method_by_name(mname)
        ts_walk_list(Memory.read_i64(node + 24))
        return
    if nt == NODE_NS_FUN_CALL:
        fname2: str = Memory.read_i64(node + 16) as str
        ts_mark_fun(fname2)
        ts_walk_list(Memory.read_i64(node + 24))
        return
    if nt == NODE_NS_STATIC_METHOD:
        sname2: str = Memory.read_i64(node + 16) as str
        ts_mark_struct(sname2)
        ts_walk_list(Memory.read_i64(node + 32))
        return
    if nt == NODE_STRUCT_INST:
        sname3: str = Memory.read_i64(node + 8) as str
        ts_mark_struct(sname3)
        fvl: i64 = Memory.read_i64(node + 16)
        if fvl != 0:
            fvc: i32 = nl_count(fvl)
            fi: i32 = 0
            while fi < fvc:
                fv: i64 = nl_get(fvl, fi)
                ts_walk_node(Memory.read_i64(fv + 16))
                fi = fi + 1
        return
    if nt == NODE_NS_STRUCT_INST:
        sname4: str = Memory.read_i64(node + 16) as str
        ts_mark_struct(sname4)
        fvl2: i64 = Memory.read_i64(node + 24)
        if fvl2 != 0:
            fvc2: i32 = nl_count(fvl2)
            fi2: i32 = 0
            while fi2 < fvc2:
                fv2: i64 = nl_get(fvl2, fi2)
                ts_walk_node(Memory.read_i64(fv2 + 16))
                fi2 = fi2 + 1
        return
    if nt == NODE_FUN_REF:
        fname3: str = Memory.read_i64(node + 8) as str
        ts_mark_fun(fname3)
        return
    if nt == NODE_SUPER_METHOD:
        ts_walk_list(Memory.read_i64(node + 16))
        return
    if nt == NODE_BUILTIN_CALL:
        ts_walk_list(Memory.read_i64(node + 16))
        return
    if nt == NODE_ENUM_ACCESS:
        ename: str = Memory.read_i64(node + 8) as str
        ts_mark_reachable(ename, 2)
        return
    if nt == NODE_VAR_DECL:
        vtype: str = Memory.read_i64(node + 8) as str
        if (vtype as i64) != 0:
            if Memory.strlen(vtype) > 0:
                if is_struct_type(vtype) == 1:
                    ts_mark_struct(vtype)
        ts_walk_node(Memory.read_i64(node + 24))
        return
    if nt == NODE_ASSIGN:
        ts_walk_node(Memory.read_i64(node + 16))
        return
    if nt == NODE_FIELD_ASSIGN:
        ts_walk_node(Memory.read_i64(node + 24))
        return
    if nt == NODE_STATIC_FIELD_ASSIGN:
        sname5: str = Memory.read_i64(node + 8) as str
        if (sname5 as i64) != 0:
            if is_struct_type(sname5) == 1:
                ts_mark_struct(sname5)
        ts_walk_node(Memory.read_i64(node + 24))
        return
    if nt == NODE_STATIC_FIELD:
        sname6: str = Memory.read_i64(node + 8) as str
        if (sname6 as i64) != 0:
            if is_struct_type(sname6) == 1:
                ts_mark_struct(sname6)
        return
    if nt == NODE_BINARY_OP or nt == NODE_COMPARISON or nt == NODE_LOGICAL_OP:
        ts_walk_node(Memory.read_i64(node + 16))
        ts_walk_node(Memory.read_i64(node + 24))
        return
    if nt == NODE_UNARY_OP:
        ts_walk_node(Memory.read_i64(node + 16))
        return
    if nt == NODE_CAST:
        ts_walk_node(Memory.read_i64(node + 8))
        return
    if nt == NODE_PAREN:
        ts_walk_node(Memory.read_i64(node + 8))
        return
    if nt == NODE_TERNARY:
        ts_walk_node(Memory.read_i64(node + 8))
        ts_walk_node(Memory.read_i64(node + 16))
        ts_walk_node(Memory.read_i64(node + 24))
        return
    if nt == NODE_RETURN:
        ts_walk_node(Memory.read_i64(node + 8))
        return
    if nt == NODE_IF:
        ts_walk_node(Memory.read_i64(node + 8))
        ts_walk_list(Memory.read_i64(node + 16))
        ts_walk_list(Memory.read_i64(node + 24))
        return
    if nt == NODE_WHILE:
        ts_walk_node(Memory.read_i64(node + 8))
        ts_walk_list(Memory.read_i64(node + 16))
        return
    if nt == NODE_FOR:
        ts_walk_node(Memory.read_i64(node + 16))
        ts_walk_node(Memory.read_i64(node + 24))
        ts_walk_list(Memory.read_i64(node + 32))
        return
    if nt == NODE_FOR_EACH:
        ts_walk_node(Memory.read_i64(node + 32))
        ts_walk_list(Memory.read_i64(node + 40))
        return
    if nt == NODE_BLOCK:
        ts_walk_list(Memory.read_i64(node + 8))
        return
    if nt == NODE_MATCH:
        ts_walk_node(Memory.read_i64(node + 8))
        ts_walk_list(Memory.read_i64(node + 16))
        ts_walk_list(Memory.read_i64(node + 24))
        return
    if nt == NODE_CASE:
        ts_walk_list(Memory.read_i64(node + 16))
        return
    if nt == NODE_ARRAY_LIT or nt == NODE_LIST_LIT:
        ts_walk_list(Memory.read_i64(node + 8))
        return
    if nt == NODE_ARRAY_ACCESS:
        ts_walk_node(Memory.read_i64(node + 16))
        return
    if nt == NODE_LIST_METHOD:
        ts_walk_list(Memory.read_i64(node + 24))
        return
    if nt == NODE_FSTRING:
        ts_walk_list(Memory.read_i64(node + 8))
        return
    if nt == NODE_STR_CONCAT:
        ts_walk_node(Memory.read_i64(node + 8))
        ts_walk_node(Memory.read_i64(node + 16))
        return
    if nt == NODE_FIELD_ACCESS:
        return
    if nt == NODE_NESTED_FIELD:
        ts_walk_node(Memory.read_i64(node + 8))
        return
    if nt == NODE_NESTED_METHOD:
        ts_walk_node(Memory.read_i64(node + 8))
        ts_walk_list(Memory.read_i64(node + 24))
        return
    if nt == NODE_CONTEXT_BLOCK:
        ts_walk_node(Memory.read_i64(node + 8))
        ts_walk_list(Memory.read_i64(node + 24))
        return
    if nt == NODE_IS_NULL or nt == NODE_IS_NOT_NULL:
        ts_walk_node(Memory.read_i64(node + 8))
        return
    if nt == NODE_FIELD_VAL:
        ts_walk_node(Memory.read_i64(node + 16))
        return
    if nt == NODE_MAP_ENTRY:
        ts_walk_node(Memory.read_i64(node + 8))
        ts_walk_node(Memory.read_i64(node + 16))
        return
    if nt == NODE_MAP_LIT:
        ts_walk_list(Memory.read_i64(node + 8))
        return
    if nt == NODE_STRUCT_FIELD:
        ts_walk_node(Memory.read_i64(node + 24))
        return
    return

fun ts_seed(ast: i64):
    sc: i32 = nl_count(ast)
    i: i32 = 0
    while i < sc:
        node: i64 = nl_get(ast, i)
        nt: i32 = nd_type(node)
        if nt != NODE_FUN_DEF and nt != NODE_STRUCT_DECL and nt != NODE_ENUM_DECL and nt != NODE_IMPL_BLOCK and nt != NODE_EXTEND_BLOCK and nt != NODE_EXTERN_BLOCK and nt != NODE_TRAIT_DECL and nt != NODE_TYPE_ALIAS and nt != NODE_IMPORT and nt != NODE_MODULE_DECL and nt != NODE_EXPORT and nt != NODE_REQUIRES and nt != NODE_USE_MODULE:
            ts_walk_node(node)
        i = i + 1
    ts_mark_fun("main")

fun ts_process_function(ast: i64, fname: str):
    sc: i32 = nl_count(ast)
    i: i32 = 0
    while i < sc:
        node: i64 = nl_get(ast, i)
        nt: i32 = nd_type(node)
        if nt == NODE_FUN_DEF:
            n_name: str = Memory.read_i64(node + 8) as str
            if str_eq(n_name, fname) == 1:
                ts_walk_list(Memory.read_i64(node + 32))
                return
        i = i + 1

fun ts_process_struct(ast: i64, sname: str):
    sc: i32 = nl_count(ast)
    i: i32 = 0
    while i < sc:
        node: i64 = nl_get(ast, i)
        nt: i32 = nd_type(node)
        if nt == NODE_STRUCT_DECL:
            n_name: str = Memory.read_i64(node + 8) as str
            if str_eq(n_name, sname) == 1:
                ts_walk_list(Memory.read_i64(node + 40))
                base: str = Memory.read_i64(node + 32) as str
                if (base as i64) != 0:
                    if Memory.strlen(base) > 0:
                        ts_mark_struct(base)
        elif nt == NODE_IMPL_BLOCK:
            n_name2: str = Memory.read_i64(node + 8) as str
            if str_eq(n_name2, sname) == 1:
                mlist: i64 = Memory.read_i64(node + 16)
                if mlist != 0:
                    mc: i32 = nl_count(mlist)
                    mi: i32 = 0
                    while mi < mc:
                        mnode: i64 = nl_get(mlist, mi)
                        ts_walk_list(Memory.read_i64(mnode + 32))
                        mi = mi + 1
        elif nt == NODE_EXTEND_BLOCK:
            n_name3: str = Memory.read_i64(node + 8) as str
            if str_eq(n_name3, sname) == 1:
                mlist2: i64 = Memory.read_i64(node + 16)
                if mlist2 != 0:
                    mc2: i32 = nl_count(mlist2)
                    mi2: i32 = 0
                    while mi2 < mc2:
                        mnode2: i64 = nl_get(mlist2, mi2)
                        ts_walk_list(Memory.read_i64(mnode2 + 32))
                        mi2 = mi2 + 1
        i = i + 1

fun ts_process_all(ast: i64):
    changed: i32 = 1
    while changed == 1:
        changed = 0
        i: i32 = 0
        while i < g_ts_count:
            off4: i64 = (i as i64) * 4
            if Memory.read_i32(g_ts_processed + off4) == 0:
                Memory.write_i32(g_ts_processed + off4, 1)
                changed = 1
                off8: i64 = (i as i64) * 8
                name: str = Memory.read_i64(g_ts_names + off8) as str
                kind: i32 = Memory.read_i32(g_ts_kinds + off4)
                if kind == 0:
                    ts_process_function(ast, name)
                elif kind == 1:
                    ts_process_struct(ast, name)
            i = i + 1

fun run_tree_shaking(ast: i64):
    if g_tree_shake_enabled == 0:
        return
    # Mark codegen-internal calls (emitted by codegen, not visible in AST)
    ts_mark_struct("Memory")
    ts_mark_struct("Str")
    ts_mark_struct("Convert")
    ts_mark_reachable("Str_concat", 0)
    ts_mark_reachable("dsl_str_concat", 0)
    ts_mark_reachable("strcmp", 0)
    ts_mark_reachable("Memory_malloc", 0)
    ts_mark_reachable("Memory_malloc_zeroed", 0)
    ts_mark_reachable("Convert_i32_to_str", 0)
    ts_mark_reachable("Convert_i64_to_str", 0)
    ts_mark_reachable("Convert_f64_to_str", 0)
    ts_mark_reachable("Convert_bool_to_str", 0)
    ts_mark_reachable("dsl_hash_i32", 0)
    ts_mark_reachable("dsl_hash_i64", 0)
    ts_mark_reachable("dsl_hash_string", 0)
    ts_seed(ast)
    ts_process_all(ast)
    IOOps.io_println(Str.concat("[tree-shake] reachable: ", Convert.i64_to_str(g_ts_count as i64)))

fun ts_extern_block_has_reachable(node: i64) -> i32:
    if g_tree_shake_enabled == 0:
        return 1
    flist: i64 = Memory.read_i64(node + 16)
    if flist == 0:
        return 0
    fc: i32 = nl_count(flist)
    fi: i32 = 0
    while fi < fc:
        fnode: i64 = nl_get(flist, fi)
        fname: str = Memory.read_i64(fnode + 8) as str
        if ts_is_extern_fun_reachable(fname) == 1:
            return 1
        fi = fi + 1
    return 0

##############################
# MLIR Codegen Types
# Type inference, implicit casting, struct layout, field index
# Depends on: codegen_core.dlt
##############################

# ==========================================
# Type Classification Helpers
# ==========================================
fun is_int_type(t: str) -> i32:
    if str_eq(t, "i8") == 1:
        return 1
    if str_eq(t, "i16") == 1:
        return 1
    if str_eq(t, "i32") == 1:
        return 1
    if str_eq(t, "i64") == 1:
        return 1
    if str_eq(t, "i128") == 1:
        return 1
    if str_eq(t, "int") == 1:
        return 1
    if str_eq(t, "u8") == 1:
        return 1
    if str_eq(t, "u16") == 1:
        return 1
    if str_eq(t, "u32") == 1:
        return 1
    if str_eq(t, "u64") == 1:
        return 1
    if str_eq(t, "u128") == 1:
        return 1
    # Intrinsic integer types
    if str_eq(t, "__i8") == 1:
        return 1
    if str_eq(t, "__i16") == 1:
        return 1
    if str_eq(t, "__i32") == 1:
        return 1
    if str_eq(t, "__i64") == 1:
        return 1
    if str_eq(t, "__i128") == 1:
        return 1
    return 0

fun is_float_type(t: str) -> i32:
    if str_eq(t, "f32") == 1:
        return 1
    if str_eq(t, "f64") == 1:
        return 1
    if str_eq(t, "float") == 1:
        return 1
    if str_eq(t, "double") == 1:
        return 1
    # Intrinsic float types
    if str_eq(t, "__f32") == 1:
        return 1
    if str_eq(t, "__f64") == 1:
        return 1
    return 0

fun is_string_type(t: str) -> i32:
    if str_eq(t, "string") == 1:
        return 1
    if str_eq(t, "str") == 1:
        return 1
    if str_eq(t, "__str") == 1:
        return 1
    return 0

fun is_ptr_type(t: str) -> i32:
    if str_eq(t, "ptr") == 1:
        return 1
    if str_eq(t, "Pointer") == 1:
        return 1
    if str_eq(t, "!llvm.ptr") == 1:
        return 1
    if is_string_type(t) == 1:
        return 1
    if is_struct_type(t) == 1:
        return 1
    # Check for ptr[T] types (e.g. ptr[i8], ptr[i32])
    tlen: i64 = Memory.strlen(t)
    if tlen >= 5:
        if Memory.read_i8(t as i64) == 112:
            if Memory.read_i8((t as i64) + 1) == 116:
                if Memory.read_i8((t as i64) + 2) == 114:
                    if Memory.read_i8((t as i64) + 3) == 91:
                        return 1
    return 0

# ==========================================
# Integer Type Width (for widening/narrowing)
# ==========================================
fun int_type_width(t: str) -> i32:
    if str_eq(t, "i8") == 1 or str_eq(t, "u8") == 1:
        return 8
    if str_eq(t, "i16") == 1 or str_eq(t, "u16") == 1:
        return 16
    if str_eq(t, "i32") == 1 or str_eq(t, "u32") == 1 or str_eq(t, "int") == 1:
        return 32
    if str_eq(t, "i64") == 1 or str_eq(t, "u64") == 1:
        return 64
    if str_eq(t, "i128") == 1 or str_eq(t, "u128") == 1:
        return 128
    return 0

fun wider_int_type(a: str, b: str) -> str:
    wa: i32 = int_type_width(a)
    wb: i32 = int_type_width(b)
    if wa >= wb:
        return a
    return b

# ==========================================
# Implicit Cast
# ==========================================
fun implicit_cast(value: str, from_type: str, to_type: str) -> str:
    # Resolve aliases only for unknown types (not built-in i32/i64/f32/f64/str/etc.)
    if is_int_type(from_type) == 0 and is_float_type(from_type) == 0 and is_string_type(from_type) == 0 and str_eq(from_type, "bool") == 0 and str_eq(from_type, "ptr") == 0 and str_eq(from_type, "Pointer") == 0 and str_eq(from_type, "unknown") == 0 and str_eq(from_type, "null") == 0:
        from_resolved: str = resolve_alias(from_type)
        if str_eq(from_resolved, "") == 0:
            return implicit_cast(value, from_resolved, to_type)
    if is_int_type(to_type) == 0 and is_float_type(to_type) == 0 and is_string_type(to_type) == 0 and str_eq(to_type, "bool") == 0 and str_eq(to_type, "ptr") == 0 and str_eq(to_type, "Pointer") == 0 and str_eq(to_type, "unknown") == 0 and str_eq(to_type, "null") == 0:
        to_resolved: str = resolve_alias(to_type)
        if str_eq(to_resolved, "") == 0:
            return implicit_cast(value, from_type, to_resolved)

    from_m: str = mlir_type(from_type)
    to_m: str = mlir_type(to_type)

    # No cast needed
    if str_eq(from_m, to_m) == 1:
        return value
    if str_eq(from_type, "unknown") == 1:
        return value

    # Bool (i1) to integer
    if str_eq(from_m, "i1") == 1 and is_int_type(to_type) == 1:
        tmp: str = new_tmp()
        emit_ind(Str.concat(Str.concat(Str.concat(Str.concat(tmp, " = llvm.zext "), value), Str.concat(" : i1 to ", to_m)), ""))
        return tmp

    # Integer to bool (i1)
    if is_int_type(from_type) == 1 and str_eq(to_m, "i1") == 1:
        tmp2: str = new_tmp()
        emit_ind(Str.concat(Str.concat(Str.concat(Str.concat(tmp2, " = llvm.trunc "), value), Str.concat(Str.concat(" : ", from_m), Str.concat(" to ", to_m))), ""))
        return tmp2

    # Integer widening / narrowing
    fw: i32 = int_type_width(from_type)
    tw: i32 = int_type_width(to_type)
    if fw > 0 and tw > 0:
        if tw > fw:
            # Widen (sign extend)
            tmp3: str = new_tmp()
            emit_ind(Str.concat(Str.concat(Str.concat(Str.concat(tmp3, " = llvm.sext "), value), Str.concat(Str.concat(" : ", from_m), Str.concat(" to ", to_m))), ""))
            return tmp3
        elif tw < fw:
            # Narrow (truncate)
            tmp4: str = new_tmp()
            emit_ind(Str.concat(Str.concat(Str.concat(Str.concat(tmp4, " = llvm.trunc "), value), Str.concat(Str.concat(" : ", from_m), Str.concat(" to ", to_m))), ""))
            return tmp4

    # Float widening/narrowing
    if str_eq(from_m, "f32") == 1 and str_eq(to_m, "f64") == 1:
        tmp5: str = new_tmp()
        emit_ind(Str.concat(Str.concat(Str.concat(tmp5, " = llvm.fpext "), value), " : f32 to f64"))
        return tmp5
    if str_eq(from_m, "f64") == 1 and str_eq(to_m, "f32") == 1:
        tmp6: str = new_tmp()
        emit_ind(Str.concat(Str.concat(Str.concat(tmp6, " = llvm.fptrunc "), value), " : f64 to f32"))
        return tmp6

    # Int to float
    if fw > 0 and is_float_type(to_type) == 1:
        tmp7: str = new_tmp()
        emit_ind(Str.concat(Str.concat(Str.concat(Str.concat(tmp7, " = llvm.sitofp "), value), Str.concat(Str.concat(" : ", from_m), Str.concat(" to ", to_m))), ""))
        return tmp7

    # Float to int
    if is_float_type(from_type) == 1 and tw > 0:
        tmp8: str = new_tmp()
        emit_ind(Str.concat(Str.concat(Str.concat(Str.concat(tmp8, " = llvm.fptosi "), value), Str.concat(Str.concat(" : ", from_m), Str.concat(" to ", to_m))), ""))
        return tmp8

    # Pointer to i64
    if str_eq(from_m, "!llvm.ptr") == 1 and str_eq(to_m, "i64") == 1:
        tmp9: str = new_tmp()
        emit_ind(Str.concat(Str.concat(Str.concat(tmp9, " = llvm.ptrtoint "), value), " : !llvm.ptr to i64"))
        return tmp9

    # i64 to pointer
    if str_eq(from_m, "i64") == 1 and str_eq(to_m, "!llvm.ptr") == 1:
        tmp10: str = new_tmp()
        emit_ind(Str.concat(Str.concat(Str.concat(tmp10, " = llvm.inttoptr "), value), " : i64 to !llvm.ptr"))
        return tmp10

    return value

# ==========================================
# Type Inference from AST Node
# ==========================================
fun infer_expr_type(node: i64) -> str:
    if node == 0:
        return "unknown"
    ntype: i32 = nd_type(node)

    if ntype == NODE_INT_LIT:
        # Check magnitude for i32 vs i64
        val: i64 = Memory.read_i64(node + 8)
        if val > 2147483647 or val < -2147483648:
            return "i64"
        return "i32"
    if ntype == NODE_FLOAT_LIT:
        return "f64"
    if ntype == NODE_STR_LIT:
        return "string"
    if ntype == NODE_BOOL_LIT:
        return "bool"
    if ntype == NODE_CHAR_LIT:
        return "char"
    if ntype == NODE_NULL_LIT:
        return "null"
    if ntype == NODE_FSTRING or ntype == NODE_INTERP_STR:
        return "string"
    if ntype == NODE_STR_CONCAT:
        return "string"

    # Self reference returns current struct/extend type
    if ntype == NODE_SELF:
        return g_cur_method_struct

    if ntype == NODE_VAR_REF:
        vname: str = Memory.read_i64(node + 8) as str
        return get_var_type(vname)

    if ntype == NODE_BINARY_OP:
        lt: str = infer_expr_type(Memory.read_i64(node + 16))
        rt: str = infer_expr_type(Memory.read_i64(node + 24))
        if str_eq(lt, "i64") == 1 or str_eq(rt, "i64") == 1:
            return "i64"
        if is_float_type(lt) == 1 or is_float_type(rt) == 1:
            if is_float_type(lt) == 1 and is_float_type(rt) == 1:
                if str_eq(lt, "f64") == 1 or str_eq(rt, "f64") == 1:
                    return "f64"
                return "f32"
            if is_float_type(lt) == 1:
                return lt
            return rt
        if is_int_type(lt) == 1 and is_int_type(rt) == 1:
            return wider_int_type(lt, rt)
        if str_eq(lt, "unknown") == 0:
            return lt
        return rt

    if ntype == NODE_COMPARISON or ntype == NODE_LOGICAL_OP:
        return "bool"

    if ntype == NODE_IS_NULL:
        return "bool"
    if ntype == NODE_IS_NOT_NULL:
        return "bool"

    if ntype == NODE_UNARY_OP:
        return infer_expr_type(Memory.read_i64(node + 16))

    if ntype == NODE_CAST:
        return Memory.read_i64(node + 16) as str

    if ntype == NODE_PAREN:
        return infer_expr_type(Memory.read_i64(node + 8))

    if ntype == NODE_TERNARY:
        return infer_expr_type(Memory.read_i64(node + 16))

    if ntype == NODE_FUN_CALL:
        fname: str = Memory.read_i64(node + 8) as str
        return get_fun_ret_type(fname)

    if ntype == NODE_STATIC_METHOD:
        sname: str = Memory.read_i64(node + 8) as str
        mname: str = Memory.read_i64(node + 16) as str
        full: str = Str.concat(Str.concat(sname, "_"), mname)
        rt2: str = get_fun_ret_type(full)
        if str_eq(rt2, "unknown") == 1:
            full = Str.concat(Str.concat(sname, "."), mname)
            rt2 = get_fun_ret_type(full)
        return rt2

    if ntype == NODE_FIELD_ACCESS:
        fa_obj: str = Memory.read_i64(node + 8) as str
        fa_field: str = Memory.read_i64(node + 16) as str
        if is_enum_type(fa_obj) == 1:
            return "i32"
        fa_obj_type: str = get_var_type(fa_obj)
        if str_eq(fa_obj_type, "") == 0 and str_eq(fa_obj_type, "unknown") == 0:
            fa_ft: str = get_field_type(fa_obj_type, fa_field)
            if str_eq(fa_ft, "") == 0 and str_eq(fa_ft, "unknown") == 0:
                return fa_ft
        return "unknown"

    if ntype == NODE_NESTED_FIELD:
        nf_base: i64 = Memory.read_i64(node + 8)
        nf_fname: str = Memory.read_i64(node + 16) as str
        nf_base_type: str = infer_expr_type(nf_base)
        if str_eq(nf_base_type, "") == 0 and str_eq(nf_base_type, "unknown") == 0:
            nf_ft: str = get_field_type(nf_base_type, nf_fname)
            if str_eq(nf_ft, "") == 0 and str_eq(nf_ft, "unknown") == 0:
                return nf_ft
        return "unknown"

    if ntype == NODE_SELF_FIELD:
        sf_field: str = Memory.read_i64(node + 8) as str
        sf_struct: str = g_cur_method_struct
        if str_eq(sf_struct, "") == 0:
            sf_ft: str = get_field_type(sf_struct, sf_field)
            if str_eq(sf_ft, "") == 0 and str_eq(sf_ft, "unknown") == 0:
                return sf_ft
        return "unknown"

    if ntype == NODE_INST_METHOD:
        im_obj: str = Memory.read_i64(node + 8) as str
        im_mname: str = Memory.read_i64(node + 16) as str
        im_obj_type: str = ""
        if str_eq(im_obj, "self") == 1:
            im_obj_type = g_cur_method_struct
        else:
            im_obj_type = get_var_type(im_obj)
        if str_eq(im_obj_type, "") == 0 and str_eq(im_obj_type, "unknown") == 0:
            # Strip generic parameter (list[i32] -> list)
            im_base: str = im_obj_type
            imb_len: i64 = Memory.strlen(im_obj_type)
            imb_i: i64 = 0
            while imb_i < imb_len:
                if Memory.read_i8((im_obj_type as i64) + imb_i) == 91:
                    im_base = str_from_range(im_obj_type, 0 as i64, imb_i)
                    imb_i = imb_len
                imb_i = imb_i + 1
            im_mangled: str = Str.concat(Str.concat(im_base, "_"), im_mname)
            im_rt: str = get_fun_ret_type(im_mangled)
            if str_eq(im_rt, "unknown") == 0 and str_eq(im_rt, "") == 0:
                return im_rt
        return "unknown"

    if ntype == NODE_ARRAY_LIT or ntype == NODE_LIST_LIT:
        return "list"

    if ntype == NODE_MAP_LIT:
        return "ptr"

    if ntype == NODE_ENUM_ACCESS:
        return "i32"

    if ntype == NODE_STATIC_FIELD:
        sf_class: str = Memory.read_i64(node + 8) as str
        if is_enum_type(sf_class) == 1:
            return "i32"
        sf_fname: str = Memory.read_i64(node + 16) as str
        sf_full: str = Str.concat(Str.concat(sf_class, "__"), sf_fname)
        sf_looked: str = lookup_static_field_type(sf_full)
        return sf_looked

    # Builtin intrinsics (@sin, @cos, @sqrt, @pow, @fabs, etc.) return float type
    if ntype == NODE_BUILTIN_CALL:
        bi_args: i64 = Memory.read_i64(node + 16)
        if bi_args != 0:
            bi_ac: i32 = nl_count(bi_args)
            if bi_ac > 0:
                bi_arg0: i64 = nl_get(bi_args, 0)
                bi_at: str = infer_expr_type(bi_arg0)
                if str_eq(bi_at, "f32") == 1:
                    return "f32"
        return "f64"

    return "unknown"
# Struct Field Index / Size
# ==========================================
fun get_field_index(struct_name: str, field_name: str) -> i32:
    fields: i64 = get_struct_fields(struct_name)
    if fields == 0:
        return -1
    fc: i32 = nl_count(fields)
    i: i32 = 0
    while i < fc:
        fnode: i64 = nl_get(fields, i)
        fname: str = Memory.read_i64(fnode + 8) as str
        if str_eq(fname, field_name) == 1:
            return i
        i = i + 1
    return -1

fun get_field_type(struct_name: str, field_name: str) -> str:
    fields: i64 = get_struct_fields(struct_name)
    if fields == 0:
        return "unknown"
    fc: i32 = nl_count(fields)
    i: i32 = 0
    while i < fc:
        fnode: i64 = nl_get(fields, i)
        fname: str = Memory.read_i64(fnode + 8) as str
        if str_eq(fname, field_name) == 1:
            # field type is at offset 16
            return Memory.read_i64(fnode + 16) as str
        i = i + 1
    return "unknown"

# Returns access modifier for a struct field: "public", "private", or "protected"
fun get_field_access(struct_name: str, field_name: str) -> str:
    fields: i64 = get_struct_fields(struct_name)
    if fields == 0:
        return "public"
    fc: i32 = nl_count(fields)
    i: i32 = 0
    while i < fc:
        fnode: i64 = nl_get(fields, i)
        fname: str = Memory.read_i64(fnode + 8) as str
        if str_eq(fname, field_name) == 1:
            # access modifier is at offset +40
            acc_val: i64 = Memory.read_i64(fnode + 40)
            if acc_val != 0:
                acc: str = acc_val as str
                if Memory.strlen(acc) > 0:
                    return acc
            return "public"
        i = i + 1
    return "public"

fun get_type_size(t: str) -> i32:
    w: i32 = int_type_width(t)
    if w > 0:
        return w / 8
    if is_float_type(t) == 1:
        if str_eq(t, "f32") == 1 or str_eq(t, "float") == 1:
            return 4
        return 8
    if str_eq(t, "bool") == 1 or str_eq(t, "i1") == 1:
        return 1
    if str_eq(t, "char") == 1:
        return 1
    # Pointers, strings, structs: 8 bytes (64-bit)
    return 8

fun align_to(offset: i32, alignment: i32) -> i32:
    rem: i32 = offset % alignment
    if rem == 0:
        return offset
    return offset + (alignment - rem)

fun get_type_alignment(t: str) -> i32:
    sz: i32 = get_type_size(t)
    if sz > 8:
        return 8
    if sz < 1:
        return 1
    return sz

fun calculate_struct_size(struct_name: str) -> i32:
    fields: i64 = get_struct_fields(struct_name)
    if fields == 0:
        return 0
    fc: i32 = nl_count(fields)
    total: i32 = 0
    max_align: i32 = 1
    i: i32 = 0
    while i < fc:
        fnode: i64 = nl_get(fields, i)
        ftype: str = Memory.read_i64(fnode + 16) as str
        fsz: i32 = get_type_size(ftype)
        falign: i32 = get_type_alignment(ftype)
        if falign > max_align:
            max_align = falign
        total = align_to(total, falign)
        total = total + fsz
        i = i + 1
    # Pad to struct alignment
    total = align_to(total, max_align)
    return total

fun get_struct_mlir_type(struct_name: str) -> str:
    fields: i64 = get_struct_fields(struct_name)
    if fields == 0:
        return "!llvm.struct<()>"
    fc: i32 = nl_count(fields)
    result: str = "!llvm.struct<("
    i: i32 = 0
    while i < fc:
        fnode: i64 = nl_get(fields, i)
        ftype: str = Memory.read_i64(fnode + 16) as str
        if i > 0:
            result = Str.concat(result, ", ")
        result = Str.concat(result, mlir_type(ftype))
        i = i + 1
    result = Str.concat(result, ")>")
    return result

##############################
# MLIR Codegen Expressions
# Generates MLIR for all expression AST nodes
# Depends on: codegen_core.dlt, codegen_types.dlt
##############################

# ==========================================
# Main Expression Dispatch
# ==========================================
fun gen_expr(node: i64, expected: str) -> str:
    if node == 0:
        return emit_zero_ptr()

    nt: i32 = nd_type(node)

    # Integer literal
    if nt == NODE_INT_LIT:
        return gen_int_lit(node, expected)

    # Float literal
    if nt == NODE_FLOAT_LIT:
        return gen_float_lit(node, expected)

    # String literal
    if nt == NODE_STR_LIT:
        return gen_str_lit(node)

    # Bool literal
    if nt == NODE_BOOL_LIT:
        return gen_bool_lit(node)

    # Char literal
    if nt == NODE_CHAR_LIT:
        return gen_char_lit(node, expected)

    # Null literal — emit type-appropriate zero
    if nt == NODE_NULL_LIT:
        if is_int_type(expected) == 1:
            null_mt: str = mlir_type(expected)
            null_tmp: str = new_tmp()
            emit_ind(Str.concat(Str.concat(Str.concat(null_tmp, " = llvm.mlir.constant(0 : "), null_mt), Str.concat(") : ", null_mt)))
            return null_tmp
        if is_float_type(expected) == 1:
            null_mt2: str = mlir_type(expected)
            null_tmp2: str = new_tmp()
            emit_ind(Str.concat(Str.concat(Str.concat(null_tmp2, " = llvm.mlir.constant(0.0 : "), null_mt2), Str.concat(") : ", null_mt2)))
            return null_tmp2
        return emit_zero_ptr()

    # Variable reference
    if nt == NODE_VAR_REF:
        vn: str = Memory.read_i64(node + 8) as str
        return gen_var_load(vn, expected)

    # Binary operation
    if nt == NODE_BINARY_OP:
        return gen_binary_op(node, expected)

    # Comparison
    if nt == NODE_COMPARISON:
        return gen_comparison(node)

    # Logical operation
    if nt == NODE_LOGICAL_OP:
        return gen_logical_op(node)

    # Unary operation
    if nt == NODE_UNARY_OP:
        return gen_unary_op(node, expected)

    # Cast
    if nt == NODE_CAST:
        return gen_cast_expr(node, expected)

    # Parentheses
    if nt == NODE_PAREN:
        inner: i64 = Memory.read_i64(node + 8)
        return gen_expr(inner, expected)

    # Ternary
    if nt == NODE_TERNARY:
        return gen_ternary(node, expected)

    # Function call
    if nt == NODE_FUN_CALL:
        return gen_fun_call(node)

    # Static method call
    if nt == NODE_STATIC_METHOD:
        return gen_static_method_call(node)

    # Namespaced function call: ns.func(args)
    if nt == NODE_NS_FUN_CALL:
        return gen_ns_fun_call(node)

    # Namespaced static method call: ns.Struct.method(args)
    if nt == NODE_NS_STATIC_METHOD:
        return gen_ns_static_method(node)

    # Instance method call
    if nt == NODE_INST_METHOD:
        return gen_instance_method_call(node)

    # Field access
    if nt == NODE_FIELD_ACCESS:
        return gen_field_access(node)

    # Nested field access (e.g., state.Gamepad.bLeftTrigger)
    if nt == NODE_NESTED_FIELD:
        return gen_nested_field_access(node, expected)

    # Self field access
    if nt == NODE_SELF_FIELD:
        return gen_self_field_access(node)

    # Self reference
    if nt == NODE_SELF:
        return "%self"

    # Static field access
    if nt == NODE_STATIC_FIELD:
        return gen_static_field_access(node)

    # Enum access
    if nt == NODE_ENUM_ACCESS:
        return gen_enum_access(node)

    # Array access
    if nt == NODE_ARRAY_ACCESS:
        return gen_array_access(node, expected)

    # F-string
    if nt == NODE_FSTRING:
        return gen_fstring(node)

    # String concat
    if nt == NODE_STR_CONCAT:
        return gen_string_concat(node)

    # Is null
    if nt == NODE_IS_NULL:
        return gen_is_null(node)

    # Is not null
    if nt == NODE_IS_NOT_NULL:
        return gen_is_not_null(node)

    # Array/List literal — dispatch based on expected type
    if nt == NODE_ARRAY_LIT or nt == NODE_LIST_LIT:
        # Check if expected type starts with "list" → 3-field layout
        is_list_type: i32 = 0
        exp_len2: i64 = Memory.strlen(expected)
        if exp_len2 >= 4:
            if Memory.read_i8((expected as i64)) == 108:
                if Memory.read_i8((expected as i64) + 1) == 105:
                    if Memory.read_i8((expected as i64) + 2) == 115:
                        if Memory.read_i8((expected as i64) + 3) == 116:
                            is_list_type = 1
        if is_list_type == 1:
            return gen_list_literal(node, expected)
        return gen_array_literal(node, expected)

    # Map literal
    if nt == NODE_MAP_LIT:
        return gen_map_literal(node)

    # Struct instantiation
    if nt == NODE_STRUCT_INST:
        return gen_struct_instantiation(node)

    # Super method call
    if nt == NODE_SUPER_METHOD:
        return gen_super_method_call(node)

    # Match expression (used as expr)
    if nt == NODE_MATCH:
        return gen_match_expr(node, expected)

    # Builtin call
    if nt == NODE_BUILTIN_CALL:
        return gen_builtin_call(node)

    # Await
    if nt == NODE_AWAIT:
        return gen_expr(Memory.read_i64(node + 8), expected)

    # Default: zero
    return emit_zero_ptr()

# ==========================================
# Literal Generators
# ==========================================
fun gen_int_lit(node: i64, expected: str) -> str:
    val: i64 = Memory.read_i64(node + 8)
    mt: str = mlir_type(expected)
    # If expected is float, emit as float constant
    if str_eq(mt, "f32") == 1 or str_eq(mt, "f64") == 1:
        tmp: str = new_tmp()
        vs: str = Str.concat(Convert.i64_to_str(val), ".0")
        emit_ind(Str.concat(Str.concat(Str.concat(Str.concat(tmp, " = llvm.mlir.constant("), vs), Str.concat(" : ", mt)), Str.concat(") : ", mt)))
        return tmp
    # Emit as i64 only when value overflows i32 range; otherwise i32 + implicit_cast
    tmp2: str = new_tmp()
    vs2: str = Convert.i64_to_str(val)
    lit_type: str = "i32"
    if val > 2147483647 or val < (0 - 2147483648):
        lit_type = "i64"
    emit_ind(Str.concat(Str.concat(Str.concat(Str.concat(tmp2, " = llvm.mlir.constant("), vs2), Str.concat(" : ", lit_type)), Str.concat(") : ", lit_type)))
    return tmp2

fun gen_float_lit(node: i64, expected: str) -> str:
    # Float value stored as string at f0
    fstr: str = Memory.read_i64(node + 8) as str
    # Always emit as f64 — implicit_cast handles narrowing to f32
    tmp: str = new_tmp()
    emit_ind(Str.concat(Str.concat(Str.concat(Str.concat(tmp, " = llvm.mlir.constant("), fstr), " : f64"), ") : f64"))
    return tmp

fun gen_str_lit(node: i64) -> str:
    text: str = Memory.read_i64(node + 8) as str
    label: str = gen_string_const(text)
    slen: i32 = get_str_len(label)
    addr: str = new_tmp()
    emit_ind(Str.concat(Str.concat(Str.concat(addr, " = llvm.mlir.addressof "), label), " : !llvm.ptr"))
    return addr

fun gen_bool_lit(node: i64) -> str:
    v: i64 = Memory.read_i64(node + 8)
    if v != 0:
        return emit_const_i1(1)
    return emit_const_i1(0)

fun gen_char_lit(node: i64, expected: str) -> str:
    ch: str = Memory.read_i64(node + 8) as str
    # Get first character ASCII value
    c: i8 = Memory.read_i8(ch as i64)
    if str_eq(expected, "string") == 1 or str_eq(expected, "str") == 1:
        label: str = gen_string_const(ch)
        addr: str = new_tmp()
        emit_ind(Str.concat(Str.concat(Str.concat(addr, " = llvm.mlir.addressof "), label), " : !llvm.ptr"))
        return addr
    # Emit as i8 constant
    tmp: str = new_tmp()
    emit_ind(Str.concat(Str.concat(Str.concat(tmp, " = llvm.mlir.constant("), Convert.i64_to_str(c as i64)), " : i8) : i8"))
    return tmp

# ==========================================
# Variable Load
# ==========================================
fun gen_var_load(name: str, expected: str) -> str:
    mn: str = get_mlir_name(name)
    if str_eq(mn, "") == 1:
        # Fallback: check if it's a function name (for function pointers)
        frt: str = get_fun_ret_type(name)
        if str_eq(frt, "unknown") == 0:
            # Emit addressof for the function and convert to i64 immediately
            tmp: str = new_tmp()
            emit_ind(Str.concat(Str.concat(Str.concat(tmp, " = llvm.mlir.addressof @"), name), " : !llvm.ptr"))
            # Always convert function pointers to i64
            tmp2: str = new_tmp()
            emit_ind(Str.concat(Str.concat(Str.concat(tmp2, " = llvm.ptrtoint "), tmp), " : !llvm.ptr to i64"))
            return tmp2
        panic(Str.concat("Variable not declared: ", name))

    vt: str = get_var_type(name)
    mt: str = mlir_type(vt)

    # Function parameters are direct SSA values
    if is_param_var(name) == 1:
        return Str.concat("%", mn)

    # Check if a local variable shadows a global with the same name
    # When inside a function, local vars should take precedence over globals
    if is_global_var(name) == 1:
        # Check if the most recent registration of this variable is NOT a param
        # and was registered after function entry (i.e. it's a local shadow)
        is_local: i32 = 0
        if g_in_function == 1:
            # The most recent match in var_names is what get_mlir_name found
            # Check if it was added as NOT a param (is_param == 0 means local alloca)
            # Scan backwards to find the most recent var with this name
            vi: i32 = g_var_count - 1
            while vi >= 0:
                voff: i64 = (vi as i64) * 8
                vn: str = Memory.read_i64(g_var_names + voff) as str
                if str_eq(vn, name) == 1:
                    vpoff: i64 = (vi as i64) * 4
                    vp: i32 = Memory.read_i32(g_var_is_param + vpoff)
                    if vp == 0:
                        is_local = 1
                    vi = -1
                vi = vi - 1
        if is_local == 0:
            ga: str = emit_addr_of(mn)
            tmp: str = emit_load(ga, mt)
            return tmp

    # Local variables: load from alloca
    tmp2: str = emit_load(Str.concat("%", mn), mt)
    return tmp2

# ==========================================
# Binary Operation
# ==========================================
fun gen_binary_op(node: i64, expected: str) -> str:
    op_str: str = Memory.read_i64(node + 8) as str
    left_node: i64 = Memory.read_i64(node + 16)
    right_node: i64 = Memory.read_i64(node + 24)

    # Infer result type
    lt: str = infer_expr_type(left_node)
    rt: str = infer_expr_type(right_node)

    # String concatenation: str + str => Str_concat
    if str_eq(op_str, "+") == 1:
        if is_string_type(lt) == 1 or is_string_type(rt) == 1:
            lv: str = gen_expr(left_node, "string")
            rv: str = gen_expr(right_node, "string")
            return emit_call("Str_concat", Str.concat(Str.concat(lv, ", "), rv), "!llvm.ptr, !llvm.ptr", "!llvm.ptr")

    result_type: str = "i32"
    if str_eq(lt, "i64") == 1 or str_eq(rt, "i64") == 1:
        result_type = "i64"
    elif is_float_type(lt) == 1 or is_float_type(rt) == 1:
        if str_eq(lt, "f64") == 1 or str_eq(rt, "f64") == 1:
            result_type = "f64"
        else:
            result_type = "f32"
    elif is_int_type(lt) == 1 and is_int_type(rt) == 1:
        result_type = wider_int_type(lt, rt)
    elif str_eq(lt, "unknown") == 0:
        result_type = lt
    elif str_eq(rt, "unknown") == 0:
        result_type = rt

    # Generate operands
    lv: str = gen_expr(left_node, result_type)
    rv: str = gen_expr(right_node, result_type)

    # Cast if needed
    if str_eq(lt, "unknown") == 0 and str_eq(lt, result_type) == 0:
        lv = implicit_cast(lv, lt, result_type)
    if str_eq(rt, "unknown") == 0 and str_eq(rt, result_type) == 0:
        rv = implicit_cast(rv, rt, result_type)

    mt: str = mlir_type(result_type)
    is_f: i32 = is_float_type(result_type)

    # Determine MLIR op
    mlir_op: str = ""
    if str_eq(op_str, "+") == 1:
        if is_f == 1:
            mlir_op = "llvm.fadd"
        else:
            mlir_op = "llvm.add"
    elif str_eq(op_str, "-") == 1:
        if is_f == 1:
            mlir_op = "llvm.fsub"
        else:
            mlir_op = "llvm.sub"
    elif str_eq(op_str, "*") == 1:
        if is_f == 1:
            mlir_op = "llvm.fmul"
        else:
            mlir_op = "llvm.mul"
    elif str_eq(op_str, "/") == 1:
        if is_f == 1:
            mlir_op = "llvm.fdiv"
        else:
            mlir_op = "llvm.sdiv"
    elif str_eq(op_str, "%") == 1:
        if is_f == 1:
            mlir_op = "llvm.frem"
        else:
            mlir_op = "llvm.srem"
    elif str_eq(op_str, "&") == 1:
        mlir_op = "llvm.and"
    elif str_eq(op_str, "|") == 1:
        mlir_op = "llvm.or"
    elif str_eq(op_str, "^") == 1:
        mlir_op = "llvm.xor"
    elif str_eq(op_str, "<<") == 1:
        mlir_op = "llvm.shl"
    elif str_eq(op_str, ">>") == 1:
        mlir_op = "llvm.ashr"
    else:
        mlir_op = "llvm.add"

    result: str = new_tmp()
    emit_ind(Str.concat(Str.concat(Str.concat(Str.concat(Str.concat(result, " = "), mlir_op), Str.concat(" ", lv)), Str.concat(", ", rv)), Str.concat(" : ", mt)))
    return result

# ==========================================
# Comparison
# ==========================================
fun gen_comparison(node: i64) -> str:
    op_str: str = Memory.read_i64(node + 8) as str
    left_node: i64 = Memory.read_i64(node + 16)
    right_node: i64 = Memory.read_i64(node + 24)

    lt: str = infer_expr_type(left_node)
    rt: str = infer_expr_type(right_node)

    # String comparison: use strcmp
    if is_string_type(lt) == 1 or is_string_type(rt) == 1:
        lv: str = gen_expr(left_node, "string")
        rv: str = gen_expr(right_node, "string")
        cmp_res: str = emit_call("strcmp", Str.concat(Str.concat(lv, ", "), rv), "!llvm.ptr, !llvm.ptr", "i32")
        c0: str = emit_const_i32(0)
        result: str = new_tmp()
        pred: str = "eq"
        if str_eq(op_str, "!=") == 1:
            pred = "ne"
        elif str_eq(op_str, "<") == 1:
            pred = "slt"
        elif str_eq(op_str, ">") == 1:
            pred = "sgt"
        elif str_eq(op_str, "<=") == 1:
            pred = "sle"
        elif str_eq(op_str, ">=") == 1:
            pred = "sge"
        emit_ind(Str.concat(Str.concat(Str.concat(Str.concat(Str.concat(result, " = llvm.icmp \""), pred), Str.concat("\" ", cmp_res)), Str.concat(", ", c0)), " : i32"))
        return result

    # Determine operand type for comparison
    cmp_type: str = "i32"
    if str_eq(lt, "i64") == 1 or str_eq(rt, "i64") == 1:
        cmp_type = "i64"
    elif is_float_type(lt) == 1 or is_float_type(rt) == 1:
        if str_eq(lt, "f64") == 1 or str_eq(rt, "f64") == 1:
            cmp_type = "f64"
        else:
            cmp_type = "f32"
    elif is_int_type(lt) == 1 and is_int_type(rt) == 1:
        cmp_type = wider_int_type(lt, rt)

    lv2: str = gen_expr(left_node, cmp_type)
    rv2: str = gen_expr(right_node, cmp_type)

    # Cast if needed
    if str_eq(lt, "unknown") == 0 and str_eq(lt, cmp_type) == 0:
        lv2 = implicit_cast(lv2, lt, cmp_type)
    if str_eq(rt, "unknown") == 0 and str_eq(rt, cmp_type) == 0:
        rv2 = implicit_cast(rv2, rt, cmp_type)

    mt: str = mlir_type(cmp_type)
    is_f: i32 = is_float_type(cmp_type)

    # Determine predicate
    pred2: str = ""
    if is_f == 1:
        if str_eq(op_str, "==") == 1:
            pred2 = "oeq"
        elif str_eq(op_str, "!=") == 1:
            pred2 = "one"
        elif str_eq(op_str, "<") == 1:
            pred2 = "olt"
        elif str_eq(op_str, ">") == 1:
            pred2 = "ogt"
        elif str_eq(op_str, "<=") == 1:
            pred2 = "ole"
        elif str_eq(op_str, ">=") == 1:
            pred2 = "oge"
        else:
            pred2 = "oeq"
    else:
        if str_eq(op_str, "==") == 1:
            pred2 = "eq"
        elif str_eq(op_str, "!=") == 1:
            pred2 = "ne"
        elif str_eq(op_str, "<") == 1:
            pred2 = "slt"
        elif str_eq(op_str, ">") == 1:
            pred2 = "sgt"
        elif str_eq(op_str, "<=") == 1:
            pred2 = "sle"
        elif str_eq(op_str, ">=") == 1:
            pred2 = "sge"
        else:
            pred2 = "eq"

    result2: str = new_tmp()
    cmp_inst: str = "llvm.icmp"
    if is_f == 1:
        cmp_inst = "llvm.fcmp"
    emit_ind(Str.concat(Str.concat(Str.concat(Str.concat(Str.concat(result2, " = "), cmp_inst), Str.concat(Str.concat(" \"", pred2), "\"")), Str.concat(Str.concat(" ", lv2), Str.concat(", ", rv2))), Str.concat(" : ", mt)))
    return result2

# ==========================================
# Logical Operation (and/or/not)
# ==========================================
fun gen_logical_op(node: i64) -> str:
    op_str: str = Memory.read_i64(node + 8) as str
    left_node: i64 = Memory.read_i64(node + 16)
    right_node: i64 = Memory.read_i64(node + 24)

    if str_eq(op_str, "not") == 1:
        # Unary not
        val: str = gen_expr(left_node, "bool")
        lt: str = infer_expr_type(left_node)
        if str_eq(lt, "bool") == 0 and str_eq(lt, "i1") == 0:
            # Convert to bool first
            c0: str = emit_const_i32(0)
            val = new_tmp()
            emit_ind(Str.concat(Str.concat(Str.concat(val, " = llvm.icmp \"ne\" "), val), ", " ))
        one: str = emit_const_i1(1)
        result: str = new_tmp()
        emit_ind(Str.concat(Str.concat(Str.concat(Str.concat(result, " = llvm.xor "), val), Str.concat(", ", one)), " : i1"))
        return result

    lv: str = gen_expr(left_node, "bool")
    rv: str = gen_expr(right_node, "bool")

    result2: str = new_tmp()
    if str_eq(op_str, "and") == 1:
        emit_ind(Str.concat(Str.concat(Str.concat(Str.concat(result2, " = llvm.and "), lv), Str.concat(", ", rv)), " : i1"))
    else:
        emit_ind(Str.concat(Str.concat(Str.concat(Str.concat(result2, " = llvm.or "), lv), Str.concat(", ", rv)), " : i1"))
    return result2

# ==========================================
# Unary Operation
# ==========================================
fun gen_unary_op(node: i64, expected: str) -> str:
    op_str: str = Memory.read_i64(node + 8) as str
    operand: i64 = Memory.read_i64(node + 16)
    val: str = gen_expr(operand, expected)
    ot: str = infer_expr_type(operand)
    mt: str = mlir_type(ot)

    if str_eq(op_str, "-") == 1:
        result: str = new_tmp()
        if is_float_type(ot) == 1:
            emit_ind(Str.concat(Str.concat(Str.concat(Str.concat(result, " = llvm.fneg "), val), " : "), mt))
        else:
            zero: str = new_tmp()
            emit_ind(Str.concat(Str.concat(Str.concat(zero, " = llvm.mlir.constant(0 : "), mt), Str.concat(") : ", mt)))
            emit_ind(Str.concat(Str.concat(Str.concat(Str.concat(Str.concat(result, " = llvm.sub "), zero), Str.concat(", ", val)), " : "), mt))
        return result

    if str_eq(op_str, "~") == 1:
        neg1: str = new_tmp()
        emit_ind(Str.concat(Str.concat(Str.concat(neg1, " = llvm.mlir.constant(-1 : "), mt), Str.concat(") : ", mt)))
        result2: str = new_tmp()
        emit_ind(Str.concat(Str.concat(Str.concat(Str.concat(Str.concat(result2, " = llvm.xor "), val), Str.concat(", ", neg1)), " : "), mt))
        return result2

    if str_eq(op_str, "not") == 1:
        one: str = emit_const_i1(1)
        result3: str = new_tmp()
        emit_ind(Str.concat(Str.concat(Str.concat(Str.concat(result3, " = llvm.xor "), val), Str.concat(", ", one)), " : i1"))
        return result3

    return val

# ==========================================
# Cast Expression
# ==========================================
fun gen_cast_expr(node: i64, expected: str) -> str:
    expr_node: i64 = Memory.read_i64(node + 8)
    target_type: str = Memory.read_i64(node + 16) as str
    from_type: str = infer_expr_type(expr_node)
    val: str = gen_expr(expr_node, from_type)
    return implicit_cast(val, from_type, target_type)

# ==========================================
# Ternary Expression (cond ? then : else)
# ==========================================
fun gen_ternary(node: i64, expected: str) -> str:
    cond_node: i64 = Memory.read_i64(node + 8)
    then_node: i64 = Memory.read_i64(node + 16)
    else_node: i64 = Memory.read_i64(node + 24)

    cond_val: str = gen_expr(cond_node, "bool")
    then_val: str = gen_expr(then_node, expected)
    else_val: str = gen_expr(else_node, expected)

    mt: str = mlir_type(expected)
    result: str = new_tmp()
    emit_ind(Str.concat(Str.concat(Str.concat(Str.concat(Str.concat(Str.concat(result, " = llvm.select "), cond_val), Str.concat(", ", then_val)), Str.concat(", ", else_val)), " : i1, "), mt))
    return result

# ==========================================
# Enum Access (Direction.UP -> i32 constant)
# ==========================================
fun gen_enum_access(node: i64) -> str:
    ename: str = Memory.read_i64(node + 8) as str
    vname: str = Memory.read_i64(node + 16) as str
    idx: i32 = get_enum_value_index(ename, vname)
    if idx < 0:
        panic(Str.concat(Str.concat(Str.concat("Unknown enum value: ", ename), "."), vname))
    return emit_const_i32(idx)

# ==========================================
# Is Null / Is Not Null
# ==========================================
fun gen_is_null(node: i64) -> str:
    expr_node: i64 = Memory.read_i64(node + 8)
    et: str = infer_expr_type(expr_node)
    val: str = gen_expr(expr_node, et)
    em: str = mlir_type(et)
    # Integer types: compare to 0
    if is_int_type(et) == 1:
        zero_val: str = new_tmp()
        emit_ind(Str.concat(Str.concat(Str.concat(zero_val, " = llvm.mlir.constant(0 : "), em), Str.concat(") : ", em)))
        result: str = new_tmp()
        emit_ind(Str.concat(Str.concat(Str.concat(Str.concat(result, " = llvm.icmp \"eq\" "), val), Str.concat(", ", zero_val)), Str.concat(" : ", em)))
        return result
    # Pointer/string/struct types: compare to null pointer
    if str_eq(em, "!llvm.ptr") == 0:
        val = implicit_cast(val, et, "ptr")
    null_val: str = emit_zero_ptr()
    result2: str = new_tmp()
    emit_ind(Str.concat(Str.concat(Str.concat(Str.concat(result2, " = llvm.icmp \"eq\" "), val), Str.concat(", ", null_val)), " : !llvm.ptr"))
    return result2

fun gen_is_not_null(node: i64) -> str:
    expr_node: i64 = Memory.read_i64(node + 8)
    et: str = infer_expr_type(expr_node)
    val: str = gen_expr(expr_node, et)
    em: str = mlir_type(et)
    # Integer types: compare to 0
    if is_int_type(et) == 1:
        zero_val: str = new_tmp()
        emit_ind(Str.concat(Str.concat(Str.concat(zero_val, " = llvm.mlir.constant(0 : "), em), Str.concat(") : ", em)))
        result: str = new_tmp()
        emit_ind(Str.concat(Str.concat(Str.concat(Str.concat(result, " = llvm.icmp \"ne\" "), val), Str.concat(", ", zero_val)), Str.concat(" : ", em)))
        return result
    # Pointer/string/struct types: compare to null pointer
    if str_eq(em, "!llvm.ptr") == 0:
        val = implicit_cast(val, et, "ptr")
    null_val: str = emit_zero_ptr()
    result2: str = new_tmp()
    emit_ind(Str.concat(Str.concat(Str.concat(Str.concat(result2, " = llvm.icmp \"ne\" "), val), Str.concat(", ", null_val)), " : !llvm.ptr"))
    return result2

# ==========================================
# String Concat
# ==========================================
fun gen_string_concat(node: i64) -> str:
    left_node: i64 = Memory.read_i64(node + 8)
    right_node: i64 = Memory.read_i64(node + 16)
    lv: str = gen_expr(left_node, "string")
    rv: str = gen_expr(right_node, "string")
    return emit_call("dsl_str_concat", Str.concat(Str.concat(lv, ", "), rv), "!llvm.ptr, !llvm.ptr", "!llvm.ptr")

# ==========================================
# F-String — generate parts with type-aware string conversion
# ==========================================
fun gen_fstring_part(node: i64) -> str:
    nt: i32 = nd_type(node)
    # String literal — generate as string constant
    if nt == NODE_STR_LIT:
        return gen_str_lit(node)
    # For expressions, infer type and convert to string
    et: str = infer_expr_type(node)
    val: str = gen_expr(node, et)
    # If already string, return as-is
    if is_string_type(et) == 1:
        return val
    # i32/int -> Convert_i32_to_str
    if str_eq(et, "i32") == 1 or str_eq(et, "int") == 1:
        return emit_call("Convert_i32_to_str", val, "i32", "!llvm.ptr")
    # i64 -> Convert_i64_to_str
    if str_eq(et, "i64") == 1:
        return emit_call("Convert_i64_to_str", val, "i64", "!llvm.ptr")
    # i8 -> sext to i32, then Convert_i32_to_str
    if str_eq(et, "i8") == 1:
        ext: str = new_tmp()
        emit_ind(Str.concat(Str.concat(Str.concat(ext, " = llvm.sext "), val), " : i8 to i32"))
        return emit_call("Convert_i32_to_str", ext, "i32", "!llvm.ptr")
    # i16 -> sext to i32, then Convert_i32_to_str
    if str_eq(et, "i16") == 1:
        ext2: str = new_tmp()
        emit_ind(Str.concat(Str.concat(Str.concat(ext2, " = llvm.sext "), val), " : i16 to i32"))
        return emit_call("Convert_i32_to_str", ext2, "i32", "!llvm.ptr")
    # u8 -> zext to i32
    if str_eq(et, "u8") == 1:
        ext3: str = new_tmp()
        emit_ind(Str.concat(Str.concat(Str.concat(ext3, " = llvm.zext "), val), " : i8 to i32"))
        return emit_call("Convert_i32_to_str", ext3, "i32", "!llvm.ptr")
    # u16 -> zext to i32
    if str_eq(et, "u16") == 1:
        ext4: str = new_tmp()
        emit_ind(Str.concat(Str.concat(Str.concat(ext4, " = llvm.zext "), val), " : i16 to i32"))
        return emit_call("Convert_i32_to_str", ext4, "i32", "!llvm.ptr")
    # u32 -> Convert_i32_to_str
    if str_eq(et, "u32") == 1:
        return emit_call("Convert_i32_to_str", val, "i32", "!llvm.ptr")
    # u64 -> Convert_i64_to_str
    if str_eq(et, "u64") == 1:
        return emit_call("Convert_i64_to_str", val, "i64", "!llvm.ptr")
    # f64 -> Convert_f64_to_str
    if str_eq(et, "f64") == 1:
        return emit_call("Convert_f64_to_str", val, "f64", "!llvm.ptr")
    # f32 -> fpext to f64, then Convert_f64_to_str
    if str_eq(et, "f32") == 1:
        ext5: str = new_tmp()
        emit_ind(Str.concat(Str.concat(Str.concat(ext5, " = llvm.fpext "), val), " : f32 to f64"))
        return emit_call("Convert_f64_to_str", ext5, "f64", "!llvm.ptr")
    # i128 -> trunc to i64, then Convert_i64_to_str
    if str_eq(et, "i128") == 1:
        ext6: str = new_tmp()
        emit_ind(Str.concat(Str.concat(Str.concat(ext6, " = llvm.trunc "), val), " : i128 to i64"))
        return emit_call("Convert_i64_to_str", ext6, "i64", "!llvm.ptr")
    # u128 -> trunc to i64, then Convert_i64_to_str
    if str_eq(et, "u128") == 1:
        ext7: str = new_tmp()
        emit_ind(Str.concat(Str.concat(Str.concat(ext7, " = llvm.trunc "), val), " : i128 to i64"))
        return emit_call("Convert_i64_to_str", ext7, "i64", "!llvm.ptr")
    # char -> zext to i32, then Convert_i32_to_str
    if str_eq(et, "char") == 1:
        ext8: str = new_tmp()
        emit_ind(Str.concat(Str.concat(Str.concat(ext8, " = llvm.zext "), val), " : i8 to i32"))
        return emit_call("Convert_i32_to_str", ext8, "i32", "!llvm.ptr")
    # bool -> Convert_bool_to_str
    if str_eq(et, "bool") == 1:
        return emit_call("Convert_bool_to_str", val, "i1", "!llvm.ptr")
    # Default: treat as pointer (string)
    return val

fun gen_fstring(node: i64) -> str:
    parts: i64 = Memory.read_i64(node + 8)
    if parts == 0:
        return gen_str_lit(node)
    pc: i32 = nl_count(parts)
    if pc == 0:
        label: str = gen_string_const("")
        return emit_addr_of(Str.concat("", label))
    result: str = gen_fstring_part(nl_get(parts, 0))
    i: i32 = 1
    while i < pc:
        part: str = gen_fstring_part(nl_get(parts, i))
        result = emit_call("Str_concat", Str.concat(Str.concat(result, ", "), part), "!llvm.ptr, !llvm.ptr", "!llvm.ptr")
        i = i + 1
    return result

# ==========================================
# Array/List Literal
# ==========================================

# Helper: extract element type from expected type annotation
fun extract_elem_type(expected: str, elems: i64, ec: i32) -> str:
    elem_type: str = "i32"
    exp_len: i64 = Memory.strlen(expected)
    exp_found: i32 = 0
    exp_i: i64 = 0
    while exp_i < exp_len:
        exp_c: i8 = Memory.read_i8((expected as i64) + exp_i)
        if exp_c == 91:
            elem_type = str_from_range(expected, exp_i + 1, exp_len - 1)
            exp_found = 1
            exp_i = exp_len
        exp_i = exp_i + 1
    # Fallback: infer from first element
    if exp_found == 0 and ec > 0:
        elem_type = infer_expr_type(nl_get(elems, 0))
    return elem_type

# Helper: calculate element slot size
fun calc_elem_slot(elem_type: str) -> i64:
    s: i64 = get_type_size(elem_type) as i64
    if s < 8:
        s = 8
    return s

# ------------------------------------------
# List Literal: 3-field layout
# [size:i32 | cap:i32 | data_ptr:i64]
# Supports dynamic resize via library methods
# ------------------------------------------
fun gen_list_literal(node: i64, expected: str) -> str:
    elems: i64 = Memory.read_i64(node + 8)
    ec: i32 = 0
    if elems != 0:
        ec = nl_count(elems)

    elem_type: str = extract_elem_type(expected, elems, ec)
    elem_slot: i64 = calc_elem_slot(elem_type)
    mt: str = mlir_type(elem_type)

    # Allocate header (16 bytes)
    c16h: str = emit_const_i64(16)
    header_p: str = emit_call("Memory_malloc", c16h, "i64", "!llvm.ptr")

    # Allocate data array
    init_cap: i32 = ec
    if init_cap < 4:
        init_cap = 4
    data_sz: str = emit_const_i64((init_cap as i64) * elem_slot)
    data_p: str = emit_call("Memory_malloc", data_sz, "i64", "!llvm.ptr")

    # Write size at +0
    size_val: str = emit_const_i32(ec)
    emit_store(size_val, header_p, "i32")

    # Write capacity at +4
    cap_val: str = emit_const_i32(init_cap)
    cap_ptr: str = new_tmp()
    c4off: str = emit_const_i64(4)
    emit_ind(Str.concat(Str.concat(Str.concat(Str.concat(cap_ptr, " = llvm.getelementptr "), header_p), Str.concat("[", Str.concat(c4off, "]"))), " : (!llvm.ptr, i64) -> !llvm.ptr, i8"))
    emit_store(cap_val, cap_ptr, "i32")

    # Write data_ptr at +8
    dp_ptr: str = new_tmp()
    c8off: str = emit_const_i64(8)
    emit_ind(Str.concat(Str.concat(Str.concat(Str.concat(dp_ptr, " = llvm.getelementptr "), header_p), Str.concat("[", Str.concat(c8off, "]"))), " : (!llvm.ptr, i64) -> !llvm.ptr, i8"))
    emit_store(data_p, dp_ptr, "!llvm.ptr")

    # Store elements into data array
    i: i32 = 0
    while i < ec:
        e_node: i64 = nl_get(elems, i)
        eval: str = gen_expr(e_node, elem_type)
        inf_type: str = infer_expr_type(e_node)
        if str_eq(inf_type, elem_type) == 0 and str_eq(inf_type, "unknown") == 0:
            eval = implicit_cast(eval, inf_type, elem_type)
        offset: i64 = (i as i64) * elem_slot
        off_s: str = emit_const_i64(offset)
        ep: str = new_tmp()
        emit_ind(Str.concat(Str.concat(Str.concat(Str.concat(ep, " = llvm.getelementptr "), data_p), Str.concat("[", Str.concat(off_s, "]"))), " : (!llvm.ptr, i64) -> !llvm.ptr, i8"))
        emit_store(eval, ep, mt)
        i = i + 1

    return header_p

# ------------------------------------------
# Array Literal: inline layout (max performance)
# [size:i32 | elem0 | elem1 | ...]
# Fixed-size, zero pointer indirection
# ------------------------------------------
fun gen_array_literal(node: i64, expected: str) -> str:
    elems: i64 = Memory.read_i64(node + 8)
    ec: i32 = 0
    if elems != 0:
        ec = nl_count(elems)

    elem_type: str = extract_elem_type(expected, elems, ec)
    elem_slot: i64 = calc_elem_slot(elem_type)
    mt: str = mlir_type(elem_type)

    # Allocate: size(4 bytes) + elements inline
    total: i64 = 4 + ((ec as i64) * elem_slot)
    sz: str = emit_const_i64(total)
    mem_p: str = emit_call("Memory_malloc", sz, "i64", "!llvm.ptr")

    # Write size at +0
    size_val: str = emit_const_i32(ec)
    emit_store(size_val, mem_p, "i32")

    # Store elements inline at +4
    i: i32 = 0
    while i < ec:
        e_node: i64 = nl_get(elems, i)
        eval: str = gen_expr(e_node, elem_type)
        inf_type: str = infer_expr_type(e_node)
        if str_eq(inf_type, elem_type) == 0 and str_eq(inf_type, "unknown") == 0:
            eval = implicit_cast(eval, inf_type, elem_type)
        offset: i64 = 4 + ((i as i64) * elem_slot)
        off_s: str = emit_const_i64(offset)
        ep: str = new_tmp()
        emit_ind(Str.concat(Str.concat(Str.concat(Str.concat(ep, " = llvm.getelementptr "), mem_p), Str.concat("[", Str.concat(off_s, "]"))), " : (!llvm.ptr, i64) -> !llvm.ptr, i8"))
        emit_store(eval, ep, mt)
        i = i + 1

    return mem_p

# ==========================================
# Map Literal
# ==========================================
fun gen_map_literal(node: i64) -> str:
    entries: i64 = Memory.read_i64(node + 8)
    ec: i32 = 0
    if entries != 0:
        ec = nl_count(entries)

    # Allocate hash map (simplified: linear array of key-value pairs)
    # Header: 16 bytes (size + capacity), then entries of (key_ptr + value_ptr) = 16 bytes each
    total: i64 = 16 + ((ec as i64) * 16)
    sz: str = emit_const_i64(total)
    mem_p: str = emit_call("Memory_malloc", sz, "i64", "!llvm.ptr")

    # Store size
    size_val: str = emit_const_i32(ec)
    emit_store(size_val, mem_p, "i32")

    # Store capacity at +4
    map_cap_val: str = emit_const_i32(ec)
    map_cap_ptr: str = new_tmp()
    map_c4off: str = emit_const_i64(4)
    emit_ind(Str.concat(Str.concat(Str.concat(Str.concat(map_cap_ptr, " = llvm.getelementptr "), mem_p), Str.concat("[", Str.concat(map_c4off, "]"))), " : (!llvm.ptr, i64) -> !llvm.ptr, i8"))
    emit_store(map_cap_val, map_cap_ptr, "i32")

    # Store entries
    i: i32 = 0
    while i < ec:
        entry: i64 = nl_get(entries, i)
        key_node: i64 = Memory.read_i64(entry + 8)
        val_node: i64 = Memory.read_i64(entry + 16)

        kv: str = gen_expr(key_node, "string")
        vt: str = infer_expr_type(val_node)
        if str_eq(vt, "unknown") == 1:
            vt = "i64"
        vmt: str = mlir_type(vt)
        vv: str = gen_expr(val_node, vt)
        # Cast value to i64 for uniform storage
        if str_eq(vt, "i64") == 0:
            vv = implicit_cast(vv, vt, "i64")

        offset: i64 = 16 + ((i as i64) * 16)
        ko: str = emit_const_i64(offset)
        kp: str = new_tmp()
        emit_ind(Str.concat(Str.concat(Str.concat(Str.concat(kp, " = llvm.getelementptr "), mem_p), Str.concat("[", Str.concat(ko, "]"))), " : (!llvm.ptr, i64) -> !llvm.ptr, i8"))
        emit_store(kv, kp, "!llvm.ptr")

        vo: str = emit_const_i64(offset + 8)
        vp: str = new_tmp()
        emit_ind(Str.concat(Str.concat(Str.concat(Str.concat(vp, " = llvm.getelementptr "), mem_p), Str.concat("[", Str.concat(vo, "]"))), " : (!llvm.ptr, i64) -> !llvm.ptr, i8"))
        emit_store(vv, vp, "i64")

        i = i + 1

    return mem_p

# ==========================================
# Struct Instantiation
# ==========================================
fun gen_struct_instantiation(node: i64) -> str:
    sname: str = Memory.read_i64(node + 8) as str
    field_vals: i64 = Memory.read_i64(node + 16)

    ssize: i32 = calculate_struct_size(sname)
    mem_p: str = ""
    if is_heap_struct(sname) == 1:
        # @heap annotation — allocate on the heap
        sz: str = emit_const_i64(ssize as i64)
        mem_p = emit_call("Memory_malloc", sz, "i64", "!llvm.ptr")
    else:
        # default (@stack or unmarked) — allocate on the stack
        struct_mtype: str = get_struct_mlir_type(sname)
        mem_p = emit_alloca(struct_mtype)

    # Count passed field_vals
    fvc: i32 = 0
    if field_vals != 0:
        fvc = nl_count(field_vals)

    # Initialize explicitly-passed fields
    i: i32 = 0
    while i < fvc:
        fv_node: i64 = nl_get(field_vals, i)
        fname: str = ""
        fval_node: i64 = 0
        # Check if named arg (NODE_FIELD_VAL) or positional arg (raw expr)
        if nd_type(fv_node) == NODE_FIELD_VAL:
            fname = Memory.read_i64(fv_node + 8) as str
            fval_node = Memory.read_i64(fv_node + 16)
        else:
            # Positional arg — map by field order
            pos_fields: i64 = get_struct_fields(sname)
            if pos_fields != 0 and i < nl_count(pos_fields):
                pos_fnode: i64 = nl_get(pos_fields, i)
                fname = Memory.read_i64(pos_fnode + 8) as str
            fval_node = fv_node
        fidx: i32 = get_field_index(sname, fname)
        if fidx >= 0:
            ftype: str = get_field_type(sname, fname)
            fval: str = gen_expr(fval_node, ftype)
            # Implicit cast if expression type differs from field type
            actual_type: str = infer_expr_type(fval_node)
            if str_eq(actual_type, ftype) == 0 and str_eq(actual_type, "unknown") == 0:
                fval = implicit_cast(fval, actual_type, ftype)
            mt: str = mlir_type(ftype)
            # GEP to field offset
            struct_mlir: str = get_struct_mlir_type(sname)
            fp: str = new_tmp()
            emit_ind(Str.concat(Str.concat(Str.concat(fp, " = llvm.getelementptr "), mem_p), Str.concat(Str.concat("[0, ", Str.concat(Convert.i64_to_str(fidx as i64), "]")), Str.concat(" : (!llvm.ptr) -> !llvm.ptr, ", struct_mlir))))
            emit_store(fval, fp, mt)
        i = i + 1

    # Initialize un-passed fields with default values or zero
    all_fields: i64 = get_struct_fields(sname)
    if all_fields != 0:
        afc: i32 = nl_count(all_fields)
        di: i32 = 0
        while di < afc:
            dfnode: i64 = nl_get(all_fields, di)
            dfname: str = Memory.read_i64(dfnode + 8) as str
            # Check if this field was already set by scanning field_vals
            was_set: i32 = 0
            j: i32 = 0
            while j < fvc:
                fv2: i64 = nl_get(field_vals, j)
                if nd_type(fv2) == NODE_FIELD_VAL:
                    fv2_name: str = Memory.read_i64(fv2 + 8) as str
                    if str_eq(fv2_name, dfname) == 1:
                        was_set = 1
                else:
                    # Positional arg at index j maps to field at index j
                    if j == di:
                        was_set = 1
                j = j + 1
            if was_set == 0:
                dftype: str = Memory.read_i64(dfnode + 16) as str
                dft_mlir: str = mlir_type(dftype)
                struct_mlir2: str = get_struct_mlir_type(sname)
                dfp: str = new_tmp()
                emit_ind(Str.concat(Str.concat(Str.concat(dfp, " = llvm.getelementptr "), mem_p), Str.concat(Str.concat("[0, ", Str.concat(Convert.i64_to_str(di as i64), "]")), Str.concat(" : (!llvm.ptr) -> !llvm.ptr, ", struct_mlir2))))
                # Check if field has a default value node at +32
                def_val_node: i64 = Memory.read_i64(dfnode + 32)
                if def_val_node != 0:
                    # Generate the default value expression
                    dfval: str = gen_expr(def_val_node, dftype)
                    # Implicit cast if needed (e.g. f64 literal for f32 field)
                    def_actual: str = infer_expr_type(def_val_node)
                    if str_eq(def_actual, dftype) == 0 and str_eq(def_actual, "unknown") == 0:
                        dfval = implicit_cast(dfval, def_actual, dftype)
                    emit_store(dfval, dfp, dft_mlir)
                else:
                    # No default — store zero
                    dz: str = new_tmp()
                    if is_float_type(dftype) == 1:
                        emit_ind(Str.concat(Str.concat(Str.concat(dz, " = llvm.mlir.constant(0.0 : "), Str.concat(dft_mlir, ") : ")), dft_mlir))
                    elif str_eq(dftype, "str") == 1 or str_eq(dftype, "string") == 1 or str_eq(dft_mlir, "!llvm.ptr") == 1:
                        emit_ind(Str.concat(dz, " = llvm.mlir.zero : !llvm.ptr"))
                    else:
                        emit_ind(Str.concat(Str.concat(Str.concat(dz, " = llvm.mlir.constant(0 : "), Str.concat(dft_mlir, ") : ")), dft_mlir))
                    emit_store(dz, dfp, dft_mlir)
            di = di + 1

    return mem_p

# ==========================================
# Builtin Call (LLVM intrinsics: sqrt, sin, cos, etc.)
# ==========================================
fun gen_builtin_call(node: i64) -> str:
    fname: str = Memory.read_i64(node + 8) as str
    args: i64 = Memory.read_i64(node + 16)

    # Map to LLVM intrinsic
    intrinsic: str = Str.concat("llvm.intr.", fname)
    ac: i32 = 0
    if args != 0:
        ac = nl_count(args)

    if ac == 1:
        # Infer the argument type instead of hardcoding f64
        arg_et: str = infer_expr_type(nl_get(args, 0))
        if is_float_type(arg_et) == 0:
            arg_et = "f64"
        arg_mt: str = mlir_type(arg_et)
        a1: str = gen_expr(nl_get(args, 0), arg_et)
        result: str = new_tmp()
        # Use direct intrinsic syntax: llvm.intr.sqrt(%val) : (f32) -> f32
        emit_ind(Str.concat(Str.concat(Str.concat(Str.concat(result, " = "), intrinsic), Str.concat("(", Str.concat(a1, ")"))), Str.concat(Str.concat(" : (", arg_mt), Str.concat(") -> ", arg_mt))))
        return result
    elif ac == 2:
        arg_et2: str = infer_expr_type(nl_get(args, 0))
        if is_float_type(arg_et2) == 0:
            arg_et2 = "f64"
        arg_mt2: str = mlir_type(arg_et2)
        a1: str = gen_expr(nl_get(args, 0), arg_et2)
        a2: str = gen_expr(nl_get(args, 1), arg_et2)
        result: str = new_tmp()
        emit_ind(Str.concat(Str.concat(Str.concat(Str.concat(result, " = "), intrinsic), Str.concat("(", Str.concat(Str.concat(a1, ", "), Str.concat(a2, ")")))), Str.concat(Str.concat(" : (", Str.concat(arg_mt2, Str.concat(", ", arg_mt2))), Str.concat(") -> ", arg_mt2))))
        return result

    return emit_zero_ptr()

##############################
# MLIR Codegen Statements
# if/while/for/match/return/break/continue/assignment
# Depends on: codegen_core.dlt, codegen_types.dlt, codegen_expr.dlt
##############################

# ==========================================
# Assignment
# ==========================================
fun gen_assignment(node: i64):
    name: str = Memory.read_i64(node + 8) as str
    val_node: i64 = Memory.read_i64(node + 16)

    # Check const/imm reassignment
    vc: i32 = is_var_const(name)
    if vc == 1:
        IOOps.io_println(Str.concat("[error] Cannot reassign immutable variable '", Str.concat(name, "'")))
        return

    mn: str = get_mlir_name(name)
    if str_eq(mn, "") == 1:
        # Variable doesn't exist — create it (implicit declaration)
        vt: str = infer_expr_type(val_node)
        if str_eq(vt, "unknown") == 1:
            vt = "i32"
        mt: str = mlir_type(vt)
        alloc: str = emit_alloca(mt)
        # Store the mlir_name without the % prefix
        alloc_name: str = str_from_range(alloc, 1, Memory.strlen(alloc))
        add_variable(name, alloc_name, vt, 0, 0)
        mn = alloc_name

    vt2: str = get_var_type(name)
    mt2: str = mlir_type(vt2)

    actual_type: str = infer_expr_type(val_node)
    value_result: str = gen_expr(val_node, vt2)

    # Implicit cast if needed (e.g., i32 literal → i64 variable)
    if str_eq(actual_type, vt2) == 0 and str_eq(actual_type, "unknown") == 0:
        value_result = implicit_cast(value_result, actual_type, vt2)

    # Store to global or local
    # Check if a local variable shadows this global (same fix as gen_var_load)
    is_local_shadow: i32 = 0
    if is_global_var(name) == 1 and g_in_function == 1:
        vi: i32 = g_var_count - 1
        while vi >= 0:
            voff: i64 = (vi as i64) * 8
            vn: str = Memory.read_i64(g_var_names + voff) as str
            if str_eq(vn, name) == 1:
                vpoff: i64 = (vi as i64) * 4
                vp: i32 = Memory.read_i32(g_var_is_param + vpoff)
                if vp == 0:
                    is_local_shadow = 1
                vi = -1
            vi = vi - 1

    if is_global_var(name) == 1 and is_local_shadow == 0:
        ga: str = emit_addr_of(mn)
        emit_store(value_result, ga, mt2)
    else:
        emit_store(value_result, Str.concat("%", mn), mt2)

# ==========================================
# Field Assignment (obj.field = value)
# ==========================================
fun gen_field_assignment(node: i64):
    obj_name: str = Memory.read_i64(node + 8) as str
    field_name: str = Memory.read_i64(node + 16) as str
    val_node: i64 = Memory.read_i64(node + 24)

    # Self field assignment: self.field = value
    if str_eq(obj_name, "self") == 1:
        sname: str = g_cur_method_struct
        ftype: str = get_field_type(sname, field_name)
        fidx: i32 = get_field_index(sname, field_name)
        mt: str = mlir_type(ftype)
        struct_mlir: str = get_struct_mlir_type(sname)
        fp: str = new_tmp()
        emit_ind(Str.concat(Str.concat(fp, " = llvm.getelementptr %self[0, "), Str.concat(Str.concat(Convert.i64_to_str(fidx as i64), "] : (!llvm.ptr) -> !llvm.ptr, "), struct_mlir)))
        val: str = gen_expr(val_node, ftype)
        actual_type: str = infer_expr_type(val_node)
        if str_eq(actual_type, ftype) == 0:
            val = implicit_cast(val, actual_type, ftype)
        emit_store(val, fp, mt)
        return

    # Get struct type of object
    obj_type: str = get_var_type(obj_name)

    # Access control enforcement for field assignment
    acc: str = get_field_access(obj_type, field_name)
    if str_eq(acc, "private") == 1:
        in_struct3: i32 = 0
        if (g_cur_method_struct as i64) != 0:
            if Memory.strlen(g_cur_method_struct) > 0:
                if str_eq(g_cur_method_struct, obj_type) == 1:
                    in_struct3 = 1
        if in_struct3 == 0:
            IOOps.io_println(Str.concat("[error] Cannot assign to private field: ", field_name))
            return
    elif str_eq(acc, "protected") == 1:
        allowed2: i32 = 0
        if (g_cur_method_struct as i64) != 0:
            if Memory.strlen(g_cur_method_struct) > 0:
                if str_eq(g_cur_method_struct, obj_type) == 1:
                    allowed2 = 1
                if allowed2 == 0:
                    par2: str = get_parent_struct(g_cur_method_struct)
                    if (par2 as i64) != 0:
                        if Memory.strlen(par2) > 0:
                            if str_eq(par2, obj_type) == 1:
                                allowed2 = 1
        if allowed2 == 0:
            IOOps.io_println(Str.concat("[error] Cannot assign to protected field: ", field_name))
            return

    # ptr[T].value = x → store through typed pointer
    if str_eq(field_name, "value") == 1:
        if is_ptr_type(obj_type) == 1:
            elem_t: str = ptr_elem_type(obj_type)
            elem_mt: str = mlir_type(elem_t)
            ptr_val: str = gen_var_load(obj_name, obj_type)
            val2: str = gen_expr(val_node, elem_t)
            emit_store(val2, ptr_val, elem_mt)
            return

    ftype2: str = get_field_type(obj_type, field_name)
    fidx2: i32 = get_field_index(obj_type, field_name)
    mt2: str = mlir_type(ftype2)

    # Load object pointer
    obj_ptr: str = gen_var_load(obj_name, obj_type)

    # GEP to field
    struct_mlir2: str = get_struct_mlir_type(obj_type)
    fp2: str = new_tmp()
    emit_ind(Str.concat(Str.concat(Str.concat(fp2, " = llvm.getelementptr "), obj_ptr), Str.concat(Str.concat("[0, ", Str.concat(Convert.i64_to_str(fidx2 as i64), "]")), Str.concat(" : (!llvm.ptr) -> !llvm.ptr, ", struct_mlir2))))

    # Generate and store value
    val3: str = gen_expr(val_node, ftype2)
    actual_type3: str = infer_expr_type(val_node)
    if str_eq(actual_type3, ftype2) == 0:
        val3 = implicit_cast(val3, actual_type3, ftype2)
    emit_store(val3, fp2, mt2)

# ==========================================
# Static Field Assignment (Struct.field = value)
# ==========================================
fun gen_static_field_assignment(node: i64):
    sname: str = Memory.read_i64(node + 8) as str
    fname: str = Memory.read_i64(node + 16) as str
    val_node: i64 = Memory.read_i64(node + 24)

    full: str = Str.concat(Str.concat(sname, "__"), fname)
    ga: str = emit_addr_of(full)
    sf_type: str = lookup_static_field_type(full)
    val: str = gen_expr(val_node, sf_type)
    actual_t: str = infer_expr_type(val_node)
    if str_eq(actual_t, sf_type) == 0 and str_eq(actual_t, "unknown") == 0:
        val = implicit_cast(val, actual_t, sf_type)
    emit_store(val, ga, sf_type)

# ==========================================
# Block Always Returns? (for branch optimization)
# ==========================================
fun block_always_returns(stmts: i64) -> i32:
    if stmts == 0:
        return 0
    sc: i32 = nl_count(stmts)
    if sc == 0:
        return 0
    last: i64 = nl_get(stmts, sc - 1)
    lt: i32 = nd_type(last)
    if lt == NODE_RETURN or lt == NODE_BREAK or lt == NODE_CONTINUE:
        return 1
    if lt == NODE_IF:
        # Both branches must return
        then_body: i64 = Memory.read_i64(last + 16)
        else_body: i64 = Memory.read_i64(last + 24)
        if else_body == 0:
            return 0
        if block_always_returns(then_body) == 1 and block_always_returns(else_body) == 1:
            return 1
    return 0

# ==========================================
# If Statement
# ==========================================
fun gen_if_stmt(node: i64):
    cond_node: i64 = Memory.read_i64(node + 8)
    then_body: i64 = Memory.read_i64(node + 16)
    else_body: i64 = Memory.read_i64(node + 24)

    then_label: str = new_label()
    end_label: str = new_label()
    else_label: str = ""
    if else_body != 0:
        else_label = new_label()

    # Generate condition
    ct: str = infer_expr_type(cond_node)
    cond_val: str = gen_expr(cond_node, ct)

    # Convert to bool if not already
    if str_eq(ct, "bool") == 0 and str_eq(ct, "i1") == 0:
        mt: str = mlir_type(ct)
        zero: str = new_tmp()
        bool_r: str = new_tmp()
        if is_float_type(ct) == 1:
            emit_ind(Str.concat(Str.concat(Str.concat(zero, " = llvm.mlir.constant(0.0 : "), mt), Str.concat(") : ", mt)))
            emit_ind(Str.concat(Str.concat(Str.concat(Str.concat(bool_r, " = llvm.fcmp \"une\" "), cond_val), Str.concat(", ", zero)), Str.concat(" : ", mt)))
        elif str_eq(mt, "!llvm.ptr") == 1:
            emit_ind(Str.concat(zero, " = llvm.mlir.zero : !llvm.ptr"))
            emit_ind(Str.concat(Str.concat(Str.concat(Str.concat(bool_r, " = llvm.icmp \"ne\" "), cond_val), Str.concat(", ", zero)), " : !llvm.ptr"))
        else:
            emit_ind(Str.concat(Str.concat(Str.concat(zero, " = llvm.mlir.constant(0 : "), mt), Str.concat(") : ", mt)))
            emit_ind(Str.concat(Str.concat(Str.concat(Str.concat(bool_r, " = llvm.icmp \"ne\" "), cond_val), Str.concat(", ", zero)), Str.concat(" : ", mt)))
        cond_val = bool_r

    # Conditional branch
    if else_body != 0:
        emit_ind(Str.concat(Str.concat(Str.concat(Str.concat("llvm.cond_br ", cond_val), ", "), then_label), Str.concat(", ", else_label)))
    else:
        emit_ind(Str.concat(Str.concat(Str.concat(Str.concat("llvm.cond_br ", cond_val), ", "), then_label), Str.concat(", ", end_label)))

    # Then block
    emit(Str.concat("  ", Str.concat(then_label, ":")))
    gen_block(then_body)
    then_ret: i32 = block_always_returns(then_body)
    if then_ret == 0:
        emit_ind(Str.concat("llvm.br ", end_label))

    # Else block
    else_ret: i32 = 0
    if else_body != 0:
        emit(Str.concat("  ", Str.concat(else_label, ":")))
        gen_block(else_body)
        else_ret = block_always_returns(else_body)
        if else_ret == 0:
            emit_ind(Str.concat("llvm.br ", end_label))

    # End block (if at least one branch doesn't return)
    if then_ret == 0 or else_ret == 0:
        emit(Str.concat("  ", Str.concat(end_label, ":")))

# ==========================================
# While Loop
# ==========================================
fun gen_while_loop(node: i64):
    cond_node: i64 = Memory.read_i64(node + 8)
    body: i64 = Memory.read_i64(node + 16)

    cond_label: str = new_label()
    body_label: str = new_label()
    end_label: str = new_label()

    # Save break/continue labels
    old_break: str = g_break_label
    old_cont: str = g_continue_label
    g_break_label = end_label
    g_continue_label = cond_label

    # Jump to condition
    emit_ind(Str.concat("llvm.br ", cond_label))

    # Condition block
    emit(Str.concat("  ", Str.concat(cond_label, ":")))
    ct: str = infer_expr_type(cond_node)
    cond_val: str = gen_expr(cond_node, ct)
    # Convert to bool
    if str_eq(ct, "bool") == 0 and str_eq(ct, "i1") == 0:
        mt: str = mlir_type(ct)
        z: str = new_tmp()
        br: str = new_tmp()
        emit_ind(Str.concat(Str.concat(Str.concat(z, " = llvm.mlir.constant(0 : "), mt), Str.concat(") : ", mt)))
        emit_ind(Str.concat(Str.concat(Str.concat(Str.concat(br, " = llvm.icmp \"ne\" "), cond_val), Str.concat(", ", z)), Str.concat(" : ", mt)))
        cond_val = br

    emit_ind(Str.concat(Str.concat(Str.concat(Str.concat("llvm.cond_br ", cond_val), ", "), body_label), Str.concat(", ", end_label)))

    # Body block
    emit(Str.concat("  ", Str.concat(body_label, ":")))
    gen_block(body)
    if block_always_returns(body) == 0:
        emit_ind(Str.concat("llvm.br ", cond_label))

    # End block
    emit(Str.concat("  ", Str.concat(end_label, ":")))

    # Restore break/continue
    g_break_label = old_break
    g_continue_label = old_cont

# ==========================================
# For Loop (C-style: init, cond, update)
# ==========================================
fun gen_for_loop(node: i64):
    init_node: i64 = Memory.read_i64(node + 8)
    cond_node: i64 = Memory.read_i64(node + 16)
    update_node: i64 = Memory.read_i64(node + 24)
    body: i64 = Memory.read_i64(node + 32)

    cond_label: str = new_label()
    body_label: str = new_label()
    update_label: str = new_label()
    end_label: str = new_label()

    old_break: str = g_break_label
    old_cont: str = g_continue_label
    g_break_label = end_label
    g_continue_label = update_label

    # Init
    push_var_scope()
    if init_node != 0:
        gen_statement(init_node)

    # Jump to condition
    emit_ind(Str.concat("llvm.br ", cond_label))

    # Condition
    emit(Str.concat("  ", Str.concat(cond_label, ":")))
    ct: str = infer_expr_type(cond_node)
    cv: str = gen_expr(cond_node, ct)
    if str_eq(ct, "bool") == 0 and str_eq(ct, "i1") == 0:
        mt: str = mlir_type(ct)
        z: str = new_tmp()
        br: str = new_tmp()
        emit_ind(Str.concat(Str.concat(Str.concat(z, " = llvm.mlir.constant(0 : "), mt), Str.concat(") : ", mt)))
        emit_ind(Str.concat(Str.concat(Str.concat(Str.concat(br, " = llvm.icmp \"ne\" "), cv), Str.concat(", ", z)), Str.concat(" : ", mt)))
        cv = br
    emit_ind(Str.concat(Str.concat(Str.concat(Str.concat("llvm.cond_br ", cv), ", "), body_label), Str.concat(", ", end_label)))

    # Body
    emit(Str.concat("  ", Str.concat(body_label, ":")))
    gen_block(body)
    if block_always_returns(body) == 0:
        emit_ind(Str.concat("llvm.br ", update_label))

    # Update
    emit(Str.concat("  ", Str.concat(update_label, ":")))
    if update_node != 0:
        gen_statement(update_node)
    emit_ind(Str.concat("llvm.br ", cond_label))

    # End
    emit(Str.concat("  ", Str.concat(end_label, ":")))
    pop_var_scope()

    g_break_label = old_break
    g_continue_label = old_cont

# ==========================================
# For-Each Loop
# ==========================================
fun gen_foreach_loop(node: i64):
    item_var: str = Memory.read_i64(node + 8) as str
    col_expr: i64 = Memory.read_i64(node + 32)
    body: i64 = Memory.read_i64(node + 40)

    cond_label: str = new_label()
    body_label: str = new_label()
    end_label: str = new_label()

    old_break: str = g_break_label
    old_cont: str = g_continue_label
    g_break_label = end_label
    g_continue_label = cond_label

    push_var_scope()

    # Get collection pointer
    col_ptr: str = gen_expr(col_expr, "ptr")

    # Infer element type from collection type annotation
    col_type: str = infer_expr_type(col_expr)
    elem_type: str = "i64"
    # Extract T from list[T] or array[T] (parser normalizes <> to [])
    ct_len: i64 = Memory.strlen(col_type)
    lt_i: i64 = 0
    while lt_i < ct_len:
        c: i8 = Memory.read_i8((col_type as i64) + lt_i)
        if c == 91:
            # Found '[', extract until ']'
            elem_type = str_from_range(col_type, lt_i + 1, ct_len - 1)
            lt_i = ct_len
        lt_i = lt_i + 1

    # Determine MLIR type for element
    elem_mt: str = mlir_type(elem_type)
    is_ptr_elem: i32 = 0
    if str_eq(elem_mt, "!llvm.ptr") == 1:
        is_ptr_elem = 1

    # Load size from collection header
    size_val: str = emit_load(col_ptr, "i32")

    # Create index variable
    idx_alloc: str = emit_alloca("i32")
    idx_name: str = str_from_range(idx_alloc, 1, Memory.strlen(idx_alloc))
    z: str = emit_const_i32(0)
    emit_store(z, idx_alloc, "i32")

    # Create item variable with correct element type
    item_alloc: str = emit_alloca(elem_mt)
    item_name: str = str_from_range(item_alloc, 1, Memory.strlen(item_alloc))
    add_variable(item_var, item_name, elem_type, 0, 0)

    emit_ind(Str.concat("llvm.br ", cond_label))

    # Condition: idx < size
    emit(Str.concat("  ", Str.concat(cond_label, ":")))
    cur_idx: str = emit_load(idx_alloc, "i32")
    cmp: str = new_tmp()
    emit_ind(Str.concat(Str.concat(Str.concat(Str.concat(cmp, " = llvm.icmp \"slt\" "), cur_idx), Str.concat(", ", size_val)), " : i32"))
    emit_ind(Str.concat(Str.concat(Str.concat(Str.concat("llvm.cond_br ", cmp), ", "), body_label), Str.concat(", ", end_label)))

    # Body
    emit(Str.concat("  ", Str.concat(body_label, ":")))

    # Calculate element slot size
    elem_slot_sz: i64 = get_type_size(elem_type) as i64
    if elem_slot_sz < 8:
        elem_slot_sz = 8

    # Detect if collection is list (3-field) or array (inline)
    is_list: i32 = 0
    if Memory.read_i8((col_type as i64)) == 108:
        if Memory.read_i8((col_type as i64) + 1) == 105:
            is_list = 1

    # Get base data pointer
    base_data: str = col_ptr
    if is_list == 1:
        # list: load data_ptr from header +8
        dp_off: str = emit_const_i64(8)
        dp_gep: str = new_tmp()
        emit_ind(Str.concat(Str.concat(Str.concat(Str.concat(dp_gep, " = llvm.getelementptr "), col_ptr), Str.concat("[", Str.concat(dp_off, "]"))), " : (!llvm.ptr, i64) -> !llvm.ptr, i8"))
        base_data = emit_load(dp_gep, "!llvm.ptr")

    # Load current element
    cur_idx2: str = emit_load(idx_alloc, "i32")
    idx_i64: str = new_tmp()
    emit_ind(Str.concat(Str.concat(Str.concat(idx_i64, " = llvm.sext "), cur_idx2), " : i32 to i64"))
    c_slot: str = emit_const_i64(elem_slot_sz)
    off: str = new_tmp()
    emit_ind(Str.concat(Str.concat(Str.concat(Str.concat(off, " = llvm.mul "), idx_i64), Str.concat(", ", c_slot)), " : i64"))

    # Add base offset (array: +4 for size field, list: +0 since data_ptr is separate)
    final_off: str = off
    if is_list == 0:
        c4base: str = emit_const_i64(4)
        final_off = new_tmp()
        emit_ind(Str.concat(Str.concat(Str.concat(Str.concat(final_off, " = llvm.add "), off), Str.concat(", ", c4base)), " : i64"))

    ep: str = new_tmp()
    emit_ind(Str.concat(Str.concat(Str.concat(Str.concat(ep, " = llvm.getelementptr "), base_data), Str.concat("[", Str.concat(final_off, "]"))), " : (!llvm.ptr, i64) -> !llvm.ptr, i8"))

    # Load and store with native element type
    elem_val: str = emit_load(ep, elem_mt)
    emit_store(elem_val, item_alloc, elem_mt)

    gen_block(body)

    # Increment index
    cur_idx3: str = emit_load(idx_alloc, "i32")
    c1: str = emit_const_i32(1)
    next_idx: str = new_tmp()
    emit_ind(Str.concat(Str.concat(Str.concat(Str.concat(next_idx, " = llvm.add "), cur_idx3), Str.concat(", ", c1)), " : i32"))
    emit_store(next_idx, idx_alloc, "i32")
    emit_ind(Str.concat("llvm.br ", cond_label))

    # End
    emit(Str.concat("  ", Str.concat(end_label, ":")))
    pop_var_scope()

    g_break_label = old_break
    g_continue_label = old_cont

# ==========================================
# Return Statement
# ==========================================
fun gen_return(node: i64):
    val_node: i64 = Memory.read_i64(node + 8)
    if val_node == 0:
        emit_ind("llvm.return")
        return

    ret_type: str = g_cur_fn_ret_type
    val: str = gen_expr(val_node, ret_type)
    vt: str = infer_expr_type(val_node)
    if str_eq(vt, ret_type) == 0 and str_eq(vt, "unknown") == 0:
        val = implicit_cast(val, vt, ret_type)

    mt: str = mlir_type(ret_type)
    emit_ind(Str.concat(Str.concat(Str.concat("llvm.return ", val), " : "), mt))

# ==========================================
# Break / Continue
# ==========================================
fun gen_break():
    if str_eq(g_break_label, "") == 0:
        emit_ind(Str.concat("llvm.br ", g_break_label))

fun gen_continue():
    if str_eq(g_continue_label, "") == 0:
        emit_ind(Str.concat("llvm.br ", g_continue_label))

# ==========================================
# Match Statement (as if-else chain)
# ==========================================
fun gen_match_stmt(node: i64):
    expr_node: i64 = Memory.read_i64(node + 8)
    cases: i64 = Memory.read_i64(node + 16)
    else_body: i64 = Memory.read_i64(node + 24)

    # Generate match expression
    et: str = infer_expr_type(expr_node)
    match_val: str = gen_expr(expr_node, et)
    mt: str = mlir_type(et)

    end_label: str = new_label()
    cc: i32 = nl_count(cases)
    i: i32 = 0

    while i < cc:
        case_node: i64 = nl_get(cases, i)
        patterns: i64 = Memory.read_i64(case_node + 8)
        body: i64 = Memory.read_i64(case_node + 16)
        guard: i64 = Memory.read_i64(case_node + 24)

        then_lbl: str = new_label()
        next_lbl: str = new_label()

        # Generate pattern comparison (first pattern for now)
        pc: i32 = nl_count(patterns)
        skip_cmp: i32 = 0
        pat_val: str = ""
        if pc > 0:
            pat: i64 = nl_get(patterns, 0)
            pat_nt: i32 = nd_type(pat)
            if pat_nt == NODE_PATTERN:
                pptype: str = Memory.read_i64(pat + 8) as str
                if str_eq(pptype, "enum") == 1:
                    pp_ename: str = Memory.read_i64(pat + 56) as str
                    pp_vname: str = Memory.read_i64(pat + 64) as str
                    pp_idx: i32 = get_enum_value_index(pp_ename, pp_vname)
                    pat_val = emit_const_i32(pp_idx)
                elif str_eq(pptype, "value") == 1:
                    pp_str_val: str = Memory.read_i64(pat + 16) as str
                    pp_tmp: str = new_tmp()
                    if str_eq(mt, "!llvm.ptr") == 1:
                        pat_val = gen_expr(pat, et)
                    else:
                        emit_ind(Str.concat(Str.concat(Str.concat(Str.concat(pp_tmp, " = llvm.mlir.constant("), pp_str_val), Str.concat(" : ", mt)), Str.concat(") : ", mt)))
                        pat_val = pp_tmp
                elif str_eq(pptype, "range") == 1:
                    pp_start_str: str = Memory.read_i64(pat + 24) as str
                    pp_end_str: str = Memory.read_i64(pat + 32) as str
                    pp_start_t: str = new_tmp()
                    pp_end_t: str = new_tmp()
                    emit_ind(Str.concat(Str.concat(Str.concat(Str.concat(pp_start_t, " = llvm.mlir.constant("), pp_start_str), Str.concat(" : ", mt)), Str.concat(") : ", mt)))
                    emit_ind(Str.concat(Str.concat(Str.concat(Str.concat(pp_end_t, " = llvm.mlir.constant("), pp_end_str), Str.concat(" : ", mt)), Str.concat(") : ", mt)))
                    pp_ge: str = new_tmp()
                    pp_le: str = new_tmp()
                    pp_and: str = new_tmp()
                    emit_ind(Str.concat(Str.concat(Str.concat(Str.concat(pp_ge, " = llvm.icmp \"sge\" "), match_val), Str.concat(", ", pp_start_t)), Str.concat(" : ", mt)))
                    emit_ind(Str.concat(Str.concat(Str.concat(Str.concat(pp_le, " = llvm.icmp \"sle\" "), match_val), Str.concat(", ", pp_end_t)), Str.concat(" : ", mt)))
                    emit_ind(Str.concat(Str.concat(Str.concat(Str.concat(pp_and, " = llvm.and "), pp_ge), Str.concat(", ", pp_le)), " : i1"))
                    emit_ind(Str.concat(Str.concat(Str.concat(Str.concat("llvm.cond_br ", pp_and), ", "), then_lbl), Str.concat(", ", next_lbl)))
                    skip_cmp = 1
                else:
                    pat_val = emit_const_i32(0)
            else:
                pat_val = gen_expr(pat, et)

        if skip_cmp == 0:
            if pc > 0:
                cmp: str = new_tmp()
                emit_ind(Str.concat(Str.concat(Str.concat(Str.concat(Str.concat(cmp, " = llvm.icmp \"eq\" "), match_val), Str.concat(", ", pat_val)), " : "), mt))
                emit_ind(Str.concat(Str.concat(Str.concat(Str.concat("llvm.cond_br ", cmp), ", "), then_lbl), Str.concat(", ", next_lbl)))
            else:
                emit_ind(Str.concat("llvm.br ", then_lbl))

        emit(Str.concat("  ", Str.concat(then_lbl, ":")))
        gen_block(body)
        if block_always_returns(body) == 0:
            emit_ind(Str.concat("llvm.br ", end_label))

        emit(Str.concat("  ", Str.concat(next_lbl, ":")))
        i = i + 1

    # Else body
    if else_body != 0:
        gen_block(else_body)
        if block_always_returns(else_body) == 0:
            emit_ind(Str.concat("llvm.br ", end_label))
    else:
        emit_ind(Str.concat("llvm.br ", end_label))

    emit(Str.concat("  ", Str.concat(end_label, ":")))

# ==========================================
# Match as Expression (returns value)
# ==========================================
fun gen_match_expr(node: i64, expected: str) -> str:
    # For match used as expression, generate as if-else chain with phi-like alloca
    result_alloc: str = emit_alloca(mlir_type(expected))

    expr_node: i64 = Memory.read_i64(node + 8)
    cases: i64 = Memory.read_i64(node + 16)
    else_body: i64 = Memory.read_i64(node + 24)

    et: str = infer_expr_type(expr_node)
    match_val: str = gen_expr(expr_node, et)
    mt: str = mlir_type(et)
    end_label: str = new_label()
    cc: i32 = nl_count(cases)
    i: i32 = 0

    while i < cc:
        case_node: i64 = nl_get(cases, i)
        patterns: i64 = Memory.read_i64(case_node + 8)
        body: i64 = Memory.read_i64(case_node + 16)

        then_lbl: str = new_label()
        next_lbl: str = new_label()

        pc: i32 = nl_count(patterns)
        skip_cmp2: i32 = 0
        pat_val: str = ""
        if pc > 0:
            pat: i64 = nl_get(patterns, 0)
            pat_nt2: i32 = nd_type(pat)
            if pat_nt2 == NODE_PATTERN:
                pptype2: str = Memory.read_i64(pat + 8) as str
                if str_eq(pptype2, "enum") == 1:
                    pp_ename2: str = Memory.read_i64(pat + 56) as str
                    pp_vname2: str = Memory.read_i64(pat + 64) as str
                    pp_idx2: i32 = get_enum_value_index(pp_ename2, pp_vname2)
                    pat_val = emit_const_i32(pp_idx2)
                elif str_eq(pptype2, "value") == 1:
                    pp_str_val2: str = Memory.read_i64(pat + 16) as str
                    pp_tmp2: str = new_tmp()
                    if str_eq(mt, "!llvm.ptr") == 1:
                        pat_val = gen_expr(pat, et)
                    else:
                        emit_ind(Str.concat(Str.concat(Str.concat(Str.concat(pp_tmp2, " = llvm.mlir.constant("), pp_str_val2), Str.concat(" : ", mt)), Str.concat(") : ", mt)))
                        pat_val = pp_tmp2
                elif str_eq(pptype2, "range") == 1:
                    pp_start_str2: str = Memory.read_i64(pat + 24) as str
                    pp_end_str2: str = Memory.read_i64(pat + 32) as str
                    pp_start_t2: str = new_tmp()
                    pp_end_t2: str = new_tmp()
                    emit_ind(Str.concat(Str.concat(Str.concat(Str.concat(pp_start_t2, " = llvm.mlir.constant("), pp_start_str2), Str.concat(" : ", mt)), Str.concat(") : ", mt)))
                    emit_ind(Str.concat(Str.concat(Str.concat(Str.concat(pp_end_t2, " = llvm.mlir.constant("), pp_end_str2), Str.concat(" : ", mt)), Str.concat(") : ", mt)))
                    pp_ge2: str = new_tmp()
                    pp_le2: str = new_tmp()
                    pp_and2: str = new_tmp()
                    emit_ind(Str.concat(Str.concat(Str.concat(Str.concat(pp_ge2, " = llvm.icmp \"sge\" "), match_val), Str.concat(", ", pp_start_t2)), Str.concat(" : ", mt)))
                    emit_ind(Str.concat(Str.concat(Str.concat(Str.concat(pp_le2, " = llvm.icmp \"sle\" "), match_val), Str.concat(", ", pp_end_t2)), Str.concat(" : ", mt)))
                    emit_ind(Str.concat(Str.concat(Str.concat(Str.concat(pp_and2, " = llvm.and "), pp_ge2), Str.concat(", ", pp_le2)), " : i1"))
                    emit_ind(Str.concat(Str.concat(Str.concat(Str.concat("llvm.cond_br ", pp_and2), ", "), then_lbl), Str.concat(", ", next_lbl)))
                    skip_cmp2 = 1
                else:
                    pat_val = emit_const_i32(0)
            else:
                pat_val = gen_expr(pat, et)

        if skip_cmp2 == 0:
            if pc > 0:
                cmp: str = new_tmp()
                emit_ind(Str.concat(Str.concat(Str.concat(Str.concat(Str.concat(cmp, " = llvm.icmp \"eq\" "), match_val), Str.concat(", ", pat_val)), " : "), mt))
                emit_ind(Str.concat(Str.concat(Str.concat(Str.concat("llvm.cond_br ", cmp), ", "), then_lbl), Str.concat(", ", next_lbl)))

        emit(Str.concat("  ", Str.concat(then_lbl, ":")))
        gen_block(body)
        emit_ind(Str.concat("llvm.br ", end_label))

        emit(Str.concat("  ", Str.concat(next_lbl, ":")))
        i = i + 1

    if else_body != 0:
        gen_block(else_body)
    emit_ind(Str.concat("llvm.br ", end_label))

    emit(Str.concat("  ", Str.concat(end_label, ":")))
    return emit_load(result_alloc, mlir_type(expected))

# ==========================================
# Variable Declaration
# (moved here from codegen_decl.dlt to avoid forward-ref bug)
# ==========================================
# Deep-copy a struct from src ptr to a new local alloca, returns dest ptr
fun copy_struct_local(src_ptr: str, sname: str) -> str:
    smtype: str = get_struct_mlir_type(sname)
    dest: str = emit_alloca(smtype)
    fields: i64 = get_struct_fields(sname)
    if fields == 0:
        return dest
    fc: i32 = nl_count(fields)
    fi: i32 = 0
    while fi < fc:
        fnode: i64 = nl_get(fields, fi)
        ftype: str = Memory.read_i64(fnode + 16) as str
        fmt: str = mlir_type(ftype)
        idx_str: str = Convert.i64_to_str(fi as i64)
        # Load from source
        sgep: str = new_tmp()
        emit_ind(Str.concat(Str.concat(Str.concat(sgep, " = llvm.getelementptr "), src_ptr), Str.concat(Str.concat("[0, ", Str.concat(idx_str, "] : (!llvm.ptr) -> !llvm.ptr, ")), smtype)))
        sval: str = emit_load(sgep, fmt)
        # Store to dest
        dgep: str = new_tmp()
        emit_ind(Str.concat(Str.concat(Str.concat(dgep, " = llvm.getelementptr "), dest), Str.concat(Str.concat("[0, ", Str.concat(idx_str, "] : (!llvm.ptr) -> !llvm.ptr, ")), smtype)))
        emit_store(sval, dgep, fmt)
        fi = fi + 1
    return dest

# List declaration statement handler
# NODE_LIST_DECL: +8=name, +16=init_value (array lit node), +24=element_type, +32=is_const
fun gen_list_decl_stmt(node: i64):
    name: str = Memory.read_i64(node + 8) as str
    init_val: i64 = Memory.read_i64(node + 16)
    etype: str = Memory.read_i64(node + 24) as str

    if is_global_list(name) == 1 and g_in_function == 0:
        # Global list: generate init value and store to global
        if init_val != 0:
            lval: str = gen_expr(init_val, "list")
            ga: str = emit_addr_of(name)
            emit_store(lval, ga, "!llvm.ptr")
        return

    # Local list: allocate alloca and store
    alloc: str = emit_alloca("!llvm.ptr")
    alloc_name: str = str_from_range(alloc, 1, Memory.strlen(alloc))
    add_variable(name, alloc_name, "list", 0, 0)
    if init_val != 0:
        lval2: str = gen_expr(init_val, "list")
        emit_store(lval2, alloc, "!llvm.ptr")
    else:
        z: str = emit_zero_ptr()
        emit_store(z, alloc, "!llvm.ptr")

fun gen_var_decl(node: i64):
    vtype: str = Memory.read_i64(node + 8) as str
    name: str = Memory.read_i64(node + 16) as str
    val_node: i64 = Memory.read_i64(node + 24)
    is_const: i32 = Memory.read_i64(node + 48) as i32

    # Global vars: init value is stored to the global address (inline, preserving order)
    if is_global_var(name) == 1 and g_in_function == 0:
        if val_node != 0:
            mn: str = get_mlir_name(name)
            vt: str = get_var_type(name)
            mt2: str = mlir_type(vt)
            actual_t: str = infer_expr_type(val_node)
            gval: str = gen_expr(val_node, vt)
            if str_eq(actual_t, vt) == 0 and str_eq(actual_t, "unknown") == 0:
                gval = implicit_cast(gval, actual_t, vt)
            # Struct deep-copy for globals
            if is_struct_type(vt) == 1 and is_heap_struct(vt) == 0:
                local_copy: str = copy_struct_local(gval, vt)
                ga: str = emit_addr_of(mn)
                emit_store(local_copy, ga, mt2)
            else:
                ga2: str = emit_addr_of(mn)
                emit_store(gval, ga2, mt2)
        return

    # Fix: parser stores "type" for bool/int/float/string keywords — use inferred type
    if str_eq(vtype, "type") == 1:
        if val_node != 0:
            vtype = infer_expr_type(val_node)

    mt: str = mlir_type(vtype)

    if val_node != 0:
        # Struct deep-copy: allocate local struct and copy fields
        if is_struct_type(vtype) == 1 and is_heap_struct(vtype) == 0:
            src_ptr: str = gen_expr(val_node, vtype)
            local_copy2: str = copy_struct_local(src_ptr, vtype)
            alloc_lc: str = emit_alloca(mt)
            alloc_lc_name: str = str_from_range(alloc_lc, 1, Memory.strlen(alloc_lc))
            add_variable(name, alloc_lc_name, vtype, 0, is_const)
            emit_store(local_copy2, alloc_lc, mt)
        else:
            # Allocate and store value
            alloc: str = emit_alloca(mt)
            alloc_name: str = str_from_range(alloc, 1, Memory.strlen(alloc))
            add_variable(name, alloc_name, vtype, 0, is_const)

            # Infer actual type and generate expression
            actual_type: str = infer_expr_type(val_node)
            value_result: str = gen_expr(val_node, vtype)

            # Implicit cast if needed
            if str_eq(actual_type, vtype) == 0 and str_eq(actual_type, "unknown") == 0:
                value_result = implicit_cast(value_result, actual_type, vtype)

            emit_store(value_result, alloc, mt)
    else:
        # No initial value — alloca + zero initialize
        alloc2: str = emit_alloca(mt)
        alloc_name2: str = str_from_range(alloc2, 1, Memory.strlen(alloc2))
        add_variable(name, alloc_name2, vtype, 0, is_const)

        if is_int_type(vtype) == 1:
            default_val: str = new_tmp()
            emit_ind(Str.concat(Str.concat(Str.concat(default_val, " = llvm.mlir.constant(0 : "), mt), Str.concat(") : ", mt)))
            emit_store(default_val, alloc2, mt)
        elif is_float_type(vtype) == 1:
            default_val2: str = new_tmp()
            emit_ind(Str.concat(Str.concat(Str.concat(default_val2, " = llvm.mlir.constant(0.0 : "), mt), Str.concat(") : ", mt)))
            emit_store(default_val2, alloc2, mt)
        elif str_eq(mt, "!llvm.ptr") == 1:
            default_val3: str = emit_zero_ptr()
            emit_store(default_val3, alloc2, mt)

# ==========================================
# Statement Dispatch
# (moved here from codegen_main.dlt to avoid forward-ref bug)
# ==========================================
fun gen_statement(node: i64):
    if node == 0:
        return
    nt: i32 = nd_type(node)

    if nt == NODE_VAR_DECL:
        gen_var_decl(node)
    elif nt == NODE_ASSIGN:
        gen_assignment(node)
    elif nt == NODE_FIELD_ASSIGN:
        gen_field_assignment(node)
    elif nt == NODE_STATIC_FIELD_ASSIGN:
        gen_static_field_assignment(node)
    elif nt == NODE_IF:
        gen_if_stmt(node)
    elif nt == NODE_WHILE:
        gen_while_loop(node)
    elif nt == NODE_FOR:
        gen_for_loop(node)
    elif nt == NODE_FOR_EACH:
        gen_foreach_loop(node)
    elif nt == NODE_RETURN:
        gen_return(node)
    elif nt == NODE_BREAK:
        gen_break()
    elif nt == NODE_CONTINUE:
        gen_continue()
    elif nt == NODE_PASS:
        # No-op
        return
    elif nt == NODE_FUN_CALL:
        gen_fun_call(node)
    elif nt == NODE_STATIC_METHOD:
        gen_static_method_call(node)
    elif nt == NODE_NS_FUN_CALL:
        gen_ns_fun_call(node)
    elif nt == NODE_NS_STATIC_METHOD:
        gen_ns_static_method(node)
    elif nt == NODE_INST_METHOD:
        gen_instance_method_call(node)
    elif nt == NODE_SUPER_METHOD:
        gen_super_method_call(node)
    elif nt == NODE_MATCH:
        gen_match_stmt(node)
    elif nt == NODE_IMPORT:
        # Imports already processed
        return
    elif nt == NODE_ARRAY_DECL:
        gen_var_decl(node)
    elif nt == NODE_LIST_DECL:
        gen_list_decl_stmt(node)
    elif nt == NODE_MAP_DECL:
        gen_var_decl(node)
    elif nt == NODE_ANNOT_DEF:
        # Annotation definitions are processed at parse time, no codegen needed
        return

# ==========================================
# Generate a Block of Statements
# ==========================================
fun gen_block(stmts: i64):
    if stmts == 0:
        return
    sc: i32 = nl_count(stmts)
    i: i32 = 0
    while i < sc:
        gen_statement(nl_get(stmts, i))
        i = i + 1

##############################
# MLIR Codegen Declarations
# fun_def, method_def, struct, enum, extern
# gen_var_decl moved to codegen_stmt.dlt (forward-ref fix)
# Depends on: codegen_core.dlt, codegen_types.dlt, codegen_expr.dlt
##############################

# ==========================================
# Function Definition
# ==========================================
fun gen_fun_def(node: i64):
    fname: str = Memory.read_i64(node + 8) as str
    params: i64 = Memory.read_i64(node + 16)
    ret_type: str = Memory.read_i64(node + 24) as str
    body: i64 = Memory.read_i64(node + 32)
    is_variadic: i64 = Memory.read_i64(node + 48)
    variadic_pname: str = Memory.read_i64(node + 56) as str

    # Resolve overloaded (mangled) function name
    fpt_str: str = build_param_types_str(params)
    mlir_fname: str = resolve_overload(fname, fpt_str)

    # Skip if already emitted (dedup for runtime vs user duplicates)
    if is_fn_emitted(mlir_fname) == 1:
        return
    mark_fn_emitted(mlir_fname)

    # Register function-level annotations for call-site checking
    fn_annot_list: i64 = Memory.read_i64(node + 80)
    if fn_annot_list != 0:
        fn_ac: i32 = Memory.read_i32(fn_annot_list)
        fn_ai: i32 = 0
        while fn_ai < fn_ac:
            fn_an: i64 = Memory.read_i64(fn_annot_list + 8 + (fn_ai * 8) as i64)
            fn_aname: str = Memory.read_i64(fn_an + 8) as str
            fn_aidx: i32 = find_annot(fn_aname)
            if fn_aidx >= 0:
                fn_ek: str = get_annot_emit_kind(fn_aidx)
                if str_eq(fn_ek, "") == 0:
                    fn_em: str = get_annot_emit_msg(fn_aidx)
                    fn_flags: i32 = 0
                    if str_eq(fn_aname, "deprecated") == 1:
                        fn_flags = 1
                    elif str_eq(fn_aname, "must_use") == 1:
                        fn_flags = 2
                    if fn_flags > 0:
                        register_fn_annot(mlir_fname, fn_flags, fn_em)
            fn_ai = fn_ai + 1

    # Reset tmp counter for each function
    g_tmp_counter = 0

    # Build parameter list
    param_str: str = ""
    pc: i32 = 0
    if params != 0:
        pc = nl_count(params)
    i: i32 = 0
    while i < pc:
        pnode: i64 = nl_get(params, i)
        pname: str = Memory.read_i64(pnode + 8) as str
        ptype: str = Memory.read_i64(pnode + 16) as str
        # Skip variadic parameter (not yet supported in codegen)
        if is_variadic == 1 and str_eq(pname, variadic_pname) == 1:
            i = i + 1
            continue
        pmt: str = mlir_type(ptype)
        if i > 0:
            param_str = Str.concat(param_str, ", ")
        param_str = Str.concat(param_str, Str.concat(Str.concat("%arg", Convert.i64_to_str(i as i64)), Str.concat(": ", pmt)))
        i = i + 1

    # Return type
    ret_mt: str = ""
    has_return: i32 = 0
    if str_eq(ret_type, "") == 0 and str_eq(ret_type, "void") == 0:
        ret_mt = mlir_type(ret_type)
        has_return = 1

    # Collect LLVM passthrough attributes from annotations (with composes expansion)
    attr_str: str = collect_llvm_attrs_from_list(Memory.read_i64(node + 80))

    # Emit function header (using mangled name)
    func_attrs: str = ""
    if str_eq(attr_str, "") == 0:
        func_attrs = Str.concat(" attributes { passthrough = [", Str.concat(attr_str, "] }"))

    if has_return == 1:
        emit_ind(Str.concat(Str.concat(Str.concat(Str.concat("llvm.func @", mlir_fname), "("), param_str), Str.concat(") -> ", Str.concat(ret_mt, Str.concat(func_attrs, " {")))))
    else:
        emit_ind(Str.concat(Str.concat(Str.concat(Str.concat("llvm.func @", mlir_fname), "("), param_str), Str.concat(")", Str.concat(func_attrs, " {"))))
    indent_inc()

    # Set up function context
    old_in_fn: i32 = g_in_function
    old_ret_type: str = g_cur_fn_ret_type
    old_fn_name: str = g_cur_fn_name
    g_in_function = 1
    g_cur_fn_ret_type = ret_type
    g_cur_fn_name = fname

    push_var_scope()

    # Register parameters as variables
    i = 0
    while i < pc:
        pnode2: i64 = nl_get(params, i)
        pname2: str = Memory.read_i64(pnode2 + 8) as str
        ptype2: str = Memory.read_i64(pnode2 + 16) as str
        # Skip variadic parameter (not yet supported in codegen)
        if is_variadic == 1 and str_eq(pname2, variadic_pname) == 1:
            i = i + 1
            continue
        arg_name: str = Str.concat("arg", Convert.i64_to_str(i as i64))
        add_variable(pname2, arg_name, ptype2, 1, 0)
        i = i + 1

    # Generate body
    if body != 0:
        gen_block(body)

    # Add implicit return if no return at end
    if has_return == 0:
        if body == 0 or block_always_returns(body) == 0:
            emit_ind("llvm.return")
    else:
        if body == 0 or block_always_returns(body) == 0:
            # Add default return
            if str_eq(ret_mt, "!llvm.ptr") == 1:
                def_ret: str = emit_zero_ptr()
                emit_ind(Str.concat(Str.concat("llvm.return ", def_ret), " : !llvm.ptr"))
            elif is_int_type(ret_type) == 1:
                def_ret2: str = new_tmp()
                emit_ind(Str.concat(Str.concat(Str.concat(def_ret2, " = llvm.mlir.constant(0 : "), ret_mt), Str.concat(") : ", ret_mt)))
                emit_ind(Str.concat(Str.concat(Str.concat("llvm.return ", def_ret2), " : "), ret_mt))
            elif is_float_type(ret_type) == 1:
                def_ret3: str = new_tmp()
                emit_ind(Str.concat(Str.concat(Str.concat(def_ret3, " = llvm.mlir.constant(0.0 : "), ret_mt), Str.concat(") : ", ret_mt)))
                emit_ind(Str.concat(Str.concat(Str.concat("llvm.return ", def_ret3), " : "), ret_mt))

    pop_var_scope()

    # Restore context
    g_in_function = old_in_fn
    g_cur_fn_ret_type = old_ret_type
    g_cur_fn_name = old_fn_name

    indent_dec()
    emit_ind("}")
    emit_blank()

# ==========================================
# Method Definition (inside impl block)
# ==========================================
fun gen_method_def(struct_name: str, node: i64):
    mname: str = Memory.read_i64(node + 8) as str
    params: i64 = Memory.read_i64(node + 16)
    ret_type: str = Memory.read_i64(node + 24) as str
    body: i64 = Memory.read_i64(node + 32)
    is_static: i64 = Memory.read_i64(node + 72)

    # Mangled name: StructName_methodName
    base_mangled: str = Str.concat(Str.concat(struct_name, "_"), mname)

    # Build param types string (skip self) for overload resolution
    mpt_str: str = ""
    mpc: i32 = 0
    if params != 0:
        mpc = nl_count(params)
    mpi: i32 = 0
    while mpi < mpc:
        mpn: i64 = nl_get(params, mpi)
        mpname: str = Memory.read_i64(mpn + 8) as str
        if str_eq(mpname, "self") == 0:
            mptype: str = Memory.read_i64(mpn + 16) as str
            if Memory.strlen(mpt_str) > 0:
                mpt_str = Str.concat(mpt_str, Str.concat(",", mptype))
            else:
                mpt_str = mptype
        mpi = mpi + 1

    # Resolve overloaded name
    mangled: str = resolve_overload(base_mangled, mpt_str)

    # Register method-level annotations for call-site checking
    mt_annot_list: i64 = Memory.read_i64(node + 80)
    if mt_annot_list != 0:
        mt_ac: i32 = Memory.read_i32(mt_annot_list)
        mt_ai: i32 = 0
        while mt_ai < mt_ac:
            mt_an: i64 = Memory.read_i64(mt_annot_list + 8 + (mt_ai * 8) as i64)
            mt_aname: str = Memory.read_i64(mt_an + 8) as str
            mt_aidx: i32 = find_annot(mt_aname)
            if mt_aidx >= 0:
                mt_ek: str = get_annot_emit_kind(mt_aidx)
                if str_eq(mt_ek, "") == 0:
                    mt_em: str = get_annot_emit_msg(mt_aidx)
                    mt_flags: i32 = 0
                    if str_eq(mt_aname, "deprecated") == 1:
                        mt_flags = 1
                    elif str_eq(mt_aname, "must_use") == 1:
                        mt_flags = 2
                    if mt_flags > 0:
                        register_fn_annot(mangled, mt_flags, mt_em)
            mt_ai = mt_ai + 1

    g_tmp_counter = 0

    # Build param list
    # Check if this is a value type (primitive / transparent wrapper)
    resolved_st: str = resolve_type_full(struct_name)
    self_is_value: i32 = 0
    if is_int_type(resolved_st) == 1:
        self_is_value = 1
    elif is_float_type(resolved_st) == 1:
        self_is_value = 1
    elif str_eq(resolved_st, "bool") == 1:
        self_is_value = 1
    elif str_eq(resolved_st, "char") == 1:
        self_is_value = 1
    # Also check intrinsic types directly
    elif is_int_type(struct_name) == 1:
        self_is_value = 1
    elif is_float_type(struct_name) == 1:
        self_is_value = 1
    elif str_eq(struct_name, "bool") == 1:
        self_is_value = 1
    elif str_eq(struct_name, "char") == 1:
        self_is_value = 1

    param_str: str = ""
    if is_static == 0:
        if str_eq(struct_name, "Bool") == 1:
            param_str = "%self: i1"
        elif str_eq(struct_name, "bool") == 1:
            param_str = "%self: i1"
        elif str_eq(struct_name, "I32") == 1:
            param_str = "%self: i32"
        elif str_eq(struct_name, "i32") == 1:
            param_str = "%self: i32"
        elif str_eq(struct_name, "I64") == 1:
            param_str = "%self: i64"
        elif str_eq(struct_name, "i64") == 1:
            param_str = "%self: i64"
        elif str_eq(struct_name, "Char") == 1:
            param_str = "%self: i8"
        elif str_eq(struct_name, "char") == 1:
            param_str = "%self: i8"
        elif str_eq(struct_name, "I8") == 1:
            param_str = "%self: i8"
        elif str_eq(struct_name, "i8") == 1:
            param_str = "%self: i8"
        elif str_eq(struct_name, "I16") == 1:
            param_str = "%self: i16"
        elif str_eq(struct_name, "i16") == 1:
            param_str = "%self: i16"
        elif str_eq(struct_name, "F32") == 1:
            param_str = "%self: f32"
        elif str_eq(struct_name, "f32") == 1:
            param_str = "%self: f32"
        elif str_eq(struct_name, "F64") == 1:
            param_str = "%self: f64"
        elif str_eq(struct_name, "f64") == 1:
            param_str = "%self: f64"
        elif self_is_value == 1:
            param_str = Str.concat("%self: ", mlir_type(resolved_st))
        else:
            param_str = "%self: !llvm.ptr"
    pc: i32 = 0
    if params != 0:
        pc = nl_count(params)
    arg_idx: i32 = 0
    i: i32 = 0
    while i < pc:
        pnode: i64 = nl_get(params, i)
        pname: str = Memory.read_i64(pnode + 8) as str
        ptype: str = Memory.read_i64(pnode + 16) as str
        # Skip self parameter (already added implicitly)
        if str_eq(pname, "self") == 1:
            i = i + 1
        else:
            pmt: str = mlir_type(ptype)
            if arg_idx > 0 or is_static == 0:
                param_str = Str.concat(param_str, Str.concat(", ", Str.concat(Str.concat("%arg", Convert.i64_to_str(arg_idx as i64)), Str.concat(": ", pmt))))
            else:
                param_str = Str.concat(Str.concat("%arg", Convert.i64_to_str(arg_idx as i64)), Str.concat(": ", pmt))
            arg_idx = arg_idx + 1
            i = i + 1

    ret_mt: str = ""
    has_return: i32 = 0
    if str_eq(ret_type, "") == 0 and str_eq(ret_type, "void") == 0:
        ret_mt = mlir_type(ret_type)
        has_return = 1

    # Collect LLVM passthrough attributes from method annotations (with composes expansion)
    m_attr_str: str = collect_llvm_attrs_from_list(Memory.read_i64(node + 80))

    m_func_attrs: str = ""
    if str_eq(m_attr_str, "") == 0:
        m_func_attrs = Str.concat(" attributes { passthrough = [", Str.concat(m_attr_str, "] }"))

    if has_return == 1:
        emit_ind(Str.concat(Str.concat(Str.concat(Str.concat("llvm.func @", mangled), "("), param_str), Str.concat(") -> ", Str.concat(ret_mt, Str.concat(m_func_attrs, " {")))))
    else:
        emit_ind(Str.concat(Str.concat(Str.concat(Str.concat("llvm.func @", mangled), "("), param_str), Str.concat(")", Str.concat(m_func_attrs, " {"))))
    indent_inc()

    old_in_fn: i32 = g_in_function
    old_ret_type: str = g_cur_fn_ret_type
    old_fn_name: str = g_cur_fn_name
    old_method_struct: str = g_cur_method_struct
    g_in_function = 1
    g_cur_fn_ret_type = ret_type
    g_cur_fn_name = mangled
    g_cur_method_struct = struct_name

    push_var_scope()

    # Register self only for instance methods
    if is_static == 0:
        add_variable("self", "self", struct_name, 1, 0)

    # Register params (skip self)
    arg_idx = 0
    i = 0
    while i < pc:
        pnode2: i64 = nl_get(params, i)
        pname2: str = Memory.read_i64(pnode2 + 8) as str
        ptype2: str = Memory.read_i64(pnode2 + 16) as str
        if str_eq(pname2, "self") == 1:
            i = i + 1
        else:
            arg_name: str = Str.concat("arg", Convert.i64_to_str(arg_idx as i64))
            add_variable(pname2, arg_name, ptype2, 1, 0)
            arg_idx = arg_idx + 1
            i = i + 1

    if body != 0:
        gen_block(body)

    if has_return == 0:
        if body == 0 or block_always_returns(body) == 0:
            emit_ind("llvm.return")

    pop_var_scope()

    g_in_function = old_in_fn
    g_cur_fn_ret_type = old_ret_type
    g_cur_fn_name = old_fn_name
    g_cur_method_struct = old_method_struct

    indent_dec()
    emit_ind("}")
    emit_blank()

# ==========================================
# Extern Block
# ==========================================
fun register_extern_sigs(node: i64):
    funcs: i64 = Memory.read_i64(node + 16)
    if funcs == 0:
        return
    fc: i32 = nl_count(funcs)
    ri: i32 = 0
    # Hoisted from loop to avoid alloca-in-loop stack overflow
    fn_node: i64 = 0
    fname: str = ""
    params: i64 = 0
    ret_type: str = ""
    pts: str = ""
    pc: i32 = 0
    pi: i32 = 0
    pnode: i64 = 0
    ptype: str = ""
    while ri < fc:
        fn_node = nl_get(funcs, ri)
        fname = Memory.read_i64(fn_node + 8) as str
        params = Memory.read_i64(fn_node + 16)
        ret_type = Memory.read_i64(fn_node + 24) as str
        # Build comma-separated param types
        pts = ""
        if params != 0:
            pc = nl_count(params)
            pi = 0
            while pi < pc:
                pnode = nl_get(params, pi)
                ptype = Memory.read_i64(pnode + 16) as str
                if pi > 0:
                    pts = Str.concat(pts, ",")
                pts = Str.concat(pts, ptype)
                pi = pi + 1
        register_fun_sig_with_params(fname, ret_type, pts)
        ri = ri + 1

fun gen_extern_block(node: i64):
    lib: str = Memory.read_i64(node + 8) as str
    funcs: i64 = Memory.read_i64(node + 16)
    if funcs == 0:
        return

    fc: i32 = nl_count(funcs)
    i: i32 = 0
    # Hoisted from loop to avoid alloca-in-loop stack overflow
    fn_node: i64 = 0
    fname: str = ""
    params: i64 = 0
    ret_type: str = ""
    param_str: str = ""
    pc: i32 = 0
    j: i32 = 0
    pnode: i64 = 0
    ptype: str = ""
    pmt: str = ""
    ret_mt: str = ""
    while i < fc:
        fn_node = nl_get(funcs, i)
        fname = Memory.read_i64(fn_node + 8) as str
        params = Memory.read_i64(fn_node + 16)
        ret_type = Memory.read_i64(fn_node + 24) as str

        # Build param types
        param_str = ""
        pc = 0
        if params != 0:
            pc = nl_count(params)
        j = 0
        while j < pc:
            pnode = nl_get(params, j)
            ptype = Memory.read_i64(pnode + 16) as str
            pmt = mlir_type(ptype)
            if j > 0:
                param_str = Str.concat(param_str, ", ")
            param_str = Str.concat(param_str, pmt)
            j = j + 1

        ret_mt = ""
        if str_eq(ret_type, "") == 0 and str_eq(ret_type, "void") == 0:
            ret_mt = mlir_type(ret_type)

        # Skip if already emitted (dedup across modules)
        if is_fn_emitted(fname) == 1:
            i = i + 1
            continue

        # Emit extern function declaration
        if str_eq(ret_mt, "") == 1:
            emit_ind(Str.concat(Str.concat(Str.concat("llvm.func @", fname), "("), Str.concat(param_str, ")")))
        else:
            emit_ind(Str.concat(Str.concat(Str.concat("llvm.func @", fname), "("), Str.concat(param_str, Str.concat(") -> ", ret_mt))))

        mark_fn_emitted(fname)
        i = i + 1

# ==========================================
# Struct Inline Methods (methods defined inside struct body)
# ==========================================
fun gen_struct_inline_methods(node: i64):
    sname: str = Memory.read_i64(node + 8) as str
    smethods: i64 = Memory.read_i64(node + 40)
    if smethods == 0:
        return
    mc: i32 = nl_count(smethods)
    i: i32 = 0
    while i < mc:
        mnode: i64 = nl_get(smethods, i)
        mdbg: str = Memory.read_i64(mnode + 8) as str
        IOOps.io_println(Str.concat(Str.concat(Str.concat("  [method] ", sname), "."), mdbg))
        gen_method_def(sname, mnode)
        i = i + 1

# ==========================================
# Impl Block
# ==========================================
fun gen_impl_block(node: i64):
    sname: str = Memory.read_i64(node + 8) as str
    methods: i64 = Memory.read_i64(node + 16)
    if methods == 0:
        return

    mc: i32 = nl_count(methods)
    i: i32 = 0
    while i < mc:
        mnode: i64 = nl_get(methods, i)
        gen_method_def(sname, mnode)
        i = i + 1

# ==========================================
# Extend Block
# ==========================================
fun gen_extend_block(node: i64):
    tname: str = Memory.read_i64(node + 8) as str
    methods: i64 = Memory.read_i64(node + 16)
    if methods == 0:
        return

    mc: i32 = nl_count(methods)
    i: i32 = 0
    while i < mc:
        mnode: i64 = nl_get(methods, i)
        # Extend methods use the type name as struct name
        gen_method_def(tname, mnode)
        i = i + 1

##############################
# MLIR Codegen Access
# Field access, static/instance method calls, array access,
# function calls, super method calls
# Depends on: codegen_core.dlt, codegen_types.dlt, codegen_expr.dlt
##############################

# ==========================================
# Field Access (obj.field)
# ==========================================
fun gen_field_access(node: i64) -> str:
    obj_name: str = Memory.read_i64(node + 8) as str
    field_name: str = Memory.read_i64(node + 16) as str

    # Check if this is enum access (e.g., Direction.UP)
    if is_enum_type(obj_name) == 1:
        eidx: i32 = get_enum_value_index(obj_name, field_name)
        return emit_const_i32(eidx)

    obj_type: str = get_var_type(obj_name)

    # Access control enforcement
    acc: str = get_field_access(obj_type, field_name)
    if str_eq(acc, "private") == 1:
        in_struct: i32 = 0
        if (g_cur_method_struct as i64) != 0:
            if Memory.strlen(g_cur_method_struct) > 0:
                if str_eq(g_cur_method_struct, obj_type) == 1:
                    in_struct = 1
        if in_struct == 0:
            IOOps.io_println(Str.concat("[error] Cannot access private field: ", field_name))
    elif str_eq(acc, "protected") == 1:
        allowed: i32 = 0
        if (g_cur_method_struct as i64) != 0:
            if Memory.strlen(g_cur_method_struct) > 0:
                if str_eq(g_cur_method_struct, obj_type) == 1:
                    allowed = 1
                if allowed == 0:
                    par: str = get_parent_struct(g_cur_method_struct)
                    if (par as i64) != 0:
                        if Memory.strlen(par) > 0:
                            if str_eq(par, obj_type) == 1:
                                allowed = 1
        if allowed == 0:
            IOOps.io_println(Str.concat("[error] Cannot access protected field: ", field_name))

    # ptr[T].value — dereference typed pointer
    if str_eq(field_name, "value") == 1:
        if is_ptr_type(obj_type) == 1:
            elem_t: str = ptr_elem_type(obj_type)
            elem_mt: str = mlir_type(elem_t)
            ptr_val: str = gen_var_load(obj_name, obj_type)
            result: str = new_tmp()
            emit_ind(Str.concat(Str.concat(Str.concat(Str.concat(result, " = llvm.load "), ptr_val), " : !llvm.ptr -> "), elem_mt))
            return result

    fidx: i32 = get_field_index(obj_type, field_name)
    ftype: str = get_field_type(obj_type, field_name)
    mt: str = mlir_type(ftype)

    # Load object pointer
    obj_ptr: str = gen_var_load(obj_name, obj_type)

    # GEP to field
    struct_mlir: str = get_struct_mlir_type(obj_type)
    fp: str = new_tmp()
    emit_ind(Str.concat(Str.concat(Str.concat(fp, " = llvm.getelementptr "), obj_ptr), Str.concat(Str.concat("[0, ", Str.concat(Convert.i64_to_str(fidx as i64), "]")), Str.concat(" : (!llvm.ptr) -> !llvm.ptr, ", struct_mlir))))

    # Load field value
    val: str = emit_load(fp, mt)
    return val

# ==========================================
# Nested Field Access (e.g., state.Gamepad.bLeftTrigger)
# ==========================================
fun gen_nested_field_access(node: i64, expected: str) -> str:
    base_node: i64 = Memory.read_i64(node + 8)
    field_name: str = Memory.read_i64(node + 16) as str

    # Build GEP chain: resolve base to a pointer (without final load)
    base_ptr: str = gen_nested_field_ptr(base_node)

    # Get type of the base expression
    base_type: str = infer_expr_type(base_node)

    # GEP into the sub-struct for the nested field
    fidx2: i32 = get_field_index(base_type, field_name)
    ftype2: str = get_field_type(base_type, field_name)
    mt2: str = mlir_type(ftype2)

    struct_mlir2: str = get_struct_mlir_type(base_type)
    fp2: str = new_tmp()
    emit_ind(Str.concat(Str.concat(Str.concat(fp2, " = llvm.getelementptr "), base_ptr), Str.concat(Str.concat("[0, ", Str.concat(Convert.i64_to_str(fidx2 as i64), "]")), Str.concat(" : (!llvm.ptr) -> !llvm.ptr, ", struct_mlir2))))

    val2: str = emit_load(fp2, mt2)
    return val2

# Returns pointer to a struct field WITHOUT loading (for nested chain)
fun gen_nested_field_ptr(node: i64) -> str:
    nt2: i32 = nd_type(node)

    if nt2 == NODE_FIELD_ACCESS:
        obj_name2: str = Memory.read_i64(node + 8) as str
        field2: str = Memory.read_i64(node + 16) as str
        obj_type2: str = get_var_type(obj_name2)
        obj_ptr2: str = gen_var_load(obj_name2, obj_type2)
        fidx3: i32 = get_field_index(obj_type2, field2)
        struct_mlir3: str = get_struct_mlir_type(obj_type2)
        fp3: str = new_tmp()
        emit_ind(Str.concat(Str.concat(Str.concat(fp3, " = llvm.getelementptr "), obj_ptr2), Str.concat(Str.concat("[0, ", Str.concat(Convert.i64_to_str(fidx3 as i64), "]")), Str.concat(" : (!llvm.ptr) -> !llvm.ptr, ", struct_mlir3))))
        return fp3

    if nt2 == NODE_NESTED_FIELD:
        inner_base: i64 = Memory.read_i64(node + 8)
        inner_field: str = Memory.read_i64(node + 16) as str
        inner_ptr: str = gen_nested_field_ptr(inner_base)
        inner_type: str = infer_expr_type(inner_base)
        fidx4: i32 = get_field_index(inner_type, inner_field)
        struct_mlir4: str = get_struct_mlir_type(inner_type)
        fp4: str = new_tmp()
        emit_ind(Str.concat(Str.concat(Str.concat(fp4, " = llvm.getelementptr "), inner_ptr), Str.concat(Str.concat("[0, ", Str.concat(Convert.i64_to_str(fidx4 as i64), "]")), Str.concat(" : (!llvm.ptr) -> !llvm.ptr, ", struct_mlir4))))
        return fp4

    if nt2 == NODE_SELF_FIELD:
        sf2: str = Memory.read_i64(node + 8) as str
        sf_type2: str = g_cur_method_struct
        fidx5: i32 = get_field_index(sf_type2, sf2)
        struct_mlir5: str = get_struct_mlir_type(sf_type2)
        fp5: str = new_tmp()
        emit_ind(Str.concat(Str.concat(Str.concat(fp5, " = llvm.getelementptr %self"), ""), Str.concat(Str.concat("[0, ", Str.concat(Convert.i64_to_str(fidx5 as i64), "]")), Str.concat(" : (!llvm.ptr) -> !llvm.ptr, ", struct_mlir5))))
        return fp5

    # Fallback: gen_expr and hope it returns a ptr
    fb_type: str = infer_expr_type(node)
    return gen_expr(node, fb_type)

# ==========================================
# Self Field Access (self.field in methods)
# ==========================================
fun gen_self_field_access(node: i64) -> str:
    field_name: str = Memory.read_i64(node + 8) as str
    sname: str = g_cur_method_struct

    fidx: i32 = get_field_index(sname, field_name)
    ftype: str = get_field_type(sname, field_name)
    mt: str = mlir_type(ftype)

    struct_mlir: str = get_struct_mlir_type(sname)
    fp: str = new_tmp()
    emit_ind(Str.concat(Str.concat(fp, " = llvm.getelementptr %self[0, "), Str.concat(Str.concat(Convert.i64_to_str(fidx as i64), "] : (!llvm.ptr) -> !llvm.ptr, "), struct_mlir)))

    val: str = emit_load(fp, mt)
    return val

# ==========================================
# Static Field Access (Struct.field)
# ==========================================
fun gen_static_field_access(node: i64) -> str:
    sname: str = Memory.read_i64(node + 8) as str
    fname: str = Memory.read_i64(node + 16) as str

    # Check if this is enum access (e.g., Direction.UP)
    if is_enum_type(sname) == 1:
        eidx: i32 = get_enum_value_index(sname, fname)
        return emit_const_i32(eidx)

    full: str = Str.concat(Str.concat(sname, "__"), fname)
    ga: str = emit_addr_of(full)
    sf_type: str = lookup_static_field_type(full)
    val: str = emit_load(ga, sf_type)
    return val

# ==========================================
# Function Call
# ==========================================
fun gen_fun_call(node: i64) -> str:
    fname: str = Memory.read_i64(node + 8) as str
    args_list: i64 = Memory.read_i64(node + 16)

    # Check if it's actually a struct instantiation
    if is_struct_type(fname) == 1:
        return gen_struct_instantiation(node)

    # Resolve overloaded function name
    ac: i32 = 0
    if args_list != 0:
        ac = nl_count(args_list)

    # Build arg types string for overload resolution
    arg_types_str: str = ""
    ati: i32 = 0
    while ati < ac:
        anode_t: i64 = nl_get(args_list, ati)
        at_raw: str = infer_expr_type(anode_t)
        at_norm: str = normalize_type(at_raw)
        if ati > 0:
            arg_types_str = Str.concat(arg_types_str, ",")
        arg_types_str = Str.concat(arg_types_str, at_norm)
        ati = ati + 1

    call_name: str = resolve_overload(fname, arg_types_str)

    # Check for annotation warnings at call site
    fn_flags: i32 = get_fn_annot_flags(call_name)
    if fn_flags == 1:
        # deprecated
        depr_msg: str = get_fn_annot_msg(call_name)
        IOOps.io_println(Str.concat("[WARNING] @deprecated: ", Str.concat(fname, Str.concat(" - ", depr_msg))))

    # Build argument list
    arg_str: str = ""
    type_str: str = ""

    i: i32 = 0
    while i < ac:
        anode: i64 = nl_get(args_list, i)
        at: str = infer_expr_type(anode)
        if str_eq(at, "unknown") == 1:
            at = "i64"

        # Check if function has registered param types (e.g., extern)
        expected_pt: str = get_fun_param_type(call_name, i)
        if str_eq(expected_pt, "") == 0:
            av: str = gen_expr(anode, expected_pt)
            if str_eq(at, expected_pt) == 0 and str_eq(at, "unknown") == 0:
                av = implicit_cast(av, at, expected_pt)
            amt: str = mlir_type(expected_pt)
            if i > 0:
                arg_str = Str.concat(arg_str, ", ")
                type_str = Str.concat(type_str, ", ")
            arg_str = Str.concat(arg_str, av)
            type_str = Str.concat(type_str, amt)
        else:
            av2: str = gen_expr(anode, at)
            amt2: str = mlir_type(at)
            if i > 0:
                arg_str = Str.concat(arg_str, ", ")
                type_str = Str.concat(type_str, ", ")
            arg_str = Str.concat(arg_str, av2)
            type_str = Str.concat(type_str, amt2)
        i = i + 1

    # Get return type (use mangled name for lookup)
    ret_type: str = get_fun_ret_type(call_name)
    ret_mt: str = ""
    if str_eq(ret_type, "unknown") == 0 and str_eq(ret_type, "") == 0 and str_eq(ret_type, "void") == 0:
        ret_mt = mlir_type(ret_type)

    # Emit call (using mangled name)
    if str_eq(ret_mt, "") == 1:
        emit_ind(Str.concat(Str.concat(Str.concat(Str.concat("llvm.call @", call_name), "("), arg_str), Str.concat(") : (", Str.concat(type_str, ") -> ()"))))
        return ""
    else:
        tmp: str = new_tmp()
        emit_ind(Str.concat(Str.concat(Str.concat(Str.concat(Str.concat(tmp, " = llvm.call @"), call_name), "("), arg_str), Str.concat(") : (", Str.concat(type_str, Str.concat(") -> ", ret_mt)))))
        return tmp

# ==========================================
# Static Method Call (Struct.method(...))
# ==========================================
fun gen_static_method_call(node: i64) -> str:
    sname: str = Memory.read_i64(node + 8) as str
    mname: str = Memory.read_i64(node + 16) as str
    args_list: i64 = Memory.read_i64(node + 24)

    # .new() constructor — redirect to struct instantiation
    if str_eq(mname, "new") == 1 and is_struct_type(sname) == 1:
        proxy: i64 = Memory.malloc_zeroed(NODE_SIZE as i64)
        Memory.write_i32(proxy, NODE_FUN_CALL)
        Memory.write_i64(proxy + 8, sname as i64)
        Memory.write_i64(proxy + 16, args_list)
        return gen_fun_call(proxy)

    # Mangled name: StructName_methodName
    mangled: str = Str.concat(Str.concat(sname, "_"), mname)

    # Build argument list
    arg_str: str = ""
    type_str: str = ""
    ac: i32 = 0
    if args_list != 0:
        ac = nl_count(args_list)

    # Look up method node to get param types
    method_node: i64 = find_impl_method(sname, mname)
    method_params: i64 = 0
    if method_node != 0:
        method_params = Memory.read_i64(method_node + 16)

    i: i32 = 0
    while i < ac:
        anode: i64 = nl_get(args_list, i)
        at: str = infer_expr_type(anode)
        if str_eq(at, "unknown") == 1:
            at = "i64"

        # Get expected param type from method definition
        expected_pt: str = ""
        if method_params != 0:
            if i < nl_count(method_params):
                mp_node: i64 = nl_get(method_params, i)
                expected_pt = Memory.read_i64(mp_node + 16) as str

        if str_eq(expected_pt, "") == 0:
            av: str = gen_expr(anode, expected_pt)
            amt: str = mlir_type(expected_pt)
            if str_eq(at, expected_pt) == 0:
                av = implicit_cast(av, at, expected_pt)
            if i > 0:
                arg_str = Str.concat(arg_str, ", ")
                type_str = Str.concat(type_str, ", ")
            arg_str = Str.concat(arg_str, av)
            type_str = Str.concat(type_str, amt)
        else:
            av2: str = gen_expr(anode, at)
            amt2: str = mlir_type(at)
            if i > 0:
                arg_str = Str.concat(arg_str, ", ")
                type_str = Str.concat(type_str, ", ")
            arg_str = Str.concat(arg_str, av2)
            type_str = Str.concat(type_str, amt2)
        i = i + 1

    # Get return type from impl method or function signature
    ret_type: str = get_fun_ret_type(mangled)
    if str_eq(ret_type, "unknown") == 1:
        # Try full name
        full: str = Str.concat(Str.concat(sname, "."), mname)
        ret_type = get_fun_ret_type(full)

    ret_mt: str = ""
    if str_eq(ret_type, "unknown") == 0 and str_eq(ret_type, "") == 0 and str_eq(ret_type, "void") == 0:
        ret_mt = mlir_type(ret_type)

    if str_eq(ret_mt, "") == 1:
        emit_ind(Str.concat(Str.concat(Str.concat(Str.concat("llvm.call @", mangled), "("), arg_str), Str.concat(") : (", Str.concat(type_str, ") -> ()"))))
        return ""
    else:
        tmp: str = new_tmp()
        emit_ind(Str.concat(Str.concat(Str.concat(Str.concat(Str.concat(tmp, " = llvm.call @"), mangled), "("), arg_str), Str.concat(") : (", Str.concat(type_str, Str.concat(") -> ", ret_mt)))))
        return tmp

# ==========================================
# Namespaced Function Call: ns.func(args)
# ==========================================
fun gen_ns_fun_call(node: i64) -> str:
    fname: str = Memory.read_i64(node + 16) as str
    args_list: i64 = Memory.read_i64(node + 24)
    proxy: i64 = Memory.malloc_zeroed(64)
    Memory.write_i32(proxy, 61)
    Memory.write_i64(proxy + 8, fname as i64)
    Memory.write_i64(proxy + 16, args_list)
    return gen_fun_call(proxy)

# ==========================================
# Namespaced Static Method: ns.Struct.method(args)
# ==========================================
fun gen_ns_static_method(node: i64) -> str:
    sname: str = Memory.read_i64(node + 16) as str
    mname: str = Memory.read_i64(node + 24) as str
    args_list: i64 = Memory.read_i64(node + 32)
    proxy: i64 = Memory.malloc_zeroed(64)
    Memory.write_i32(proxy, 85)
    Memory.write_i64(proxy + 8, sname as i64)
    Memory.write_i64(proxy + 16, mname as i64)
    Memory.write_i64(proxy + 24, args_list)
    return gen_static_method_call(proxy)

# ==========================================
# Instance Method Call (obj.method(...))
# ==========================================
fun gen_instance_method_call(node: i64) -> str:
    obj_name: str = Memory.read_i64(node + 8) as str
    mname: str = Memory.read_i64(node + 16) as str
    args_list: i64 = Memory.read_i64(node + 24)

    # Get struct type
    obj_type: str = ""
    obj_ptr: str = ""
    if str_eq(obj_name, "self") == 1:
        obj_type = g_cur_method_struct
        obj_ptr = "%self"
    else:
        obj_type = get_var_type(obj_name)
        obj_ptr = gen_var_load(obj_name, obj_type)

    # Strip generic parameter from type name (e.g., list[i32] -> list)
    base_type: str = obj_type
    bt_len: i64 = Memory.strlen(obj_type)
    bt_i: i64 = 0
    while bt_i < bt_len:
        if Memory.read_i8((obj_type as i64) + bt_i) == 91:
            base_type = str_from_range(obj_type, 0 as i64, bt_i)
            bt_i = bt_len
        bt_i = bt_i + 1

    # Mangled name
    mangled: str = Str.concat(Str.concat(base_type, "_"), mname)

    # Build argument list (self + args) and collect arg types for overload
    # Check if self is a value type (primitive / transparent)
    resolved_ot: str = resolve_type_full(base_type)
    self_val: i32 = 0
    if is_int_type(resolved_ot) == 1:
        self_val = 1
    elif is_float_type(resolved_ot) == 1:
        self_val = 1
    elif str_eq(resolved_ot, "bool") == 1:
        self_val = 1
    elif str_eq(resolved_ot, "char") == 1:
        self_val = 1
    elif is_int_type(base_type) == 1:
        self_val = 1
    elif is_float_type(base_type) == 1:
        self_val = 1
    elif str_eq(base_type, "bool") == 1:
        self_val = 1
    elif str_eq(base_type, "char") == 1:
        self_val = 1

    arg_str: str = obj_ptr
    type_str: str = "!llvm.ptr"
    if self_val == 1:
        type_str = mlir_type(resolved_ot)
    call_arg_types: str = ""

    ac: i32 = 0
    if args_list != 0:
        ac = nl_count(args_list)

    # Look up method node to get param types for implicit casting
    method_node2: i64 = find_impl_method(base_type, mname)
    method_params2: i64 = 0
    if method_node2 != 0:
        method_params2 = Memory.read_i64(method_node2 + 16)

    i: i32 = 0
    while i < ac:
        anode: i64 = nl_get(args_list, i)
        at: str = infer_expr_type(anode)
        if str_eq(at, "unknown") == 1:
            at = "i64"

        # Get expected param type from method definition (skip self at index 0)
        expected_pt2: str = ""
        if method_params2 != 0:
            param_idx: i32 = i + 1
            if param_idx < nl_count(method_params2):
                mp_node2: i64 = nl_get(method_params2, param_idx)
                expected_pt2 = Memory.read_i64(mp_node2 + 16) as str

        if str_eq(expected_pt2, "") == 0:
            av: str = gen_expr(anode, expected_pt2)
            if str_eq(at, expected_pt2) == 0 and str_eq(at, "unknown") == 0:
                # Only implicit cast for compatible types (e.g., i32->i64), not across categories
                if is_int_type(at) == 1 and is_int_type(expected_pt2) == 1:
                    av = implicit_cast(av, at, expected_pt2)
                    at = expected_pt2
                elif is_float_type(at) == 1 and is_float_type(expected_pt2) == 1:
                    av = implicit_cast(av, at, expected_pt2)
                    at = expected_pt2
            amt: str = mlir_type(at)
            arg_str = Str.concat(arg_str, Str.concat(", ", av))
            type_str = Str.concat(type_str, Str.concat(", ", amt))
        else:
            av2: str = gen_expr(anode, at)
            amt2: str = mlir_type(at)
            arg_str = Str.concat(arg_str, Str.concat(", ", av2))
            type_str = Str.concat(type_str, Str.concat(", ", amt2))

        # Build overload type string
        if Memory.strlen(call_arg_types) > 0:
            call_arg_types = Str.concat(call_arg_types, Str.concat(",", at))
        else:
            call_arg_types = at
        i = i + 1

    # Resolve overloaded method name
    mangled = resolve_overload(mangled, call_arg_types)

    # Get return type
    ret_type: str = get_fun_ret_type(mangled)
    # If method not found on child type, try parent type (inheritance)
    if str_eq(ret_type, "unknown") == 1:
        parent_type: str = get_parent_struct(base_type)
        if str_eq(parent_type, "") == 0:
            parent_mangled: str = Str.concat(Str.concat(parent_type, "_"), mname)
            parent_mangled = resolve_overload(parent_mangled, call_arg_types)
            parent_rt: str = get_fun_ret_type(parent_mangled)
            if str_eq(parent_rt, "unknown") == 0:
                mangled = parent_mangled
                ret_type = parent_rt
    ret_mt: str = ""
    if str_eq(ret_type, "unknown") == 0 and str_eq(ret_type, "") == 0 and str_eq(ret_type, "void") == 0:
        ret_mt = mlir_type(ret_type)

    if str_eq(ret_mt, "") == 1:
        emit_ind(Str.concat(Str.concat(Str.concat(Str.concat("llvm.call @", mangled), "("), arg_str), Str.concat(") : (", Str.concat(type_str, ") -> ()"))))
        return ""
    else:
        tmp: str = new_tmp()
        emit_ind(Str.concat(Str.concat(Str.concat(Str.concat(Str.concat(tmp, " = llvm.call @"), mangled), "("), arg_str), Str.concat(") : (", Str.concat(type_str, Str.concat(") -> ", ret_mt)))))
        return tmp

# ==========================================
# Super Method Call
# ==========================================
fun gen_super_method_call(node: i64) -> str:
    mname: str = Memory.read_i64(node + 8) as str
    args_list: i64 = Memory.read_i64(node + 16)

    # In Dolet, super calls the base class method
    # Look up parent struct from inheritance registry
    sname: str = g_cur_method_struct
    parent_sname: str = get_parent_struct(sname)
    if str_eq(parent_sname, "") == 0:
        sname = parent_sname
    mangled: str = Str.concat(Str.concat(sname, "_"), mname)

    arg_str: str = "%self"
    type_str: str = "!llvm.ptr"

    ac: i32 = 0
    if args_list != 0:
        ac = nl_count(args_list)

    i: i32 = 0
    while i < ac:
        anode: i64 = nl_get(args_list, i)
        at: str = infer_expr_type(anode)
        if str_eq(at, "unknown") == 1:
            at = "i64"
        av: str = gen_expr(anode, at)
        amt: str = mlir_type(at)
        arg_str = Str.concat(arg_str, Str.concat(", ", av))
        type_str = Str.concat(type_str, Str.concat(", ", amt))
        i = i + 1

    ret_type: str = get_fun_ret_type(mangled)
    ret_mt: str = ""
    if str_eq(ret_type, "unknown") == 0 and str_eq(ret_type, "") == 0:
        ret_mt = mlir_type(ret_type)

    if str_eq(ret_mt, "") == 1:
        emit_ind(Str.concat(Str.concat(Str.concat(Str.concat("llvm.call @", mangled), "("), arg_str), Str.concat(") : (", Str.concat(type_str, ") -> ()"))))
        return ""
    tmp: str = new_tmp()
    emit_ind(Str.concat(Str.concat(Str.concat(Str.concat(Str.concat(tmp, " = llvm.call @"), mangled), "("), arg_str), Str.concat(") : (", Str.concat(type_str, Str.concat(") -> ", ret_mt)))))
    return tmp

# ==========================================
# Array Access (arr[idx])
# ==========================================
fun gen_array_access(node: i64, expected: str) -> str:
    arr_node: i64 = Memory.read_i64(node + 8)
    idx_node: i64 = Memory.read_i64(node + 16)

    # Get array pointer
    arr_ptr: str = gen_expr(arr_node, "ptr")

    # Get index value
    idx_val: str = gen_expr(idx_node, "i64")

    # Ensure index is i64 (widen i32 loop vars)
    idx_type: str = infer_expr_type(idx_node)
    if str_eq(idx_type, "i32") == 1:
        idx_val = implicit_cast(idx_val, "i32", "i64")

    # Default element type
    elem_type: str = expected
    if str_eq(elem_type, "unknown") == 1:
        elem_type = "i64"
    mt: str = mlir_type(elem_type)

    # Calculate offset: header (16 bytes) + idx * elem_size
    elem_size: i32 = get_type_size(elem_type)
    es: str = emit_const_i64(elem_size as i64)
    off: str = new_tmp()
    emit_ind(Str.concat(Str.concat(Str.concat(Str.concat(off, " = llvm.mul "), idx_val), Str.concat(", ", es)), " : i64"))
    c16: str = emit_const_i64(16)
    off2: str = new_tmp()
    emit_ind(Str.concat(Str.concat(Str.concat(Str.concat(off2, " = llvm.add "), off), Str.concat(", ", c16)), " : i64"))

    ep: str = new_tmp()
    emit_ind(Str.concat(Str.concat(Str.concat(Str.concat(ep, " = llvm.getelementptr "), arr_ptr), Str.concat("[", Str.concat(off2, "]"))), " : (!llvm.ptr, i64) -> !llvm.ptr, i8"))

    val: str = emit_load(ep, mt)
    return val

##############################
# MLIR Codegen Main
# generate(), statement dispatch, runtime, main function
# Depends on: all other codegen files
##############################

# gen_statement and gen_var_decl moved to codegen_stmt.dlt (forward-ref fix)

# ==========================================
# Generate Pure Runtime Declarations
# ==========================================
fun gen_runtime_decls():
    # String comparison (inline implementation — no libc needed)
    emit_ind("// Inline strcmp implementation")
    emit_ind("llvm.func @strcmp(%a: !llvm.ptr, %b: !llvm.ptr) -> i32 {")
    emit_ind("  %zero = llvm.mlir.constant(0 : i32) : i32")
    emit_ind("  %one = llvm.mlir.constant(1 : i64) : i64")
    emit_ind("  %z8 = llvm.mlir.constant(0 : i8) : i8")
    emit_ind("  llvm.br ^loop(%a, %b : !llvm.ptr, !llvm.ptr)")
    emit_ind("^loop(%p1: !llvm.ptr, %p2: !llvm.ptr):")
    emit_ind("  %c1 = llvm.load %p1 : !llvm.ptr -> i8")
    emit_ind("  %c2 = llvm.load %p2 : !llvm.ptr -> i8")
    emit_ind("  %ne = llvm.icmp \"ne\" %c1, %c2 : i8")
    emit_ind("  llvm.cond_br %ne, ^diff(%c1, %c2 : i8, i8), ^same(%c1, %p1, %p2 : i8, !llvm.ptr, !llvm.ptr)")
    emit_ind("^same(%sc: i8, %sp1: !llvm.ptr, %sp2: !llvm.ptr):")
    emit_ind("  %isz = llvm.icmp \"eq\" %sc, %z8 : i8")
    emit_ind("  llvm.cond_br %isz, ^ret(%zero : i32), ^next(%sp1, %sp2 : !llvm.ptr, !llvm.ptr)")
    emit_ind("^next(%np1: !llvm.ptr, %np2: !llvm.ptr):")
    emit_ind("  %np1n = llvm.getelementptr %np1[%one] : (!llvm.ptr, i64) -> !llvm.ptr, i8")
    emit_ind("  %np2n = llvm.getelementptr %np2[%one] : (!llvm.ptr, i64) -> !llvm.ptr, i8")
    emit_ind("  llvm.br ^loop(%np1n, %np2n : !llvm.ptr, !llvm.ptr)")
    emit_ind("^diff(%d1: i8, %d2: i8):")
    emit_ind("  %e1 = llvm.zext %d1 : i8 to i32")
    emit_ind("  %e2 = llvm.zext %d2 : i8 to i32")
    emit_ind("  %res = llvm.sub %e1, %e2 : i32")
    emit_ind("  llvm.br ^ret(%res : i32)")
    emit_ind("^ret(%rv: i32):")
    emit_ind("  llvm.return %rv : i32")
    emit_ind("}")
    emit_blank()

    # Hash functions
    emit_ind("// Pure Dolet Runtime")

    # dsl_hash_i32
    emit_ind("llvm.func @dsl_hash_i32(%arg0: i32) -> i64 {")
    emit_ind("  %0 = llvm.sext %arg0 : i32 to i64")
    emit_ind("  %c = llvm.mlir.constant(2654435761 : i64) : i64")
    emit_ind("  %1 = llvm.mul %0, %c : i64")
    emit_ind("  llvm.return %1 : i64")
    emit_ind("}")
    emit_blank()

    # dsl_hash_i64
    emit_ind("llvm.func @dsl_hash_i64(%arg0: i64) -> i64 {")
    emit_ind("  %c = llvm.mlir.constant(11400714819323198485 : i64) : i64")
    emit_ind("  %1 = llvm.mul %arg0, %c : i64")
    emit_ind("  llvm.return %1 : i64")
    emit_ind("}")
    emit_blank()

    # dsl_hash_string (FNV-1a)
    emit_ind("llvm.func @dsl_hash_string(%arg0: !llvm.ptr) -> i64 {")
    emit_ind("  %offset_basis = llvm.mlir.constant(14695981039346656037 : i64) : i64")
    emit_ind("  %prime = llvm.mlir.constant(1099511628211 : i64) : i64")
    emit_ind("  %null = llvm.mlir.zero : !llvm.ptr")
    emit_ind("  %is_null = llvm.icmp \"eq\" %arg0, %null : !llvm.ptr")
    emit_ind("  llvm.cond_br %is_null, ^null, ^body(%offset_basis, %arg0 : i64, !llvm.ptr)")
    emit_ind("^null:")
    emit_ind("  %z = llvm.mlir.constant(0 : i64) : i64")
    emit_ind("  llvm.return %z : i64")
    emit_ind("^body(%hash: i64, %ptr: !llvm.ptr):")
    emit_ind("  %char = llvm.load %ptr : !llvm.ptr -> i8")
    emit_ind("  %end = llvm.mlir.constant(0 : i8) : i8")
    emit_ind("  %is_end = llvm.icmp \"eq\" %char, %end : i8")
    emit_ind("  llvm.cond_br %is_end, ^return(%hash : i64), ^process(%hash, %ptr, %char : i64, !llvm.ptr, i8)")
    emit_ind("^process(%h: i64, %p: !llvm.ptr, %c: i8):")
    emit_ind("  %c_i64 = llvm.sext %c : i8 to i64")
    emit_ind("  %h_xor = llvm.xor %h, %c_i64 : i64")
    emit_ind("  %h_new = llvm.mul %h_xor, %prime : i64")
    emit_ind("  %one = llvm.mlir.constant(1 : i64) : i64")
    emit_ind("  %next = llvm.getelementptr %p[%one] : (!llvm.ptr, i64) -> !llvm.ptr, i8")
    emit_ind("  llvm.br ^body(%h_new, %next : i64, !llvm.ptr)")
    emit_ind("^return(%final: i64):")
    emit_ind("  llvm.return %final : i64")
    emit_ind("}")
    emit_blank()

# ==========================================
# Generate String Constants
# ==========================================
fun gen_string_constants():
    i: i32 = 0
    while i < g_str_count:
        off8: i64 = (i as i64) * 8
        off4: i64 = (i as i64) * 4
        label: str = Memory.read_i64(g_str_labels + off8) as str
        text: str = Memory.read_i64(g_str_texts + off8) as str
        slen: i32 = Memory.read_i32(g_str_lens + off4)

        escaped: str = escape_mlir_string(text)
        # llvm.mlir.global internal constant @strN("text\00") {addr_space = 0 : i32} : !llvm.array<N x i8>
        emit_ind(Str.concat(Str.concat(Str.concat(Str.concat("llvm.mlir.global internal constant ", label), "(\""), escaped), Str.concat(Str.concat("\\00\") {addr_space = 0 : i32} : !llvm.array<", Convert.i64_to_str(slen as i64)), " x i8>")))
        i = i + 1
    emit_blank()

g_str_emitted_count: i32 = 0

# Emit string constants that were added after the initial gen_string_constants pass
fun gen_late_string_constants():
    if g_str_count <= g_str_emitted_count:
        return
    i: i32 = g_str_emitted_count
    while i < g_str_count:
        off8: i64 = (i as i64) * 8
        off4: i64 = (i as i64) * 4
        label: str = Memory.read_i64(g_str_labels + off8) as str
        text: str = Memory.read_i64(g_str_texts + off8) as str
        slen: i32 = Memory.read_i32(g_str_lens + off4)
        escaped: str = escape_mlir_string(text)
        emit_ind(Str.concat(Str.concat(Str.concat(Str.concat("llvm.mlir.global internal constant ", label), "(\""), escaped), Str.concat(Str.concat("\\00\") {addr_space = 0 : i32} : !llvm.array<", Convert.i64_to_str(slen as i64)), " x i8>")))
        i = i + 1
    emit_blank()

# ==========================================
# Collect Phase: scan AST and register types
# ==========================================
fun collect_declarations(ast: i64):
    sc: i32 = nl_count(ast)
    i: i32 = 0
    # Hoisted from loop to avoid alloca-in-loop stack overflow
    node: i64 = 0
    nt: i32 = 0
    ename: str = ""
    variants: i64 = 0
    vlist: i64 = 0
    vc: i32 = 0
    j: i32 = 0
    vnode: i64 = 0
    sname: str = ""
    fields: i64 = 0
    base_class: str = ""
    s_stack_alloc: i64 = 0
    s_type_params: i64 = 0
    tf: i64 = 0
    inner_t: str = ""
    parent_fields: i64 = 0
    pfc: i32 = 0
    merged: i64 = 0
    pi: i32 = 0
    cfc: i32 = 0
    ci: i32 = 0
    smethods: i64 = 0
    smc: i32 = 0
    sj: i32 = 0
    smnode: i64 = 0
    smname: str = ""
    smret: str = ""
    smangled: str = ""
    sm_params: i64 = 0
    sm_pt: str = ""
    fname: str = ""
    ret_type: str = ""
    fparams: i64 = 0
    fpt_str: str = ""
    mangled_fn: str = ""
    isname: str = ""
    methods: i64 = 0
    mc: i32 = 0
    j2: i32 = 0
    mnode: i64 = 0
    mname: str = ""
    mret: str = ""
    mangled: str = ""
    m_params: i64 = 0
    m_pt: str = ""
    etname: str = ""
    emethods: i64 = 0
    mc2: i32 = 0
    j3: i32 = 0
    enode: i64 = 0
    emname: str = ""
    emret: str = ""
    emangled_base: str = ""
    eparams: i64 = 0
    ept_str: str = ""
    epc: i32 = 0
    epi: i32 = 0
    epn: i64 = 0
    epname: str = ""
    eptype: str = ""
    emangled: str = ""
    vname2: str = ""
    aname: str = ""
    atarget: str = ""
    # Static field filtering variables (hoisted)
    total_fc: i32 = 0
    inst_fields: i64 = 0
    sfi: i32 = 0
    sf_node: i64 = 0
    sf_is_st: i64 = 0
    sf_nm: str = ""
    sf_tp: str = ""
    sf_full_nm: str = ""
    sf_def: i64 = 0
    while i < sc:
        node = nl_get(ast, i)
        nt = nd_type(node)

        # Enum declarations
        if nt == NODE_ENUM_DECL:
            ename = Memory.read_i64(node + 8) as str
            variants = Memory.read_i64(node + 16)
            vlist = mk_node_list(32)
            if variants != 0:
                vc = nl_count(variants)
                j = 0
                while j < vc:
                    vnode = nl_get(variants, j)
                    nl_add(vlist, vnode)
                    j = j + 1
            register_enum(ename, vlist)

        # Struct declarations
        if nt == NODE_STRUCT_DECL:
            sname = Memory.read_i64(node + 8) as str
            fields = Memory.read_i64(node + 16)
            base_class = Memory.read_i64(node + 32) as str
            s_stack_alloc = Memory.read_i64(node + 56)

            s_type_params = Memory.read_i64(node + 24)
            if s_type_params != 0:
                register_generic(sname, s_type_params)

            if s_stack_alloc == 2:
                if fields != 0:
                    if nl_count(fields) > 0:
                        tf = nl_get(fields, 0)
                        inner_t = Memory.read_i64(tf + 16) as str
                        register_transparent(sname, inner_t)
            else:
                if s_stack_alloc == 3:
                    register_heap_struct(sname)
                if str_eq(base_class, "") == 0:
                    parent_fields = get_struct_fields(base_class)
                    if parent_fields != 0:
                        pfc = nl_count(parent_fields)
                        merged = mk_node_list(64)
                        pi = 0
                        while pi < pfc:
                            nl_add(merged, nl_get(parent_fields, pi))
                            pi = pi + 1
                        if fields != 0:
                            cfc = nl_count(fields)
                            ci = 0
                            while ci < cfc:
                                nl_add(merged, nl_get(fields, ci))
                                ci = ci + 1
                        fields = merged
                    register_parent_struct(sname, base_class)
                if fields != 0:
                    # Separate instance fields from static fields
                    total_fc = nl_count(fields)
                    inst_fields = mk_node_list(64)
                    sfi = 0
                    while sfi < total_fc:
                        sf_node = nl_get(fields, sfi)
                        sf_is_st = Memory.read_i64(sf_node + 48)
                        if sf_is_st == 1:
                            sf_nm = Memory.read_i64(sf_node + 8) as str
                            sf_tp = Memory.read_i64(sf_node + 16) as str
                            if str_eq(sf_tp, "") == 1:
                                sf_tp = "i64"
                            sf_full_nm = Str.concat(Str.concat(sname, "__"), sf_nm)
                            sf_def = Memory.read_i64(sf_node + 32)
                            if sf_def != 0:
                                register_static_field_with_default(sf_full_nm, sf_tp, sf_def)
                            else:
                                register_static_field(sf_full_nm, sf_tp)
                        else:
                            nl_add(inst_fields, sf_node)
                        sfi = sfi + 1
                    register_struct(sname, inst_fields)
                smethods = Memory.read_i64(node + 40)
                if smethods != 0:
                    smc = nl_count(smethods)
                    sj = 0
                    while sj < smc:
                        smnode = nl_get(smethods, sj)
                        smname = Memory.read_i64(smnode + 8) as str
                        smret = Memory.read_i64(smnode + 24) as str
                        smangled = Str.concat(Str.concat(sname, "_"), smname)
                        sm_params = Memory.read_i64(smnode + 16)
                        sm_pt = build_param_types_str_no_self(sm_params)
                        register_fun_sig_with_params(smangled, smret, sm_pt)
                        register_impl_method(sname, smname, smnode)
                        sj = sj + 1

        # Function definitions
        if nt == NODE_FUN_DEF:
            fname = Memory.read_i64(node + 8) as str
            ret_type = Memory.read_i64(node + 24) as str
            fparams = Memory.read_i64(node + 16)
            fpt_str = build_param_types_str(fparams)
            mangled_fn = register_overload(fname, fpt_str)
            register_fun_sig_with_params(mangled_fn, ret_type, fpt_str)

        # Impl blocks
        if nt == NODE_IMPL_BLOCK:
            isname = Memory.read_i64(node + 8) as str
            methods = Memory.read_i64(node + 16)
            if methods != 0:
                mc = nl_count(methods)
                j2 = 0
                while j2 < mc:
                    mnode = nl_get(methods, j2)
                    mname = Memory.read_i64(mnode + 8) as str
                    mret = Memory.read_i64(mnode + 24) as str
                    mangled = Str.concat(Str.concat(isname, "_"), mname)
                    m_params = Memory.read_i64(mnode + 16)
                    m_pt = build_param_types_str_no_self(m_params)
                    mangled = register_overload(mangled, m_pt)
                    register_fun_sig_with_params(mangled, mret, m_pt)
                    register_impl_method(isname, mname, mnode)
                    j2 = j2 + 1

        # Extend blocks
        if nt == NODE_EXTEND_BLOCK:
            etname = Memory.read_i64(node + 8) as str
            emethods = Memory.read_i64(node + 16)
            if emethods != 0:
                mc2 = nl_count(emethods)
                j3 = 0
                while j3 < mc2:
                    enode = nl_get(emethods, j3)
                    emname = Memory.read_i64(enode + 8) as str
                    emret = Memory.read_i64(enode + 24) as str
                    emangled_base = Str.concat(Str.concat(etname, "_"), emname)
                    eparams = Memory.read_i64(enode + 16)
                    ept_str = ""
                    if eparams != 0:
                        epc = nl_count(eparams)
                        epi = 0
                        while epi < epc:
                            epn = nl_get(eparams, epi)
                            epname = Memory.read_i64(epn + 8) as str
                            if str_eq(epname, "self") == 0:
                                eptype = Memory.read_i64(epn + 16) as str
                                if Memory.strlen(ept_str) > 0:
                                    ept_str = Str.concat(ept_str, Str.concat(",", eptype))
                                else:
                                    ept_str = eptype
                            epi = epi + 1
                    emangled = register_overload(emangled_base, ept_str)
                    register_fun_sig_with_params(emangled, emret, ept_str)
                    register_impl_method(etname, emname, enode)
                    j3 = j3 + 1

        # Extern blocks
        if nt == NODE_EXTERN_BLOCK:
            register_extern_sigs(node)

        # Variable declarations
        if nt == NODE_VAR_DECL:
            vname2 = Memory.read_i64(node + 16) as str
            register_global_var(vname2, node)

        # List declarations — treated as ptr globals
        if nt == NODE_LIST_DECL:
            vname2 = Memory.read_i64(node + 8) as str
            register_global_list(vname2, node)

        # Type alias
        if nt == NODE_TYPE_ALIAS:
            aname = Memory.read_i64(node + 8) as str
            atarget = Memory.read_i64(node + 16) as str
            register_alias(aname, atarget)

        i = i + 1

# ==========================================
# Collect String Literals from AST
# ==========================================
fun collect_strings_list(nlist: i64):
    if nlist == 0:
        return
    lc: i32 = nl_count(nlist)
    li: i32 = 0
    while li < lc:
        collect_strings(nl_get(nlist, li))
        li = li + 1

fun collect_strings(node: i64):
    if node == 0:
        return
    nt: i32 = nd_type(node)

    if nt == NODE_STR_LIT:
        text: str = Memory.read_i64(node + 8) as str
        gen_string_const(text)
        return

    if nt == NODE_FSTRING:
        collect_strings_list(Memory.read_i64(node + 8))
        return

    # Recurse into all known node structures
    if nt == NODE_VAR_DECL:
        collect_strings(Memory.read_i64(node + 24))
        return
    if nt == NODE_ASSIGN or nt == NODE_FIELD_ASSIGN:
        collect_strings(Memory.read_i64(node + 16))
        return
    if nt == NODE_BINARY_OP or nt == NODE_COMPARISON or nt == NODE_LOGICAL_OP:
        collect_strings(Memory.read_i64(node + 16))
        collect_strings(Memory.read_i64(node + 24))
        return
    if nt == NODE_UNARY_OP:
        collect_strings(Memory.read_i64(node + 16))
        return
    if nt == NODE_CAST:
        collect_strings(Memory.read_i64(node + 8))
        return
    if nt == NODE_PAREN:
        collect_strings(Memory.read_i64(node + 8))
        return
    if nt == NODE_RETURN:
        collect_strings(Memory.read_i64(node + 8))
        return
    if nt == NODE_FUN_CALL or nt == NODE_BUILTIN_CALL:
        collect_strings_list(Memory.read_i64(node + 16))
        return
    if nt == NODE_STATIC_METHOD or nt == NODE_NS_FUN_CALL:
        collect_strings_list(Memory.read_i64(node + 24))
        return
    if nt == NODE_NS_STATIC_METHOD:
        collect_strings_list(Memory.read_i64(node + 32))
        return
    if nt == NODE_INST_METHOD:
        collect_strings_list(Memory.read_i64(node + 24))
        return
    if nt == NODE_FUN_DEF:
        collect_strings_list(Memory.read_i64(node + 32))
        return
    if nt == NODE_IF:
        collect_strings(Memory.read_i64(node + 8))
        collect_strings_list(Memory.read_i64(node + 16))
        collect_strings_list(Memory.read_i64(node + 24))
        return
    if nt == NODE_WHILE:
        collect_strings(Memory.read_i64(node + 8))
        collect_strings_list(Memory.read_i64(node + 16))
        return
    if nt == NODE_FOR:
        collect_strings(Memory.read_i64(node + 16))
        collect_strings(Memory.read_i64(node + 24))
        collect_strings_list(Memory.read_i64(node + 32))
        return
    if nt == NODE_FOR_EACH:
        collect_strings(Memory.read_i64(node + 32))
        collect_strings_list(Memory.read_i64(node + 40))
        return
    if nt == NODE_BLOCK:
        collect_strings_list(Memory.read_i64(node + 8))
        return
    if nt == NODE_ARRAY_LIT or nt == NODE_LIST_LIT:
        collect_strings_list(Memory.read_i64(node + 8))
        return
    if nt == NODE_TERNARY:
        collect_strings(Memory.read_i64(node + 8))
        collect_strings(Memory.read_i64(node + 16))
        collect_strings(Memory.read_i64(node + 24))
        return
    if nt == NODE_IMPL_BLOCK or nt == NODE_EXTEND_BLOCK:
        collect_strings_list(Memory.read_i64(node + 16))
        return
    if nt == NODE_STRUCT_DECL:
        collect_strings_list(Memory.read_i64(node + 40))
        return
    if nt == NODE_METHOD_DEF:
        collect_strings_list(Memory.read_i64(node + 32))
        return
    if nt == NODE_MATCH:
        collect_strings(Memory.read_i64(node + 8))
        collect_strings_list(Memory.read_i64(node + 16))
        collect_strings_list(Memory.read_i64(node + 24))
        return
    if nt == NODE_CASE:
        collect_strings_list(Memory.read_i64(node + 16))
        return
    if nt == NODE_STRUCT_INST:
        # field_vals node_list at +16, each field_val has value expr at +16
        fvl: i64 = Memory.read_i64(node + 16)
        if fvl != 0:
            fvc: i32 = nl_count(fvl)
            fi: i32 = 0
            while fi < fvc:
                fv: i64 = nl_get(fvl, fi)
                collect_strings(Memory.read_i64(fv + 16))
                fi = fi + 1
        return
    if nt == NODE_STRUCT_FIELD:
        # default value at +24
        collect_strings(Memory.read_i64(node + 24))
        return
    if nt == NODE_FIELD_VAL:
        # Keyword arg in struct construction: name at +8, value at +16
        collect_strings(Memory.read_i64(node + 16))
        return

fun collect_all_strings(ast: i64):
    sc: i32 = nl_count(ast)
    i: i32 = 0
    while i < sc:
        collect_strings(nl_get(ast, i))
        i = i + 1

# ==========================================
# Generate Global Variable Declarations
# ==========================================
fun gen_global_var_decls():
    if g_global_var_count == 0:
        return
    emit_ind("// Global variable declarations")
    i: i32 = 0
    while i < g_global_var_count:
        off: i64 = (i as i64) * 8
        gname: str = Memory.read_i64(g_global_var_names + off) as str
        gnode: i64 = Memory.read_i64(g_global_var_nodes + off)

        vtype: str = Memory.read_i64(gnode + 8) as str

        # If type is empty (const without annotation), infer from value expression
        if str_eq(vtype, "") == 1:
            val_node_infer: i64 = Memory.read_i64(gnode + 24)
            if val_node_infer != 0:
                vtype = infer_expr_type(val_node_infer)
            if str_eq(vtype, "") == 1 or str_eq(vtype, "unknown") == 1:
                vtype = "i64"

        mt: str = mlir_type(vtype)

        # Create unique mlir name
        mname: str = gname
        g_is_const: i32 = Memory.read_i64(gnode + 48) as i32
        add_variable(gname, mname, vtype, 2, g_is_const)

        # Emit global declaration
        emit_ind(Str.concat(Str.concat(Str.concat("llvm.mlir.global internal @", mname), " () {addr_space = 0 : i32} : "), Str.concat(mt, " {")))
        if is_string_type(vtype) == 1:
            emit_ind("  %0 = llvm.mlir.zero : !llvm.ptr")
            emit_ind("  llvm.return %0 : !llvm.ptr")
        elif is_int_type(vtype) == 1:
            emit_ind(Str.concat(Str.concat("  %0 = llvm.mlir.constant(0 : ", mt), Str.concat(") : ", mt)))
            emit_ind(Str.concat(Str.concat("  llvm.return %0 : ", mt), ""))
        elif is_float_type(vtype) == 1:
            emit_ind(Str.concat(Str.concat("  %0 = llvm.mlir.constant(0.0 : ", mt), Str.concat(") : ", mt)))
            emit_ind(Str.concat(Str.concat("  llvm.return %0 : ", mt), ""))
        else:
            emit_ind(Str.concat("  %0 = llvm.mlir.zero : ", mt))
            emit_ind(Str.concat("  llvm.return %0 : ", mt))
        emit_ind("}")
        i = i + 1
    emit_blank()

# ==========================================
# Generate Global List Declarations (list vars as !llvm.ptr globals)
# ==========================================
fun gen_global_list_decls():
    if g_global_list_count == 0:
        return
    emit_ind("// Global list variable declarations")
    i: i32 = 0
    while i < g_global_list_count:
        off: i64 = (i as i64) * 8
        lname: str = Memory.read_i64(g_global_list_names + off) as str
        add_variable(lname, lname, "list", 2, 0)
        emit_ind(Str.concat(Str.concat("llvm.mlir.global internal @", lname), " () {addr_space = 0 : i32} : !llvm.ptr {"))
        emit_ind("  %0 = llvm.mlir.zero : !llvm.ptr")
        emit_ind("  llvm.return %0 : !llvm.ptr")
        emit_ind("}")
        i = i + 1
    emit_blank()

# ==========================================
# Generate Struct Static Field Declarations
# ==========================================
fun gen_static_field_decls():
    if g_static_field_count == 0:
        return
    emit_ind("// Struct static field declarations")
    # Hoist variables to avoid alloca-in-loop
    i: i32 = 0
    off: i64 = 0
    sf_name: str = ""
    sf_type: str = ""
    sf_def: i64 = 0
    mt: str = ""
    def_int_val: str = "0"
    def_float_val: str = "0.0"
    def_nt: i32 = 0
    while i < g_static_field_count:
        off = (i as i64) * 8
        sf_name = Memory.read_i64(g_sf_names + off) as str
        sf_type = Memory.read_i64(g_sf_types + off) as str
        sf_def = Memory.read_i64(g_sf_defaults + off)
        mt = mlir_type(sf_type)
        add_variable(sf_name, sf_name, sf_type, 2, 0)
        emit_ind(Str.concat(Str.concat(Str.concat("llvm.mlir.global internal @", sf_name), " () {addr_space = 0 : i32} : "), Str.concat(mt, " {")))
        # Check for non-zero default literal values
        def_int_val = "0"
        def_float_val = "0.0"
        if sf_def != 0:
            def_nt = nd_type(sf_def)
            if def_nt == NODE_INT_LIT:
                def_int_val = Convert.i64_to_str(Memory.read_i64(sf_def + 8))
            elif def_nt == NODE_FLOAT_LIT:
                def_float_val = Memory.read_i64(sf_def + 8) as str
        if is_string_type(sf_type) == 1:
            emit_ind("  %0 = llvm.mlir.zero : !llvm.ptr")
            emit_ind("  llvm.return %0 : !llvm.ptr")
        elif is_int_type(sf_type) == 1:
            emit_ind(Str.concat(Str.concat("  %0 = llvm.mlir.constant(", def_int_val), Str.concat(Str.concat(" : ", mt), Str.concat(") : ", mt))))
            emit_ind(Str.concat("  llvm.return %0 : ", mt))
        elif is_float_type(sf_type) == 1:
            emit_ind(Str.concat(Str.concat("  %0 = llvm.mlir.constant(", def_float_val), Str.concat(Str.concat(" : ", mt), Str.concat(") : ", mt))))
            emit_ind(Str.concat("  llvm.return %0 : ", mt))
        else:
            emit_ind(Str.concat("  %0 = llvm.mlir.zero : ", mt))
            emit_ind(Str.concat("  llvm.return %0 : ", mt))
        emit_ind("}")
        i = i + 1
    emit_blank()

# ==========================================
# Function Deduplication (prevent duplicate MLIR emissions)
# ==========================================
g_emitted_fn_names: i64 = 0
g_emitted_fn_count: i32 = 0

fun init_emitted_fns():
    g_emitted_fn_names = Memory.malloc_zeroed(4096 * 8)
    g_emitted_fn_count = 0

fun is_fn_emitted(name: str) -> i32:
    i: i32 = 0
    while i < g_emitted_fn_count:
        off: i64 = (i as i64) * 8
        existing: str = Memory.read_i64(g_emitted_fn_names + off) as str
        if str_eq(existing, name) == 1:
            return 1
        i = i + 1
    return 0

fun mark_fn_emitted(name: str):
    if g_emitted_fn_count >= 4096:
        return
    off: i64 = (g_emitted_fn_count as i64) * 8
    Memory.write_i64(g_emitted_fn_names + off, name as i64)
    g_emitted_fn_count = g_emitted_fn_count + 1

# ==========================================
# Generate Functions
# ==========================================
fun gen_functions(ast: i64):
    sc: i32 = nl_count(ast)
    i: i32 = 0
    while i < sc:
        node: i64 = nl_get(ast, i)
        nt: i32 = nd_type(node)

        if nt == NODE_EXTERN_BLOCK:
            if ts_extern_block_has_reachable(node) == 1:
                gen_extern_block(node)
        elif nt == NODE_STRUCT_DECL:
            sdbg: str = Memory.read_i64(node + 8) as str
            # Skip @transparent structs — they have no MLIR representation
            s_sa: i64 = Memory.read_i64(node + 56)
            if s_sa != 2:
                if ts_is_reachable(sdbg) == 1:
                    if is_fn_emitted(sdbg) == 0:
                        mark_fn_emitted(sdbg)
                        gen_struct_inline_methods(node)
        elif nt == NODE_FUN_DEF:
            ts_fname: str = Memory.read_i64(node + 8) as str
            if ts_is_reachable(ts_fname) == 1:
                gen_fun_def(node)
        elif nt == NODE_IMPL_BLOCK:
            ts_sname: str = Memory.read_i64(node + 8) as str
            if ts_is_reachable(ts_sname) == 1:
                gen_impl_block(node)
        elif nt == NODE_EXTEND_BLOCK:
            ts_tname: str = Memory.read_i64(node + 8) as str
            if ts_is_reachable(ts_tname) == 1:
                gen_extend_block(node)
        i = i + 1

# ==========================================
# Generate Main Body (top-level statements)
# ==========================================
fun gen_main_body(ast: i64):
    sc: i32 = nl_count(ast)
    i: i32 = 0
    while i < sc:
        node: i64 = nl_get(ast, i)
        nt: i32 = nd_type(node)

        # Skip declarations (already generated)
        if nt == NODE_FUN_DEF:
            i = i + 1
        elif nt == NODE_STRUCT_DECL:
            i = i + 1
        elif nt == NODE_ENUM_DECL:
            i = i + 1
        elif nt == NODE_IMPL_BLOCK:
            i = i + 1
        elif nt == NODE_EXTEND_BLOCK:
            i = i + 1
        elif nt == NODE_EXTERN_BLOCK:
            i = i + 1
        elif nt == NODE_TRAIT_DECL:
            i = i + 1
        elif nt == NODE_TYPE_ALIAS:
            i = i + 1
        elif nt == NODE_IMPORT:
            i = i + 1
        else:
            # Top-level statement — generate in main
            gen_statement(node)
            i = i + 1

# ==========================================
# Check if AST has user-defined main
# ==========================================
fun has_user_main(ast: i64) -> i32:
    sc: i32 = nl_count(ast)
    i: i32 = 0
    while i < sc:
        node: i64 = nl_get(ast, i)
        nt: i32 = nd_type(node)
        if nt == NODE_FUN_DEF:
            fname: str = Memory.read_i64(node + 8) as str
            if str_eq(fname, "main") == 1:
                return 1
        i = i + 1
    return 0

# ==========================================
# Main Generate Function
# ==========================================
fun generate(ast: i64) -> str:
    init_all_registries()
    IOOps.io_println("[gen] init done")

    # Phase 1: Collect declarations
    collect_declarations(ast)
    IOOps.io_println("[gen] collect_declarations done")

    # Phase 1.5: Tree shaking (opt-in)
    run_tree_shaking(ast)

    # Phase 2: Collect string literals
    collect_all_strings(ast)
    IOOps.io_println("[gen] collect_strings done")

    # Phase 3: Emit module
    emit("// MLIR generated by Dolet Self-Hosting Compiler")
    emit("// Target: MLIR -> LLVM IR -> Machine Code")
    emit("")
    emit("module {")
    indent_inc()

    # String constants
    gen_string_constants()
    g_str_emitted_count = g_str_count

    # Windows helpers
    emit_ind("// Microsoft linker requires _fltused for floating-point code")
    emit_ind("llvm.mlir.global external @_fltused(1 : i32) {addr_space = 0 : i32} : i32")
    emit_blank()
    emit_ind("// Stack probe function for Windows")
    emit_ind("llvm.func @__chkstk() {")
    emit_ind("  llvm.return")
    emit_ind("}")
    emit_blank()

    # Runtime declarations
    gen_runtime_decls()

    # Global variable declarations
    gen_global_var_decls()

    # Global list declarations (list variables at top level)
    gen_global_list_decls()

    # Struct static field declarations
    gen_static_field_decls()

    # User-defined functions
    gen_functions(ast)

    # Main function (if user didn't define one)
    if has_user_main(ast) == 0:
        g_tmp_counter = 0
        emit_ind("llvm.func @main() -> i32 {")
        indent_inc()

        # Generate all top-level statements in source order
        # (var decls with init values are generated inline, preserving execution order)
        gen_main_body(ast)

        # Return 0
        c0: str = emit_const_i32(0)
        emit_ind(Str.concat(Str.concat("llvm.return ", c0), " : i32"))

        indent_dec()
        emit_ind("}")

    # Emit any string constants added during codegen
    gen_late_string_constants()

    indent_dec()
    emit("}")

    # Join all output lines — O(n) bulk copy instead of O(n²) concat
    # First pass: compute total length
    total_len: i64 = 0
    i: i32 = 0
    while i < g_out_count:
        total_len = total_len + Memory.strlen(get_output_line(i))
        if i > 0:
            total_len = total_len + 1
        i = i + 1
    # Second pass: copy into pre-allocated buffer
    buf: i64 = Memory.malloc(total_len + 1)
    pos: i64 = 0
    i = 0
    line: str = ""
    llen: i64 = 0
    while i < g_out_count:
        if i > 0:
            Memory.write_i8(buf + pos, 10 as i8)
            pos = pos + 1
        line = get_output_line(i)
        llen = Memory.strlen(line)
        if llen > 0:
            Memory.copy(buf + pos, line as i64, llen)
            pos = pos + llen
        i = i + 1
    Memory.write_i8(buf + pos, 0 as i8)
    return buf as str

# ===== Driver =====
##############################
# Pipeline Init
# Workaround for Python MLIR generator global init bug.
# Explicitly initializes ALL constants for tokenizer, parser, and codegen.
##############################

fun init_tokenizer_constants():
    TK_EOF = 0
    TK_NEWLINE = 1
    TK_IDENT = 2
    TK_INT = 3
    TK_INT64 = 4
    TK_FLOAT = 5
    TK_STRING = 6
    TK_CHAR = 7
    TK_FSTRING = 8
    TK_BOOL = 9
    TK_NULL = 10
    TK_HEX = 11
    TK_BINARY = 12
