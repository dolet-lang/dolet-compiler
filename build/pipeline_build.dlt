# FunctionReferenceNode: f0=name (str)
fun mk_fun_ref(name: str) -> i64:
    n: i64 = alloc_node(NODE_FUN_REF)
    Memory.write_i64(n + 8, name as i64)
    return n

fun funref_name(n: i64) -> str:
