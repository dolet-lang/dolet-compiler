fun funcall_args(n: i64) -> i64:
    return Memory.read_i64(n + 16)

fun funcall_type_args(n: i64) -> i64:
    return Memory.read_i64(n + 24)

# BuiltinCallNode: f0=name (str), f1=args (node_list)
fun mk_builtin_call(name: str, args: i64) -> i64:
    n: i64 = alloc_node(NODE_BUILTIN_CALL)
    Memory.write_i64(n + 8, name as i64)
    Memory.write_i64(n + 16, args)
    return n

fun builtin_name(n: i64) -> str:
    return Memory.read_i64(n + 8) as str

fun builtin_args(n: i64) -> i64:
