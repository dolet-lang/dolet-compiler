##############################
# Test 15: Struct Inheritance
# Tests struct extends and super method calls
##############################

struct Entity:
    x: i32
    y: i32

impl Entity:
    fun position() -> str:
        return @"({self.x}, {self.y})"

struct Player extends Entity:
    name: str
    health: i32 = 100

impl Player:
    fun info() -> str:
        return @"{self.name} at ({self.x}, {self.y}) HP: {self.health}"

p: Player = Player(name="Hero", x=10, y=20)
print(p.info())
print(p.x)
print(p.y)
