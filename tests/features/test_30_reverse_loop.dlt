##############################
# Test 30: Reverse Loop & Step
# Tests reverse for loop and negative step
##############################

# Reverse for loop (auto-reverse)
print("Reverse 5 to 0:")
for i in 5 to 0:
    print(i)

# Negative step
print("100 to 0 step -20:")
for i in 100 to 0 step -20:
    print(i)

# Normal step for comparison
print("0 to 10 step 3:")
for i in 0 to 10 step 3:
    print(i)
