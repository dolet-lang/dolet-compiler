##############################
# Test 19: Collections (list & array)
# Tests basic list and array creation
##############################

# List creation using list<T> syntax
nums: list<i32> = [10, 20, 30]
print(nums.size())

# Array creation
arr: array<i32> = [1, 2, 3, 4, 5]
for v in arr:
    print(v)

# List of strings
names: list<str> = ["Ali", "Sara"]
print(names.size())
