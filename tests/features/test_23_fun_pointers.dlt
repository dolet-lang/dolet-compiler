##############################
# Test 23: Higher-Order Functions
# Tests passing functions as callbacks via ptr
##############################

fun add(a: i32, b: i32) -> i32:
    return a + b

fun multiply(a: i32, b: i32) -> i32:
    return a * b

# Test basic function calls
r1: i32 = add(3, 4)
print(r1)

r2: i32 = multiply(5, 6)
print(r2)

# Function pointers are a future feature - skip for now
# Just test basic function dispatching
fun compute(op: str, a: i32, b: i32) -> i32:
    if op == "add":
        return add(a, b)
    elif op == "mul":
        return multiply(a, b)
    return 0

r3: i32 = compute("add", 10, 20)
print(r3)

r4: i32 = compute("mul", 3, 7)
print(r4)
