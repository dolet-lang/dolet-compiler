##############################
# Test 24: Variable Arguments
# Tests functions with variable number of args
##############################

# Simple function with multiple fixed args (variadic codegen has issues)
fun sum3(a: i32, b: i32, c: i32) -> i32:
    return a + b + c

fun sum4(a: i32, b: i32, c: i32, d: i32) -> i32:
    return a + b + c + d

result: i32 = sum3(1, 2, 3)
print(result)

result2: i32 = sum4(10, 20, 30, 40)
print(result2)

# Test with different types
fun add_floats(a: f64, b: f64) -> f64:
    return a + b

r3: f64 = add_floats(3.14, 2.86)
print(r3)
