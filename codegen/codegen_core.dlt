# ==========================================
# Output Buffer — stores MLIR lines as string pointers
# ==========================================
g_out: i64 = 0
g_out_count: i32 = 0
g_out_cap: i32 = 65536

fun init_codegen():
    g_out_cap = 65536
    g_out = Memory.malloc_zeroed((g_out_cap as i64) * 8)
    g_out_count = 0
    g_tmp_counter = 0
    g_label_counter = 0
    g_str_counter = 0
    g_indent_level = 0
    g_var_count = 0
    g_scope_depth = 0
    g_fun_sig_count = 0
    g_struct_count = 0
    g_enum_count = 0
    g_global_var_count = 0
    g_static_field_count = 0
    g_impl_count = 0
    g_in_function = 0
    g_cur_fn_ret_type = ""
    g_cur_fn_name = ""
    g_cur_method_struct = ""
    g_break_label = ""
    g_continue_label = ""

fun emit(line: str):
    off: i64 = (g_out_count as i64) * 8
    Memory.write_i64(g_out + off, line as i64)
    g_out_count = g_out_count + 1

fun emit_blank():
    emit("")

fun get_output_line(idx: i32) -> str:
    off: i64 = (idx as i64) * 8
    return Memory.read_i64(g_out + off) as str

# ==========================================
# Indentation
# ==========================================
g_indent_level: i32 = 0

fun ind() -> str:
    n: i32 = g_indent_level
    if n == 0:
        return ""
    if n == 1:
        return "  "
    if n == 2:
        return "    "
    if n == 3:
        return "      "
    if n == 4:
        return "        "
    if n == 5:
        return "          "
    # Fallback: build manually
    result: str = ""
    i: i32 = 0
    while i < n:
        result = Str.concat(result, "  ")
        i = i + 1
    return result

fun indent_inc():
    g_indent_level = g_indent_level + 1

fun indent_dec():
    if g_indent_level > 0:
        g_indent_level = g_indent_level - 1

# ==========================================
# Counters — tmp variables, labels, string constants
# ==========================================
g_tmp_counter: i32 = 0
g_label_counter: i32 = 0
g_str_counter: i32 = 0

fun new_tmp() -> str:
    n: i32 = g_tmp_counter
    g_tmp_counter = g_tmp_counter + 1
    return Str.concat("%", Convert.i64_to_str(n as i64))

fun new_label() -> str:
    n: i32 = g_label_counter
    g_label_counter = g_label_counter + 1
    return Str.concat("^bb", Convert.i64_to_str(n as i64))

fun new_str_label() -> str:
    n: i32 = g_str_counter
    g_str_counter = g_str_counter + 1
    return Str.concat("@str", Convert.i64_to_str(n as i64))

# ==========================================
# String Constants Pool
# Tracks pre-registered string constants for MLIR output
# ==========================================
g_str_labels: i64 = 0
g_str_texts: i64 = 0
g_str_lens: i64 = 0
g_str_count: i32 = 0
g_str_cap: i32 = 1024

fun init_str_pool():
    g_str_cap = 1024
    g_str_labels = Memory.malloc_zeroed((g_str_cap as i64) * 8)
    g_str_texts = Memory.malloc_zeroed((g_str_cap as i64) * 8)
    g_str_lens = Memory.malloc_zeroed((g_str_cap as i64) * 4)
    g_str_count = 0
    g_str_counter = 0

fun escaped_byte_len(text: str) -> i64:
    slen: i64 = Memory.strlen(text)
    count: i64 = 0
    i: i64 = 0
    while i < slen:
        c: i8 = Memory.read_i8((text as i64) + i)
        if c == 92 and i + 1 < slen:
            nc: i8 = Memory.read_i8((text as i64) + i + 1)
            if nc == 110 or nc == 116 or nc == 114 or nc == 48 or nc == 92 or nc == 34:
                count = count + 1
                i = i + 2
                continue
        count = count + 1
        i = i + 1
    return count

fun gen_string_const(text: str) -> str:
    # Check if already registered
    i: i32 = 0
    while i < g_str_count:
        off: i64 = (i as i64) * 8
        existing: str = Memory.read_i64(g_str_texts + off) as str
        if str_eq(existing, text) == 1:
            return Memory.read_i64(g_str_labels + off) as str
        i = i + 1
    # Register new
    label: str = new_str_label()
    slen: i64 = escaped_byte_len(text) + 1
    off2: i64 = (g_str_count as i64) * 8
    off3: i64 = (g_str_count as i64) * 4
    Memory.write_i64(g_str_labels + off2, label as i64)
    Memory.write_i64(g_str_texts + off2, text as i64)
    Memory.write_i32(g_str_lens + off3, slen as i32)
    g_str_count = g_str_count + 1
    return label

fun get_str_len(label: str) -> i32:
    i: i32 = 0
    while i < g_str_count:
        off: i64 = (i as i64) * 8
        existing: str = Memory.read_i64(g_str_labels + off) as str
        if str_eq(existing, label) == 1:
            return Memory.read_i32(g_str_lens + ((i as i64) * 4))
        i = i + 1
    return 0

# ==========================================
# Variable Registry
# ==========================================
g_var_names: i64 = 0
g_var_mlir: i64 = 0
g_var_types: i64 = 0
g_var_is_param: i64 = 0
g_var_count: i32 = 0
g_var_cap: i32 = 512

fun init_var_registry():
    g_var_cap = 512
    g_var_names = Memory.malloc_zeroed((g_var_cap as i64) * 8)
    g_var_mlir = Memory.malloc_zeroed((g_var_cap as i64) * 8)
    g_var_types = Memory.malloc_zeroed((g_var_cap as i64) * 8)
    g_var_is_param = Memory.malloc_zeroed((g_var_cap as i64) * 4)
    g_var_count = 0

fun add_variable(name: str, mlir_name: str, vtype: str, is_param: i32):
    off8: i64 = (g_var_count as i64) * 8
    off4: i64 = (g_var_count as i64) * 4
    Memory.write_i64(g_var_names + off8, name as i64)
    Memory.write_i64(g_var_mlir + off8, mlir_name as i64)
    Memory.write_i64(g_var_types + off8, vtype as i64)
    Memory.write_i32(g_var_is_param + off4, is_param)
    g_var_count = g_var_count + 1

fun get_mlir_name(name: str) -> str:
    i: i32 = g_var_count - 1
    while i >= 0:
        off: i64 = (i as i64) * 8
        vn: str = Memory.read_i64(g_var_names + off) as str
        if str_eq(vn, name) == 1:
            return Memory.read_i64(g_var_mlir + off) as str
        i = i - 1
    return ""

fun get_var_type(name: str) -> str:
    i: i32 = g_var_count - 1
    while i >= 0:
        off: i64 = (i as i64) * 8
        vn: str = Memory.read_i64(g_var_names + off) as str
        if str_eq(vn, name) == 1:
            return Memory.read_i64(g_var_types + off) as str
        i = i - 1
    return "unknown"

fun is_param_var(name: str) -> i32:
    i: i32 = g_var_count - 1
    while i >= 0:
        off8: i64 = (i as i64) * 8
        off4: i64 = (i as i64) * 4
        vn: str = Memory.read_i64(g_var_names + off8) as str
        if str_eq(vn, name) == 1:
            return Memory.read_i32(g_var_is_param + off4)
        i = i - 1
    return 0

# ==========================================
# Scope Management
# ==========================================
g_scope_marks: i64 = 0
g_scope_depth: i32 = 0

fun init_scopes():
    g_scope_marks = Memory.malloc_zeroed(256 * 4)
    g_scope_depth = 0

fun push_var_scope():
    off: i64 = (g_scope_depth as i64) * 4
    Memory.write_i32(g_scope_marks + off, g_var_count)
    g_scope_depth = g_scope_depth + 1

fun pop_var_scope():
    if g_scope_depth > 0:
        g_scope_depth = g_scope_depth - 1
        off: i64 = (g_scope_depth as i64) * 4
        g_var_count = Memory.read_i32(g_scope_marks + off)

# ==========================================
# Function Signature Registry
# ==========================================
g_fun_sig_names: i64 = 0
g_fun_sig_ret: i64 = 0
g_fun_sig_count: i32 = 0

fun init_fun_sigs():
    g_fun_sig_names = Memory.malloc_zeroed(512 * 8)
    g_fun_sig_ret = Memory.malloc_zeroed(512 * 8)
    g_fun_sig_params = Memory.malloc_zeroed(512 * 8)
    g_fun_sig_count = 0

g_fun_sig_params: i64 = 0

fun register_fun_sig(name: str, ret_type: str):
    off: i64 = (g_fun_sig_count as i64) * 8
    Memory.write_i64(g_fun_sig_names + off, name as i64)
    Memory.write_i64(g_fun_sig_ret + off, ret_type as i64)
    Memory.write_i64(g_fun_sig_params + off, "" as i64)
    g_fun_sig_count = g_fun_sig_count + 1

fun register_fun_sig_with_params(name: str, ret_type: str, param_types: str):
    off: i64 = (g_fun_sig_count as i64) * 8
    Memory.write_i64(g_fun_sig_names + off, name as i64)
    Memory.write_i64(g_fun_sig_ret + off, ret_type as i64)
    Memory.write_i64(g_fun_sig_params + off, param_types as i64)
    g_fun_sig_count = g_fun_sig_count + 1

fun get_fun_param_type(name: str, idx: i32) -> str:
    i: i32 = 0
    while i < g_fun_sig_count:
        off: i64 = (i as i64) * 8
        fn: str = Memory.read_i64(g_fun_sig_names + off) as str
        if str_eq(fn, name) == 1:
            pts: str = Memory.read_i64(g_fun_sig_params + off) as str
            plen: i64 = Memory.strlen(pts)
            if plen == 0:
                return ""
            # Split by comma, get idx-th element
            cur: i32 = 0
            start: i64 = 0
            j: i64 = 0
            while j <= plen:
                c: i8 = 0
                if j < plen:
                    c = Memory.read_i8((pts as i64) + j)
                if c == 44 or j == plen:
                    if cur == idx:
                        return str_from_range(pts, start, j)
                    cur = cur + 1
                    start = j + 1
                j = j + 1
            return ""
        i = i + 1
    return ""

fun get_fun_ret_type(name: str) -> str:
    i: i32 = 0
    while i < g_fun_sig_count:
        off: i64 = (i as i64) * 8
        fn: str = Memory.read_i64(g_fun_sig_names + off) as str
        if str_eq(fn, name) == 1:
            return Memory.read_i64(g_fun_sig_ret + off) as str
        i = i + 1
    return "unknown"

# ==========================================
# Struct Type Registry
# ==========================================
g_struct_names: i64 = 0
g_struct_field_lists: i64 = 0
g_struct_count: i32 = 0

fun init_struct_registry():
    g_struct_names = Memory.malloc_zeroed(256 * 8)
    g_struct_field_lists = Memory.malloc_zeroed(256 * 8)
    g_struct_count = 0

fun register_struct(name: str, fields: i64):
    off: i64 = (g_struct_count as i64) * 8
    Memory.write_i64(g_struct_names + off, name as i64)
    Memory.write_i64(g_struct_field_lists + off, fields)
    g_struct_count = g_struct_count + 1

fun is_struct_type(name: str) -> i32:
    i: i32 = 0
    while i < g_struct_count:
        off: i64 = (i as i64) * 8
        sn: str = Memory.read_i64(g_struct_names + off) as str
        if str_eq(sn, name) == 1:
            return 1
        i = i + 1
    return 0

fun get_struct_fields(name: str) -> i64:
    i: i32 = 0
    while i < g_struct_count:
        off: i64 = (i as i64) * 8
        sn: str = Memory.read_i64(g_struct_names + off) as str
        if str_eq(sn, name) == 1:
            return Memory.read_i64(g_struct_field_lists + off)
        i = i + 1
    return 0

# ==========================================
# Transparent Struct Registry
# @transparent struct maps to its inner raw type
# ==========================================
g_trans_names: i64 = 0
g_trans_inner: i64 = 0
g_trans_count: i32 = 0

fun init_transparent_registry():
    g_trans_names = Memory.malloc_zeroed(128 * 8)
    g_trans_inner = Memory.malloc_zeroed(128 * 8)
    g_trans_count = 0

fun register_transparent(name: str, inner_type: str):
    off: i64 = (g_trans_count as i64) * 8
    Memory.write_i64(g_trans_names + off, name as i64)
    Memory.write_i64(g_trans_inner + off, inner_type as i64)
    g_trans_count = g_trans_count + 1

fun is_transparent_type(name: str) -> i32:
    i: i32 = 0
    while i < g_trans_count:
        off: i64 = (i as i64) * 8
        tn: str = Memory.read_i64(g_trans_names + off) as str
        if str_eq(tn, name) == 1:
            return 1
        i = i + 1
    return 0

fun get_transparent_inner(name: str) -> str:
    i: i32 = 0
    while i < g_trans_count:
        off: i64 = (i as i64) * 8
        tn: str = Memory.read_i64(g_trans_names + off) as str
        if str_eq(tn, name) == 1:
            return Memory.read_i64(g_trans_inner + off) as str
        i = i + 1
    return ""

# ==========================================
# Type Alias Registry
# type i32 = I32 → resolve i32 to I32
# ==========================================
g_alias_names: i64 = 0
g_alias_targets: i64 = 0
g_alias_count: i32 = 0

fun init_alias_registry():
    g_alias_names = Memory.malloc_zeroed(128 * 8)
    g_alias_targets = Memory.malloc_zeroed(128 * 8)
    g_alias_count = 0

fun register_alias(name: str, target: str):
    off: i64 = (g_alias_count as i64) * 8
    Memory.write_i64(g_alias_names + off, name as i64)
    Memory.write_i64(g_alias_targets + off, target as i64)
    g_alias_count = g_alias_count + 1

fun resolve_alias(name: str) -> str:
    i: i32 = 0
    while i < g_alias_count:
        off: i64 = (i as i64) * 8
        an: str = Memory.read_i64(g_alias_names + off) as str
        if str_eq(an, name) == 1:
            return Memory.read_i64(g_alias_targets + off) as str
        i = i + 1
    return ""

# Resolve type through alias + transparent chain
# i32 → I32 → __i32 (transparent inner)
fun resolve_type_full(name: str) -> str:
    # Step 1: check alias
    target: str = resolve_alias(name)
    if str_eq(target, "") == 0:
        # Step 2: if aliased to transparent struct, return inner type
        if is_transparent_type(target) == 1:
            return get_transparent_inner(target)
        return target
    # Step 3: if name itself is transparent, return inner type
    if is_transparent_type(name) == 1:
        return get_transparent_inner(name)
    return name

# ==========================================
# Enum Type Registry
# ==========================================
g_enum_names: i64 = 0
g_enum_value_lists: i64 = 0
g_enum_count: i32 = 0

fun init_enum_registry():
    g_enum_names = Memory.malloc_zeroed(256 * 8)
    g_enum_value_lists = Memory.malloc_zeroed(256 * 8)
    g_enum_count = 0

fun register_enum(name: str, values: i64):
    off: i64 = (g_enum_count as i64) * 8
    Memory.write_i64(g_enum_names + off, name as i64)
    Memory.write_i64(g_enum_value_lists + off, values)
    g_enum_count = g_enum_count + 1

fun is_enum_type(name: str) -> i32:
    i: i32 = 0
    while i < g_enum_count:
        off: i64 = (i as i64) * 8
        en: str = Memory.read_i64(g_enum_names + off) as str
        if str_eq(en, name) == 1:
            return 1
        i = i + 1
    return 0

fun get_enum_value_index(enum_name: str, val_name: str) -> i32:
    i: i32 = 0
    while i < g_enum_count:
        off: i64 = (i as i64) * 8
        en: str = Memory.read_i64(g_enum_names + off) as str
        if str_eq(en, enum_name) == 1:
            vlist: i64 = Memory.read_i64(g_enum_value_lists + off)
            vc: i32 = nl_count(vlist)
            j: i32 = 0
            while j < vc:
                vnode: i64 = nl_get(vlist, j)
                vn: str = Memory.read_i64(vnode + 8) as str
                if str_eq(vn, val_name) == 1:
                    return j
                j = j + 1
            return -1
        i = i + 1
    return -1

# ==========================================
# Global Variable Tracking
# ==========================================
g_global_var_names: i64 = 0
g_global_var_nodes: i64 = 0
g_global_var_count: i32 = 0

fun init_global_vars():
    g_global_var_names = Memory.malloc_zeroed(256 * 8)
    g_global_var_nodes = Memory.malloc_zeroed(256 * 8)
    g_global_var_count = 0

fun register_global_var(name: str, node: i64):
    off: i64 = (g_global_var_count as i64) * 8
    Memory.write_i64(g_global_var_names + off, name as i64)
    Memory.write_i64(g_global_var_nodes + off, node)
    g_global_var_count = g_global_var_count + 1

fun is_global_var(name: str) -> i32:
    i: i32 = 0
    while i < g_global_var_count:
        off: i64 = (i as i64) * 8
        gn: str = Memory.read_i64(g_global_var_names + off) as str
        if str_eq(gn, name) == 1:
            return 1
        i = i + 1
    return 0

# ==========================================
# Static Fields Tracking
# ==========================================
g_sf_names: i64 = 0
g_sf_types: i64 = 0
g_static_field_count: i32 = 0

fun init_static_fields():
    g_sf_names = Memory.malloc_zeroed(256 * 8)
    g_sf_types = Memory.malloc_zeroed(256 * 8)
    g_static_field_count = 0

fun register_static_field(full_name: str, ftype: str):
    off: i64 = (g_static_field_count as i64) * 8
    Memory.write_i64(g_sf_names + off, full_name as i64)
    Memory.write_i64(g_sf_types + off, ftype as i64)
    g_static_field_count = g_static_field_count + 1

# ==========================================
# Impl Method Registry
# ==========================================
g_impl_struct: i64 = 0
g_impl_method_name: i64 = 0
g_impl_method_node: i64 = 0
g_impl_count: i32 = 0

fun init_impl_registry():
    g_impl_struct = Memory.malloc_zeroed(512 * 8)
    g_impl_method_name = Memory.malloc_zeroed(512 * 8)
    g_impl_method_node = Memory.malloc_zeroed(512 * 8)
    g_impl_count = 0

fun register_impl_method(sname: str, mname: str, mnode: i64):
    off: i64 = (g_impl_count as i64) * 8
    Memory.write_i64(g_impl_struct + off, sname as i64)
    Memory.write_i64(g_impl_method_name + off, mname as i64)
    Memory.write_i64(g_impl_method_node + off, mnode)
    g_impl_count = g_impl_count + 1

fun find_impl_method(sname: str, mname: str) -> i64:
    i: i32 = 0
    while i < g_impl_count:
        off: i64 = (i as i64) * 8
        s: str = Memory.read_i64(g_impl_struct + off) as str
        m: str = Memory.read_i64(g_impl_method_name + off) as str
        if str_eq(s, sname) == 1 and str_eq(m, mname) == 1:
            return Memory.read_i64(g_impl_method_node + off)
        i = i + 1
    return 0

# ==========================================
# Codegen State
# ==========================================
g_in_function: i32 = 0
g_cur_fn_ret_type: str = ""
g_cur_fn_name: str = ""
g_cur_method_struct: str = ""
g_break_label: str = ""
g_continue_label: str = ""

# ==========================================
# MLIR Type Mapping
fun mlir_type(dolet_type: str) -> str:
    # Resolve type aliases first (e.g. type UserID = i64)
    alias_resolved: str = resolve_alias(dolet_type)
    if str_eq(alias_resolved, "") == 0:
        return mlir_type(alias_resolved)

    # Direct struct type checks (for transparent types like I32, I64)
    if str_eq(dolet_type, "I8") == 1:
        return "i8"
    if str_eq(dolet_type, "I16") == 1:
        return "i16"
    if str_eq(dolet_type, "I32") == 1:
        return "i32"
    if str_eq(dolet_type, "I64") == 1:
        return "i64"
    if str_eq(dolet_type, "I128") == 1:
        return "i128"
    if str_eq(dolet_type, "U8") == 1:
        return "i8"
    if str_eq(dolet_type, "U16") == 1:
        return "i16"
    if str_eq(dolet_type, "U32") == 1:
        return "i32"
    if str_eq(dolet_type, "U64") == 1:
        return "i64"
    if str_eq(dolet_type, "U128") == 1:
        return "i128"
    if str_eq(dolet_type, "F32") == 1:
        return "f32"
    if str_eq(dolet_type, "F64") == 1:
        return "f64"
    if str_eq(dolet_type, "Bool") == 1:
        return "i1"
    if str_eq(dolet_type, "Char") == 1:
        return "i8"

    # Compiler intrinsic types (__i32 → LLVM i32, etc.)
    if str_eq(dolet_type, "__i8") == 1:
        return "i8"
    if str_eq(dolet_type, "__i16") == 1:
        return "i16"
    if str_eq(dolet_type, "__i32") == 1:
        return "i32"
    if str_eq(dolet_type, "__i64") == 1:
        return "i64"
    if str_eq(dolet_type, "__i128") == 1:
        return "i128"
    if str_eq(dolet_type, "__f32") == 1:
        return "f32"
    if str_eq(dolet_type, "__f64") == 1:
        return "f64"
    if str_eq(dolet_type, "__ptr") == 1:
        return "!llvm.ptr"
    if str_eq(dolet_type, "__bool") == 1:
        return "i1"
    if str_eq(dolet_type, "__char") == 1:
        return "i8"
    if str_eq(dolet_type, "__str") == 1:
        return "!llvm.ptr"
    if str_eq(dolet_type, "int") == 1:
        return "i32"
    if str_eq(dolet_type, "i8") == 1:
        return "i8"
    if str_eq(dolet_type, "i16") == 1:
        return "i16"
    if str_eq(dolet_type, "i32") == 1:
        return "i32"
    if str_eq(dolet_type, "i64") == 1:
        return "i64"
    if str_eq(dolet_type, "i128") == 1:
        return "i128"
    if str_eq(dolet_type, "u8") == 1:
        return "i8"
    if str_eq(dolet_type, "u16") == 1:
        return "i16"
    if str_eq(dolet_type, "u32") == 1:
        return "i32"
    if str_eq(dolet_type, "u64") == 1:
        return "i64"
    if str_eq(dolet_type, "u128") == 1:
        return "i128"
    if str_eq(dolet_type, "float") == 1:
        return "f32"
    if str_eq(dolet_type, "f32") == 1:
        return "f32"
    if str_eq(dolet_type, "double") == 1:
        return "f64"
    if str_eq(dolet_type, "f64") == 1:
        return "f64"
    if str_eq(dolet_type, "bool") == 1:
        return "i1"
    if str_eq(dolet_type, "i1") == 1:
        return "i1"
    if str_eq(dolet_type, "char") == 1:
        return "i8"
    if str_eq(dolet_type, "string") == 1:
        return "!llvm.ptr"
    if str_eq(dolet_type, "str") == 1:
        return "!llvm.ptr"
    if str_eq(dolet_type, "ptr") == 1:
        return "!llvm.ptr"
    if str_eq(dolet_type, "array") == 1:
        return "!llvm.ptr"
    if str_eq(dolet_type, "list") == 1:
        return "!llvm.ptr"
    if str_eq(dolet_type, "null") == 1:
        return "!llvm.ptr"
    # ptr[T] — all typed pointers are opaque pointers in MLIR
    if Memory.read_i8(dolet_type as i64) == 112:
        if Memory.read_i8((dolet_type as i64) + 1) == 116:
            if Memory.read_i8((dolet_type as i64) + 2) == 114:
                if Memory.read_i8((dolet_type as i64) + 3) == 91:
                    return "!llvm.ptr"
    # Check if enum (all enums are i32)
    if is_enum_type(dolet_type) == 1:
        return "i32"
    # Check if struct (all structs are pointers)
    if is_struct_type(dolet_type) == 1:
        return "!llvm.ptr"
    # Default: pointer
    return "!llvm.ptr"

# ==========================================
# Ptr[T] Type Helpers
# ==========================================
fun is_ptr_type(t: str) -> i32:
    tlen: i64 = Memory.strlen(t)
    if tlen < 5:
        return 0
    if Memory.read_i8(t as i64) == 112:
        if Memory.read_i8((t as i64) + 1) == 116:
            if Memory.read_i8((t as i64) + 2) == 114:
                if Memory.read_i8((t as i64) + 3) == 91:
                    return 1
    return 0

fun ptr_elem_type(t: str) -> str:
    # t = "ptr[i8]" → return "i8"
    slen: i64 = Memory.strlen(t)
    return str_from_range(t, 4, slen - 1)

# ==========================================
# Emit Helpers — common MLIR patterns
# ==========================================
fun emit_ind(text: str):
    emit(Str.concat(ind(), text))

fun emit_const_i32(val: i32) -> str:
    tmp: str = new_tmp()
    emit_ind(Str.concat(Str.concat(Str.concat(tmp, " = llvm.mlir.constant("), Convert.i64_to_str(val as i64)), " : i32) : i32"))
    return tmp

fun emit_const_i64(val: i64) -> str:
    tmp: str = new_tmp()
    emit_ind(Str.concat(Str.concat(Str.concat(tmp, " = llvm.mlir.constant("), Convert.i64_to_str(val)), " : i64) : i64"))
    return tmp

fun emit_const_i1(val: i32) -> str:
    tmp: str = new_tmp()
    emit_ind(Str.concat(Str.concat(Str.concat(tmp, " = llvm.mlir.constant("), Convert.i64_to_str(val as i64)), " : i1) : i1"))
    return tmp

fun emit_zero_ptr() -> str:
    tmp: str = new_tmp()
    emit_ind(Str.concat(tmp, " = llvm.mlir.zero : !llvm.ptr"))
    return tmp

fun emit_alloca(mtype: str) -> str:
    c1: str = emit_const_i64(1)
    alloc: str = new_tmp()
    emit_ind(Str.concat(Str.concat(Str.concat(Str.concat(alloc, " = llvm.alloca "), c1), Str.concat(" x ", mtype)), " : (i64) -> !llvm.ptr"))
    return alloc

fun emit_store(val: str, dest: str, mtype: str):
    emit_ind(Str.concat(Str.concat(Str.concat(Str.concat(Str.concat("llvm.store ", val), ", "), dest), Str.concat(" : ", mtype)), ", !llvm.ptr"))

fun emit_load(src: str, mtype: str) -> str:
    tmp: str = new_tmp()
    emit_ind(Str.concat(Str.concat(Str.concat(Str.concat(tmp, " = llvm.load "), src), Str.concat(" : !llvm.ptr -> ", mtype)), ""))
    return tmp

fun emit_addr_of(global_name: str) -> str:
    tmp: str = new_tmp()
    emit_ind(Str.concat(Str.concat(Str.concat(tmp, " = llvm.mlir.addressof @"), global_name), " : !llvm.ptr"))
    return tmp

fun emit_call(fn_name: str, args: str, arg_types: str, ret_type: str) -> str:
    if str_eq(ret_type, "") == 1:
        emit_ind(Str.concat(Str.concat(Str.concat(Str.concat("llvm.call @", fn_name), "("), args), Str.concat(") : (", Str.concat(arg_types, ") -> ()"))))
        return ""
    tmp: str = new_tmp()
    emit_ind(Str.concat(Str.concat(Str.concat(Str.concat(Str.concat(tmp, " = llvm.call @"), fn_name), "("), args), Str.concat(") : (", Str.concat(arg_types, Str.concat(") -> ", ret_type)))))
    return tmp

# ==========================================
# String Escape for MLIR
# ==========================================
fun escape_mlir_string(text: str) -> str:
    result: str = ""
    slen: i64 = Memory.strlen(text)
    i: i64 = 0
    while i < slen:
        c: i8 = Memory.read_i8((text as i64) + i)
        if c == 10:
            result = Str.concat(result, "\\0A")
        elif c == 13:
            result = Str.concat(result, "\\0D")
        elif c == 34:
            result = Str.concat(result, "\\22")
        elif c == 92:
            # Handle escape sequences: \n \t \r \0 \\ \"
            next_c: i8 = 0
            if i + 1 < slen:
                next_c = Memory.read_i8((text as i64) + i + 1)
            if next_c == 110:
                result = Str.concat(result, "\\0A")
                i = i + 1
            elif next_c == 116:
                result = Str.concat(result, "\\09")
                i = i + 1
            elif next_c == 114:
                result = Str.concat(result, "\\0D")
                i = i + 1
            elif next_c == 48:
                result = Str.concat(result, "\\00")
                i = i + 1
            elif next_c == 92:
                result = Str.concat(result, "\\5C")
                i = i + 1
            elif next_c == 34:
                result = Str.concat(result, "\\22")
                i = i + 1
            else:
                result = Str.concat(result, "\\5C")
        else:
            # Single char append — build 1-byte string
            buf: i64 = Memory.malloc_zeroed(2)
            Memory.write_i8(buf, c)
            Memory.write_i8(buf + 1, 0)
            result = Str.concat(result, buf as str)
        i = i + 1
    return result

# ==========================================
# Function Overload Registry
# ==========================================
g_ovl_orig: i64 = 0
g_ovl_params: i64 = 0
g_ovl_mangled: i64 = 0
g_ovl_count: i32 = 0

fun init_overload_registry():
    g_ovl_orig = Memory.malloc_zeroed(1024 * 8)
    g_ovl_params = Memory.malloc_zeroed(1024 * 8)
    g_ovl_mangled = Memory.malloc_zeroed(1024 * 8)
    g_ovl_count = 0

fun normalize_type(t: str) -> str:
    if str_eq(t, "string") == 1:
        return "str"
    if str_eq(t, "int") == 1:
        return "i32"
    if str_eq(t, "float") == 1:
        return "f32"
    if str_eq(t, "double") == 1:
        return "f64"
    return t

fun build_param_types_str(params: i64) -> str:
    if params == 0:
        return ""
    pc: i32 = nl_count(params)
    result: str = ""
    i: i32 = 0
    while i < pc:
        pnode: i64 = nl_get(params, i)
        ptype: str = Memory.read_i64(pnode + 16) as str
        ptype = normalize_type(ptype)
        if i > 0:
            result = Str.concat(result, ",")
        result = Str.concat(result, ptype)
        i = i + 1
    return result

fun register_overload(orig_name: str, param_types_str: str) -> str:
    # Check if this exact (orig_name, param_types) already exists
    i: i32 = 0
    while i < g_ovl_count:
        off: i64 = (i as i64) * 8
        en: str = Memory.read_i64(g_ovl_orig + off) as str
        ep: str = Memory.read_i64(g_ovl_params + off) as str
        if str_eq(en, orig_name) == 1 and str_eq(ep, param_types_str) == 1:
            return Memory.read_i64(g_ovl_mangled + off) as str
        i = i + 1

    # Check if any overload with same name exists
    has_existing: i32 = 0
    i = 0
    while i < g_ovl_count:
        off2: i64 = (i as i64) * 8
        en2: str = Memory.read_i64(g_ovl_orig + off2) as str
        if str_eq(en2, orig_name) == 1:
            has_existing = 1
            i = g_ovl_count
        i = i + 1

    # Build mangled name
    mangled: str = orig_name
    if has_existing == 1:
        # Subsequent overload: name__type1_type2
        # Replace commas with underscores
        suffix: str = ""
        slen: i64 = Memory.strlen(param_types_str)
        j: i64 = 0
        while j < slen:
            c: i8 = Memory.read_i8((param_types_str as i64) + j)
            if c == 44:
                suffix = Str.concat(suffix, "_")
            else:
                buf: i64 = Memory.malloc_zeroed(2)
                Memory.write_i8(buf, c)
                Memory.write_i8(buf + 1, 0)
                suffix = Str.concat(suffix, buf as str)
            j = j + 1
        mangled = Str.concat(Str.concat(orig_name, "__"), suffix)

    # Register
    off3: i64 = (g_ovl_count as i64) * 8
    Memory.write_i64(g_ovl_orig + off3, orig_name as i64)
    Memory.write_i64(g_ovl_params + off3, param_types_str as i64)
    Memory.write_i64(g_ovl_mangled + off3, mangled as i64)
    g_ovl_count = g_ovl_count + 1
    return mangled

fun resolve_overload(orig_name: str, arg_types_str: str) -> str:
    # Search for exact match on (orig_name, arg_types_str)
    i: i32 = 0
    while i < g_ovl_count:
        off: i64 = (i as i64) * 8
        en: str = Memory.read_i64(g_ovl_orig + off) as str
        ep: str = Memory.read_i64(g_ovl_params + off) as str
        if str_eq(en, orig_name) == 1 and str_eq(ep, arg_types_str) == 1:
            return Memory.read_i64(g_ovl_mangled + off) as str
        i = i + 1
    # No overload found — return original name
    return orig_name

# ==========================================
# Generic Type Registry
# Tracks which struct names have type parameters
# ==========================================
g_generic_names: i64 = 0
g_generic_params: i64 = 0
g_generic_count: i32 = 0

fun init_generic_registry():
    g_generic_names = Memory.malloc_zeroed(128 * 8)
    g_generic_params = Memory.malloc_zeroed(128 * 8)
    g_generic_count = 0

fun register_generic(name: str, params: i64):
    off: i64 = (g_generic_count as i64) * 8
    Memory.write_i64(g_generic_names + off, name as i64)
    Memory.write_i64(g_generic_params + off, params)
    g_generic_count = g_generic_count + 1

fun is_generic_type(name: str) -> i32:
    i: i32 = 0
    while i < g_generic_count:
        off: i64 = (i as i64) * 8
        if str_eq(Memory.read_i64(g_generic_names + off) as str, name) == 1:
            return 1
        i = i + 1
    return 0

fun get_generic_params(name: str) -> i64:
    i: i32 = 0
    while i < g_generic_count:
        off: i64 = (i as i64) * 8
        if str_eq(Memory.read_i64(g_generic_names + off) as str, name) == 1:
            return Memory.read_i64(g_generic_params + off)
        i = i + 1
    return 0

# ==========================================
# Init All Registries
# ==========================================
fun init_all_registries():
    init_ast_constants()
    init_codegen()
    init_str_pool()
    init_var_registry()
    init_scopes()
    init_fun_sigs()
    init_struct_registry()
    init_transparent_registry()
    init_alias_registry()
    init_enum_registry()
    init_global_vars()
    init_static_fields()
    init_impl_registry()
    init_overload_registry()
    init_generic_registry()
    # Pre-register common strings
    gen_string_const("%s\n")
    gen_string_const("null")
    gen_string_const("")
    gen_string_const("true")
    gen_string_const("false")
