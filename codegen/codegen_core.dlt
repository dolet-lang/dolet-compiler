##############################
# MLIR Codegen Core
# State, output buffer, string pool, MLIR types,
# variable registry, scoping, counters, helpers
##############################

# ==========================================
# String Utility Functions
# ==========================================
fun str_eq(a: str, b: str) -> i32:
    la: i64 = Memory.strlen(a)
    lb: i64 = Memory.strlen(b)
    if la != lb:
        return 0
    i: i64 = 0
    while i < la:
        ca: i8 = Memory.read_i8((a as i64) + i)
        cb: i8 = Memory.read_i8((b as i64) + i)
        if ca != cb:
            return 0
        i = i + 1
    return 1

fun str_from_range(src: str, start: i64, end_pos: i64) -> str:
    slen: i64 = end_pos - start
    if slen <= 0:
        return ""
    buf: i64 = Memory.malloc_zeroed(slen + 1)
    i: i64 = 0
    while i < slen:
        ch: i8 = Memory.read_i8((src as i64) + start + i)
        Memory.write_i8(buf + i, ch)
        i = i + 1
    Memory.write_i8(buf + slen, 0)
    return buf as str

fun char_at(s: str, idx: i64) -> i8:
    return Memory.read_i8((s as i64) + idx)

fun panic(msg: str):
    IOOps.io_println(msg)
    ExitProcess(1)

